NODE_ENV=production
APP_VERSION=0.1.0
PORT=8788
API_HOST_PORT=8788
POSTGRES_HOST_PORT=55433

POSTGRES_DB=rebase
POSTGRES_USER=rebase
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=https://api.rebase.network
CORS_ALLOWED_ORIGINS=https://rebase.network,https://rebase.community,https://admin.rebase.network

DEV_ADMIN_EMAIL=admin@rebase.network
DEV_ADMIN_PASSWORD=replace-with-a-strong-admin-password
DEV_ADMIN_NAME=Rebase Super Admin

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=rebase-media
R2_PUBLIC_BASE_URL=
R2_DEV_USE_WRANGLER=true
CLOUDFLARE_API_TOKEN=
WRANGLER_CONFIG_DIR=/home/rebase/.config/.wrangler

CLOUDFLARED_TUNNEL_TOKEN=
