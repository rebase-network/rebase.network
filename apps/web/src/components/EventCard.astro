---
import type { Event } from '@rebase/types';
import { formatEventWindow } from '@/lib/dates';
import { resolvePublicEventStatus } from '@/lib/eventStatus';
import { DEFAULT_EVENT_COVER_PATH } from '@/lib/placeholders';
import { getEventPath } from '@/lib/paths';

interface Props {
  event: Event;
  compact?: boolean;
}

const { event, compact = false } = Astro.props;
const eventStatus = resolvePublicEventStatus(event);
---

<article class:list={['event-card', 'card', { compact }]}>
  <a class="cover-link" href={getEventPath(event.publicNumber, event.slug)} aria-label={event.title}>
    <img
      class:list={['cover-image', !event.coverImageUrl && 'default-cover-image']}
      src={event.coverImageUrl ?? DEFAULT_EVENT_COVER_PATH}
      alt=""
      loading="lazy"
    />
  </a>
  <div class="content">
    <div class="status-row">
      <p class="status">{eventStatus.statusLabel}</p>
      <span class:list={['chip', eventStatus.isPast && 'is-past']}>{eventStatus.actionLabel}</span>
    </div>
    <h3>
      <a href={getEventPath(event.publicNumber, event.slug)}>{event.title}</a>
    </h3>
    <p class="summary">{event.summary}</p>
    <ul class="meta-list">
      <li>{formatEventWindow(event.startAt, event.endAt)}</li>
      <li>{event.location} · {event.venue}</li>
    </ul>
    {!compact && event.tags.length > 0 && (
      <ul class="tag-list">
        {event.tags.map((tag) => <li>{tag}</li>)}
      </ul>
    )}
  </div>
</article>

<style>
  .event-card {
    display: grid;
    overflow: hidden;
  }

  .event-card:hover,
  .event-card:focus-within {
    transform: translateY(-2px);
    border-color: rgba(15, 118, 110, 0.2);
    box-shadow: var(--shadow-strong);
  }

  .cover-link {
    display: block;
    overflow: hidden;
    aspect-ratio: 5 / 3;
    background: linear-gradient(135deg, rgba(15, 118, 110, 0.12), rgba(17, 94, 89, 0.04));
  }

  .cover-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 260ms ease;
  }

  .default-cover-image {
    background: transparent;
  }

  .event-card:hover .cover-image,
  .event-card:focus-within .cover-image {
    transform: scale(1.03);
  }

  .content {
    padding: 1.25rem;
  }

  .status {
    margin: 0 0 0.8rem;
    color: var(--accent-strong);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    text-transform: none;
  }

  .status-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
  }

  .status {
    margin-bottom: 0;
  }

  .chip {
    padding: 0.34rem 0.68rem;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.08);
    color: var(--accent-strong);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: none;
  }

  .chip.is-past {
    background: rgba(92, 107, 115, 0.08);
    color: var(--muted);
  }

  h3 {
    margin: 0 0 0.7rem;
    font-size: 1.45rem;
    line-height: 1.08;
  }

  h3 a {
    transition: color 160ms ease;
  }

  .event-card:hover h3 a,
  .event-card:focus-within h3 a {
    color: var(--accent-strong);
  }

  .summary {
    margin: 0 0 1rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .meta-list {
    margin: 0;
    padding-left: 1rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tag-list li {
    padding: 0.36rem 0.7rem;
    border-radius: 999px;
    background: rgba(17, 94, 89, 0.08);
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .compact {
    display: grid;
  }

  .compact .content {
    padding: 1.05rem;
  }

  .compact h3 {
    margin-bottom: 0.6rem;
    font-size: 1.28rem;
  }

  .compact .summary {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    margin-bottom: 0.85rem;
  }

  .compact .meta-list {
    font-size: 0.95rem;
  }
</style>
