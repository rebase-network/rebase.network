---
interface Props {
  kicker: string;
  title: string;
  description: string;
  variant?: 'default' | 'cool';
}

const { kicker, title, description, variant = 'default' } = Astro.props;
---

<article class:list={['card', 'list-empty-state', { 'variant-cool': variant === 'cool' }]}>
  <p class="hero-kicker">{kicker}</p>
  <h2>{title}</h2>
  <p class="empty-copy">{description}</p>
</article>

<style>
  .list-empty-state {
    padding: 1.35rem;
    border: 1px solid rgba(31, 41, 51, 0.08);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(248, 252, 251, 0.9));
  }

  h2,
  .empty-copy {
    margin: 0;
  }

  h2 {
    margin-top: 1rem;
    font-size: clamp(1.55rem, 2.4vw, 2.35rem);
    line-height: 1.08;
  }

  .empty-copy {
    margin-top: 0.8rem;
    color: var(--muted);
    line-height: 1.8;
  }

  .variant-cool {
    background:
      radial-gradient(circle at top right, rgba(125, 211, 252, 0.16), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(246, 251, 252, 0.9));
  }
</style>
