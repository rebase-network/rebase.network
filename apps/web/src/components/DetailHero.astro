---
interface BreadcrumbItem {
  href?: string;
  label: string;
  current?: boolean;
}

interface DetailAction {
  href: string;
  label: string;
  external?: boolean;
  secondary?: boolean;
  showIcon?: boolean;
}

interface Props {
  kicker?: string;
  edition?: string;
  title: string;
  summary: string;
  note?: string;
  breadcrumbs?: BreadcrumbItem[];
  meta?: string[];
  actions?: DetailAction[];
  jumps?: Array<{ href: string; label: string }>;
  heroClass?: string;
  heroStyle?: string;
  hideTopline?: boolean;
  titleAside?: string;
  inlineMetaActions?: boolean;
}

const {
  kicker,
  edition,
  title,
  summary,
  note,
  breadcrumbs = [],
  meta = [],
  actions = [],
  jumps = [],
  heroClass,
  heroStyle,
  hideTopline = false,
  titleAside,
  inlineMetaActions = false,
} = Astro.props;

const metaItems = meta.filter(Boolean);
---

<article class:list={['hero-panel', 'card', 'detail-hero', heroClass]} style={heroStyle}>
  {!hideTopline && (kicker || breadcrumbs.length > 0 || edition) && (
    <div class="detail-topline">
      <div class="detail-context">
        {kicker && <p class="hero-kicker light">{kicker}</p>}
        {breadcrumbs.length > 0 && (
          <nav class="detail-breadcrumbs light" aria-label="Breadcrumb">
            {breadcrumbs.map((item, index) => (
              <>
                {item.current || !item.href ? (
                  <span aria-current={item.current ? 'page' : undefined}>{item.label}</span>
                ) : (
                  <a href={item.href}>{item.label}</a>
                )}
                {index < breadcrumbs.length - 1 && <span aria-hidden="true">/</span>}
              </>
            ))}
          </nav>
        )}
      </div>
      {edition && <span class="detail-edition">{edition}</span>}
    </div>
  )}

  <div class:list={['detail-title-row', titleAside && 'has-aside']}>
    <h1 class="hero-title light">{title}</h1>
    {titleAside && <span class="detail-title-aside light">{titleAside}</span>}
  </div>
  <p class="hero-summary light">{summary}</p>

  {inlineMetaActions ? (
    (metaItems.length > 0 || actions.length > 0) && (
      <div class="detail-footer-row">
        {metaItems.length > 0 && (
          <div class="detail-meta-strip">
            {metaItems.map((item) => (
              <span class="detail-meta-pill">{item}</span>
            ))}
          </div>
        )}

        {actions.length > 0 && (
          <div class="button-row inline-actions">
            {actions.map((action) => (
              <a
                class:list={['button-link', { secondary: action.secondary }]}
                href={action.href}
                target={action.external ? '_blank' : undefined}
                rel={action.external ? 'noreferrer' : undefined}
              >
                {action.label}
                {(action.showIcon ?? action.external) && <span>↗</span>}
              </a>
            ))}
          </div>
        )}
      </div>
    )
  ) : (
    <>
      {metaItems.length > 0 && (
        <div class="detail-meta-strip">
          {metaItems.map((item) => (
            <span class="detail-meta-pill">{item}</span>
          ))}
        </div>
      )}

      {actions.length > 0 && (
        <div class="button-row">
          {actions.map((action) => (
            <a
              class:list={['button-link', { secondary: action.secondary }]}
              href={action.href}
              target={action.external ? '_blank' : undefined}
              rel={action.external ? 'noreferrer' : undefined}
            >
              {action.label}
              {(action.showIcon ?? action.external) && <span>↗</span>}
            </a>
          ))}
        </div>
      )}
    </>
  )}

  {note && <p class="detail-hero-note light">{note}</p>}

  {jumps.length > 0 && (
    <div class="detail-jump-list">
      {jumps.map((jump) => (
        <a href={jump.href}>{jump.label}</a>
      ))}
    </div>
  )}
</article>

<style>
  .detail-title-row,
  .detail-footer-row {
    display: grid;
    gap: 0.75rem;
  }

  .detail-title-row.has-aside {
    align-items: start;
  }

  .inline-actions {
    margin-top: 0;
  }

  @media (min-width: 781px) {
    .article-hero .detail-title-row.has-aside,
    .article-hero .detail-footer-row {
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .article-hero .detail-footer-row {
      align-items: center;
    }
  }
</style>
