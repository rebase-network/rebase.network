---
import type { Contributor } from '@rebase/types';
import { createAvatarData } from '@/lib/avatar';
import { renderMarkdown } from '@/lib/markdown';

interface Props {
  contributor: Contributor;
}

const { contributor } = Astro.props;
const avatarBackground = createAvatarData(contributor.avatarSeed);
const bioHtml = renderMarkdown(contributor.bio);
const telegramHref = contributor.telegram
  ? contributor.telegram.startsWith('http')
    ? contributor.telegram
    : `https://t.me/${contributor.telegram.replace(/^@/, '')}`
  : undefined;
const hasContacts = Boolean(contributor.twitterUrl || telegramHref || contributor.wechat);
const isHistoricalContributor = contributor.activityStatus === 'inactive';
---

<article class="contributor-card card">
  {contributor.avatarUrl ? (
    <img class="avatar image" src={contributor.avatarUrl} alt={`${contributor.name} 头像`} loading="lazy" />
  ) : (
    <div class="avatar" style={`background:${avatarBackground}`}>
      <span>{contributor.name.slice(0, 1)}</span>
    </div>
  )}
  <div class="content">
    {isHistoricalContributor && <p class="profile-kicker">历史贡献者</p>}
    <h3>{contributor.name}</h3>
    <p class="headline">{contributor.headline}</p>
    <div class="bio" set:html={bioHtml} />
    {hasContacts && (
      <ul class="contact-list">
        {contributor.twitterUrl && (
          <li><a href={contributor.twitterUrl} target="_blank" rel="noreferrer">X / Twitter</a></li>
        )}
        {telegramHref && (
          <li><a href={telegramHref} target="_blank" rel="noreferrer">{contributor.telegram}</a></li>
        )}
        {contributor.wechat && <li><span>微信：{contributor.wechat}</span></li>}
      </ul>
    )}
  </div>
</article>

<style>
  .contributor-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    padding: 1.15rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(247, 252, 250, 0.86));
  }

  .contributor-card:hover,
  .contributor-card:focus-within {
    transform: translateY(-4px);
    border-color: rgba(15, 118, 110, 0.18);
    box-shadow: var(--shadow-strong);
  }

  .avatar {
    display: grid;
    width: 4rem;
    height: 4rem;
    place-items: center;
    border-radius: 1.25rem;
    color: white;
    font-size: 1.35rem;
    font-weight: 800;
    box-shadow: 0 16px 32px rgba(26, 40, 34, 0.12);
  }

  .image {
    object-fit: cover;
  }

  .content h3,
  .profile-kicker,
  .headline,
  .bio,
  .contact-list {
    margin: 0;
  }

  .profile-kicker {
    color: var(--accent-strong);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .content h3 {
    margin-top: 0.2rem;
    font-size: 1.4rem;
    line-height: 1.08;
  }

  .headline {
    margin-top: 0.2rem;
    color: var(--accent-strong);
    font-weight: 700;
    line-height: 1.5;
  }

  .bio {
    margin-top: 0.65rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .bio :global(p) {
    margin: 0;
  }

  .contact-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.95rem;
    padding: 0;
    list-style: none;
  }

  .contact-list a,
  .contact-list span {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.74rem;
    border: 1px solid rgba(15, 118, 110, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.78);
    color: var(--accent-strong);
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.35;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease, box-shadow 160ms ease;
  }

  .contact-list a:hover,
  .contact-list a:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(15, 118, 110, 0.24);
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 12px 24px rgba(15, 118, 110, 0.08);
  }

  @media (max-width: 720px) {
    .contributor-card {
      grid-template-columns: 1fr;
    }

    .avatar {
      width: 4rem;
      height: 4rem;
      border-radius: 1.25rem;
    }
  }
</style>
