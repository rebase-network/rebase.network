---
import type { Article } from '@rebase/types';
import { formatDate } from '@/lib/dates';
import { getArticlePath } from '@/lib/paths';
import { DEFAULT_ARTICLE_COVER_PATH } from '@/lib/placeholders';

interface Props {
  article: Article;
  featured?: boolean;
  compact?: boolean;
}

const { article, featured = false, compact = false } = Astro.props;
const authorLine = article.authors.map((author) => author.name).filter(Boolean).join(' · ');
---

<article class:list={['article-card', 'card', { featured, compact }] }>
  <a class="cover-link" href={getArticlePath(article.publicNumber, article.slug)} aria-label={article.title}>
    <img
      class:list={['cover-image', !article.coverImageUrl && 'default-cover-image']}
      src={article.coverImageUrl ?? DEFAULT_ARTICLE_COVER_PATH}
      alt=""
      loading="lazy"
    />
  </a>
  <div class="content">
    <p class="meta">{formatDate(article.publishedAt)} · {article.readingTime}</p>
    <h3>
      <a href={getArticlePath(article.publicNumber, article.slug)}>{article.title}</a>
    </h3>
    <p class="summary">{article.summary}</p>
    {authorLine && <p class="author-line">{authorLine}</p>}
    {!compact && article.tags.length > 0 && (
      <ul class="tags">
        {article.tags.map((tag) => <li>{tag}</li>)}
      </ul>
    )}
  </div>
</article>

<style>
  .article-card {
    overflow: hidden;
    display: grid;
  }

  .article-card:hover,
  .article-card:focus-within {
    transform: translateY(-2px);
    border-color: rgba(15, 118, 110, 0.2);
    box-shadow: var(--shadow-strong);
  }

  .cover-link {
    display: block;
    overflow: hidden;
    aspect-ratio: 5 / 3;
    background: linear-gradient(135deg, rgba(15, 118, 110, 0.12), rgba(17, 94, 89, 0.04));
  }

  .cover-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 260ms ease;
  }

  .default-cover-image {
    background: transparent;
  }

  .article-card:hover .cover-image,
  .article-card:focus-within .cover-image {
    transform: scale(1.03);
  }

  .author-line {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.76rem;
    font-weight: 800;
  }


  .content {
    padding: 1.25rem;
  }

  .meta {
    margin: 0 0 0.75rem;
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0;
    text-transform: none;
  }

  h3 {
    margin: 0 0 0.75rem;
    font-size: 1.4rem;
    line-height: 1.08;
  }

  .summary {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  h3 a {
    transition: color 160ms ease;
  }

  .article-card:hover h3 a,
  .article-card:focus-within h3 a {
    color: var(--accent-strong);
    text-transform: none;
    letter-spacing: 0.02em;
  }

  .author-line {
    margin: 1rem 0 0;
    color: var(--accent-strong);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tags li {
    padding: 0.42rem 0.75rem;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.08);
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .featured h3 {
    font-size: clamp(1.8rem, 2.2vw, 2.5rem);
  }

  .featured {
    align-self: start;
  }

  .featured .cover-link {
    aspect-ratio: 16 / 9;
    min-height: 18rem;
  }

  .featured .content {
    padding: 1.5rem;
  }

  .featured .author-line {
    margin-top: 1.15rem;
  }

  .compact .content {
    padding: 1.1rem;
  }

  .compact h3 {
    margin-bottom: 0.65rem;
    font-size: 1.28rem;
  }

  .compact .summary {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .compact .author-line {
    margin-top: 0.9rem;
  }
</style>
