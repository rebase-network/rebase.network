---
import type { Job } from '@rebase/types';
import { formatDate } from '@/lib/dates';
import { getJobPath } from '@/lib/paths';

interface Props {
  job: Job;
}

const { job } = Astro.props;
const availabilityLabel = job.expiresAt ? `截止 ${formatDate(job.expiresAt)}` : '长期开放';
---

<a class="job-card card" href={getJobPath(job.slug)}>
  <div class="job-card-topline">
    <p class="company-name">{job.companyName}</p>
    <div class="job-card-flags">
      <span>{availabilityLabel}</span>
      {job.supportsRemote && <strong class="remote-flag">远程</strong>}
    </div>
  </div>
  <h3>{job.roleTitle}</h3>
  <p class="summary">{job.summary}</p>
  <dl class="job-facts">
    <div>
      <dt>薪资</dt>
      <dd>{job.salary}</dd>
    </div>
    <div>
      <dt>模式</dt>
      <dd>{job.workMode}</dd>
    </div>
    <div>
      <dt>地点</dt>
      <dd>{job.location}</dd>
    </div>
  </dl>
</a>

<style is:global>
  .job-card {
    display: grid;
    gap: 0.9rem;
    padding: 1.15rem;
  }

  .job-card:hover,
  .job-card:focus-visible {
    transform: translateY(-4px);
    border-color: rgba(15, 118, 110, 0.18);
    box-shadow: var(--shadow-strong);
  }

  .job-card .job-card-topline {
    display: grid;
    gap: 0.45rem;
  }

  .job-card .company-name {
    margin: 0;
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .job-card .job-card-flags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .job-card .job-card-flags span,
  .job-card .remote-flag {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.62rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1;
  }

  .job-card .job-card-flags span {
    background: rgba(31, 41, 51, 0.05);
    color: var(--muted);
  }

  .job-card .remote-flag {
    margin: 0;
    background: rgba(15, 118, 110, 0.1);
    color: var(--accent-strong);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .job-card h3 {
    margin: 0;
    font-size: 1.32rem;
    line-height: 1.05;
    transition: color 160ms ease;
  }

  .job-card:hover h3,
  .job-card:focus-visible h3 {
    color: var(--accent-strong);
  }

  .job-card .summary {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .job-card .job-facts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 0;
    padding-top: 0.9rem;
    border-top: 1px solid var(--line);
  }

  .job-card .job-facts div {
    min-width: 0;
  }

  .job-card dt {
    color: var(--muted);
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .job-card dd {
    margin: 0.28rem 0 0;
    font-weight: 700;
    line-height: 1.45;
  }

  @media (max-width: 720px) {
    .job-card .job-facts {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }
  }
</style>
