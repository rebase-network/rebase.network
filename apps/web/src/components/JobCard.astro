---
import type { Job } from '@rebase/types';
import { formatDate } from '@/lib/dates';
import { getJobPath } from '@/lib/paths';

interface Props {
  job: Job;
  compact?: boolean;
}

const { job, compact = false } = Astro.props;
const freshnessLabel = job.isExpired ? '已过期' : `更新 ${formatDate(job.updatedAt)}`;
const normalizedCompanyName = job.companyName.trim();
const companyName = normalizedCompanyName && !['/', '-', '—'].includes(normalizedCompanyName)
  ? normalizedCompanyName
  : '公司未公开';
const formatWorkMode = (value: string) => {
  switch (value) {
    case 'full-time':
      return '全职';
    case 'part-time':
      return '兼职';
    default:
      return value;
  }
};
---

<a class:list={['job-card', 'card', { compact }]} href={getJobPath(job.publicNumber, job.slug)}>
  <div class="job-card-topline">
    <p class:list={['company-name', companyName === '公司未公开' && 'is-missing']}>{companyName}</p>
    <div class="job-card-flags">
      <span class:list={['job-state-flag', job.isExpired && 'is-expired']}>{freshnessLabel}</span>
      {job.supportsRemote && <strong class="remote-flag">远程</strong>}
    </div>
  </div>
  <h3>{job.roleTitle}</h3>
  <p class="summary">{job.summary}</p>
  <dl class="job-facts">
    <div>
      <dt>薪资</dt>
      <dd>{job.salary}</dd>
    </div>
    <div>
      <dt>模式</dt>
      <dd>{formatWorkMode(job.workMode)}</dd>
    </div>
    <div>
      <dt>地点</dt>
      <dd>{job.location}</dd>
    </div>
  </dl>
</a>

<style is:global>
  .job-card {
    display: grid;
    gap: 0.9rem;
    padding: 1.15rem;
  }

  .job-card:hover,
  .job-card:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(15, 118, 110, 0.18);
    box-shadow: var(--shadow-strong);
  }

  .job-card .job-card-topline {
    display: grid;
    gap: 0.45rem;
  }

  .job-card .company-name {
    margin: 0;
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: none;
  }

  .job-card .company-name.is-missing {
    color: rgba(92, 107, 115, 0.78);
    font-weight: 600;
  }

  .job-card .job-card-flags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .job-card .job-state-flag,
  .job-card .remote-flag {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.62rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1;
  }

  .job-card .job-state-flag {
    background: rgba(31, 41, 51, 0.05);
    color: var(--muted);
  }

  .job-card .job-state-flag.is-expired {
    background: rgba(185, 28, 28, 0.1);
    color: #991b1b;
  }

  .job-card .remote-flag {
    margin: 0;
    background: rgba(15, 118, 110, 0.1);
    color: var(--accent-strong);
    letter-spacing: 0;
    text-transform: none;
  }

  .job-card h3 {
    margin: 0;
    font-size: 1.32rem;
    line-height: 1.05;
    transition: color 160ms ease;
  }

  .job-card:hover h3,
  .job-card:focus-visible h3 {
    color: var(--accent-strong);
  }

  .job-card .summary {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .job-card .job-facts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding-top: 0.85rem;
    border-top: 1px solid var(--line);
  }

  .job-card .job-facts div {
    display: inline-flex;
    align-items: baseline;
    gap: 0.38rem;
    min-width: 0;
    max-width: 100%;
    padding: 0.42rem 0.62rem;
    border: 1px solid rgba(31, 41, 51, 0.07);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.62);
  }

  .job-card dt {
    color: var(--muted);
    font-size: 0.72rem;
    letter-spacing: 0;
    text-transform: none;
  }

  .job-card dd {
    margin: 0;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .job-card.compact {
    gap: 0.82rem;
    padding: 1.02rem;
  }

  .job-card.compact h3 {
    font-size: 1.24rem;
  }

  .job-card.compact .job-facts {
    gap: 0.46rem;
    padding-top: 0.78rem;
  }

  @media (max-width: 720px) {
    .job-card .job-facts {
      align-items: flex-start;
    }
  }
</style>
