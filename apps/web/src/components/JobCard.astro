---
import type { Job } from '@rebase/types';
import { formatDate } from '@/lib/dates';
import { getJobPath } from '@/lib/paths';

interface Props {
  job: Job;
}

const { job } = Astro.props;
const companyInitial = job.companyName.slice(0, 1).toUpperCase();
const availabilityLabel = job.expiresAt ? `截止 ${formatDate(job.expiresAt)}` : '长期开放';
---

<article class="job-card card">
  <div class="meta-row">
    <div class="company-mark" aria-hidden="true">{companyInitial}</div>
    <div class="company-copy">
      <p>{job.companyName}</p>
      <span>{availabilityLabel}</span>
    </div>
    {job.supportsRemote && <strong class="remote-flag">远程</strong>}
  </div>
  <h3>
    <a href={getJobPath(job.slug)}>{job.roleTitle}</a>
  </h3>
  <p class="summary">{job.summary}</p>
  <dl>
    <div>
      <dt>薪资</dt>
      <dd>{job.salary}</dd>
    </div>
    <div>
      <dt>模式</dt>
      <dd>{job.workMode}</dd>
    </div>
    <div>
      <dt>地点</dt>
      <dd>{job.location}</dd>
    </div>
  </dl>
  {job.tags.length > 0 && (
    <ul class="tag-list">
      {job.tags.map((tag) => <li>{tag}</li>)}
    </ul>
  )}
</article>

<style>
  .job-card {
    padding: 1.25rem;
  }

  .job-card:hover,
  .job-card:focus-within {
    transform: translateY(-4px);
    border-color: rgba(15, 118, 110, 0.18);
    box-shadow: var(--shadow-strong);
  }

  .meta-row,
  dl {
    display: flex;
    align-items: start;
    gap: 1rem;
  }

  .meta-row {
    margin-bottom: 0.8rem;
    align-items: center;
  }

  .company-mark {
    display: grid;
    width: 2.8rem;
    height: 2.8rem;
    place-items: center;
    border-radius: 0.95rem;
    background: linear-gradient(135deg, rgba(15, 118, 110, 0.15), rgba(245, 158, 11, 0.22));
    color: var(--accent-strong);
    font-size: 1.05rem;
    font-weight: 800;
  }

  .company-copy {
    min-width: 0;
  }

  .company-copy p,
  .company-copy span {
    margin: 0;
  }

  .company-copy p {
    font-size: 0.92rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .company-copy span {
    margin-top: 0.25rem;
    display: block;
    color: var(--muted);
    font-size: 0.8rem;
  }

  .remote-flag {
    margin-left: auto;
    padding: 0.34rem 0.68rem;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.1);
    color: var(--accent-strong);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h3 {
    margin: 0 0 0.75rem;
    font-size: 1.45rem;
    line-height: 1.08;
  }

  h3 a {
    transition: color 160ms ease;
  }

  .job-card:hover h3 a,
  .job-card:focus-within h3 a {
    color: var(--accent-strong);
  }

  .summary {
    margin: 0 0 1rem;
    color: var(--muted);
    line-height: 1.7;
  }

  dl {
    flex-wrap: wrap;
    margin: 0;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
    justify-content: space-between;
  }

  dt {
    color: var(--muted);
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  dd {
    margin: 0.3rem 0 0;
    font-weight: 700;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tag-list li {
    padding: 0.36rem 0.7rem;
    border-radius: 999px;
    background: rgba(31, 41, 51, 0.05);
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 700;
  }
</style>
