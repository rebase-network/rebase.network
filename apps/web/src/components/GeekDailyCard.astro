---
import type { GeekDailyEpisode } from '@rebase/types';
import { formatDate } from '@/lib/dates';
import { getGeekDailyPath } from '@/lib/paths';

interface Props {
  episode: GeekDailyEpisode;
  compact?: boolean;
}

const { episode, compact = false } = Astro.props;
---

<article class:list={['daily-card', 'card', { compact }]}>
  <div class="meta-row">
    <p class="meta">{formatDate(episode.publishedAt)}</p>
    <span class="issue-no">#{episode.episodeNumber}</span>
  </div>
  <h3>
    <a href={getGeekDailyPath(episode.episodeNumber)}>{episode.title}</a>
  </h3>
  <p class="body">{episode.summary}</p>
  <p class="item-count">{episode.items.length} 条社区推荐</p>
  <ul class="tags">
    {episode.tags.map((tag) => <li>{tag}</li>)}
  </ul>
</article>

<style>
  .daily-card {
    padding: 1.25rem;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 252, 244, 0.88));
  }

  .daily-card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: linear-gradient(180deg, #f59e0b 0%, #0f766e 100%);
    opacity: 0.82;
  }

  .daily-card:hover,
  .daily-card:focus-within {
    transform: translateY(-4px);
    border-color: rgba(245, 158, 11, 0.22);
    box-shadow: var(--shadow-strong);
  }

  .meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .meta {
    margin: 0 0 0.75rem;
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .issue-no {
    padding: 0.35rem 0.68rem;
    border-radius: 999px;
    background: rgba(245, 158, 11, 0.12);
    color: #92400e;
    font-size: 0.78rem;
    font-weight: 800;
  }

  h3 {
    margin: 0 0 0.75rem;
    font-size: 1.35rem;
    line-height: 1.12;
  }

  h3 a {
    transition: color 160ms ease;
  }

  .daily-card:hover h3 a,
  .daily-card:focus-within h3 a {
    color: #92400e;
  }

  .body {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .item-count {
    margin: 1rem 0 0;
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tags li {
    padding: 0.42rem 0.75rem;
    border-radius: 999px;
    background: rgba(245, 158, 11, 0.12);
    color: #92400e;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .compact {
    padding: 1.05rem;
  }

  .compact .meta {
    margin-bottom: 0.62rem;
  }

  .compact h3 {
    margin-bottom: 0.62rem;
    font-size: 1.28rem;
  }

  .compact .body {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .compact .item-count,
  .compact .tags {
    margin-top: 0.88rem;
  }
</style>
