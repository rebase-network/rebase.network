---
import EventCard from '@/components/EventCard.astro';
import ListEmptyState from '@/components/ListEmptyState.astro';
import ListPageHero from '@/components/ListPageHero.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPastEvents, getSiteSettings, getUpcomingEvents } from '@/lib/content';

const [site, upcomingEvents, pastEvents] = await Promise.all([
  getSiteSettings(),
  getUpcomingEvents(),
  getPastEvents(),
]);
const leadUpcomingEvent = upcomingEvents[0];
const remainingUpcomingEvents = leadUpcomingEvent ? upcomingEvents.slice(1) : upcomingEvents;
---

<BaseLayout site={site} title="Rebase 活动" description="查看 Rebase 社区的当前活动与历史活动归档。">
  <ListPageHero
    kicker="活动"
    edition="Rebase Agenda"
    title="Rebase 活动"
    summary="查看当前活动、外部报名入口和历史活动归档。"
    heroClass="events-hero"
  />

  <section id="upcoming-archive" class="shell page-section">
    <SectionHeader
      eyebrow="近期活动"
      title="当前活动"
      description="把可参与的活动放在最前面，时间、地点和报名方式一眼可见。"
      href="/events/rss.xml"
      hrefLabel="订阅 RSS"
    />
    {leadUpcomingEvent ? (
      <div class="events-current-stack">
        <div class="event-lead-grid">
          <EventCard event={leadUpcomingEvent} />
        </div>
        {remainingUpcomingEvents.length > 0 && (
          <div class="grid-3">
            {remainingUpcomingEvents.map((event) => <EventCard event={event} />)}
          </div>
        )}
      </div>
    ) : (
      <ListEmptyState
        kicker="持续排期"
        title="更多活动正在安排中。"
        description="新的公开活动会继续按同一结构补进这条时间线里。"
      />
    )}
  </section>

  <section id="past-archive" class="shell page-section">
    <SectionHeader
      eyebrow="历史归档"
      title="历史活动"
      description="历史活动也应该保留完整上下文，而不是在活动结束后就从社区表面消失。"
    />
    {pastEvents.length > 0 ? (
      <div class="grid-3">
        {pastEvents.map((event) => <EventCard event={event} />)}
      </div>
    ) : (
      <ListEmptyState
        kicker="归档建设中"
        title="历史活动档案会继续补全。"
        description="这部分会逐步补上过往活动的时间、地点、主题和说明，让站点保留更完整的社区记忆。"
        variant="cool"
      />
    )}
  </section>
</BaseLayout>

<style>
  :global(.events-hero) {
    background:
      radial-gradient(circle at top left, rgba(125, 211, 252, 0.24), transparent 30%),
      radial-gradient(circle at 90% 18%, rgba(15, 118, 110, 0.18), transparent 22%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 252, 251, 0.92));
  }

  :global(.events-hero::before) {
    content: 'EVENTS';
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    color: rgba(17, 94, 89, 0.08);
    font-family: var(--display-font);
    font-size: clamp(3.8rem, 8vw, 6.6rem);
    letter-spacing: 0.08em;
    line-height: 0.82;
    pointer-events: none;
  }

  :global(.events-hero .hero-title) {
    max-width: 8ch;
    text-wrap: balance;
  }

  .events-current-stack {
    display: grid;
    gap: 1rem;
  }

  .event-lead-grid {
    display: grid;
  }
</style>
