---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import { getEventBySlug, getEvents, getSiteSettings } from '@/lib/content';
import { formatEventWindow } from '@/lib/dates';
import { getEventPath, getEventRouteParam, getEventSlugFromRouteParam } from '@/lib/paths';
import type { Event } from '@rebase/types';

export async function getStaticPaths() {
  const events = await getEvents();
  return events.map((event) => ({
    params: { slug: getEventRouteParam(event.startAt, event.slug) },
    props: {
      event,
      related: events.filter((item) => item.slug !== event.slug).slice(0, 2),
    },
  }));
}

const eventSlug = getEventSlugFromRouteParam(Astro.params.slug ?? '');
const site = await getSiteSettings();
const event = (Astro.props.event as Event | undefined) ?? (await getEventBySlug(eventSlug));
const related = (Astro.props.related as Event[] | undefined) ?? [];
const eventStatusLabel = event ? (event.status === 'upcoming' ? '即将举办' : '活动归档') : '';
const registrationModeLabel = event ? (event.registrationUrl ? '开放报名' : '仅信息说明') : '';

if (!event) {
  Astro.response.status = 404;
}
---

<BaseLayout
  site={site}
  title={event ? event.title : '活动未找到'}
  description={event ? event.summary : '你访问的活动页面暂时无法找到。'}
  socialImage={event?.coverImageUrl}
  noindex={!event}
>
  {event ? (
    <>
      <section class="shell page-hero single">
        <article class="hero-panel card detail-hero event-hero">
          <div class="detail-topline">
            <div class="detail-context">
              <p class="hero-kicker light">活动详情</p>
              <nav class="detail-breadcrumbs light" aria-label="Breadcrumb">
                <a href="/">首页</a>
                <span aria-hidden="true">/</span>
                <a href="/events">活动</a>
                <span aria-hidden="true">/</span>
                <span aria-current="page">{event.title}</span>
              </nav>
            </div>
            <span class="detail-edition">{eventStatusLabel}</span>
          </div>
          <h1 class="hero-title light">{event.title}</h1>
          <p class="hero-summary light">{event.summary}</p>
          <div class="detail-meta-strip">
            <span class="detail-meta-pill">{event.city}</span>
            <span class="detail-meta-pill">{event.venue}</span>
            <span class="detail-meta-pill">{registrationModeLabel}</span>
          </div>
          <p class="detail-hero-note light">{formatEventWindow(event.startAt, event.endAt)} · {event.location}</p>
          <div class="button-row">
            {event.registrationUrl && (
              <a class="button-link" href={event.registrationUrl} target="_blank" rel="noreferrer">外部报名 <span>↗</span></a>
            )}
            <a class="button-link secondary" href="/events">返回活动列表</a>
          </div>
          <div class="detail-jump-list">
            <a href="#event-body">活动内容</a>
            <a href="#event-info">活动信息</a>
            <a href={related.length > 0 ? '#event-related' : '#event-actions'}>继续追踪</a>
          </div>
        </article>
      </section>

      <section class="shell page-section detail-shell">
        <article id="event-body" class="card detail-body-card event-detail">
          <div class="detail-body-lead event-meta">
            <p>{formatEventWindow(event.startAt, event.endAt)}</p>
            <p>{event.location} · {event.venue}</p>
          </div>
          <MarkdownContent content={event.content} />
        </article>

        <aside class="card detail-sidebar">
          <section class="detail-sidebar-section">
            <h2>页面导览</h2>
            <p class="detail-sidebar-copy">如果你是从活动分享或历史归档进入，可以先用这些锚点快速定位。</p>
            <ul class="detail-sidebar-list">
              <li><a href="#event-body">查看活动内容</a></li>
              <li><a href="#event-info">查看活动信息</a></li>
              <li><a href={related.length > 0 ? '#event-related' : '#event-actions'}>继续追踪</a></li>
            </ul>
          </section>

          <section id="event-info" class="detail-sidebar-section">
            <h2>活动信息</h2>
            <ul class="detail-fact-list">
              <li>
                <strong>活动状态</strong>
                <span>{eventStatusLabel}</span>
              </li>
              <li>
                <strong>时间窗口</strong>
                <span>{formatEventWindow(event.startAt, event.endAt)}</span>
              </li>
              <li>
                <strong>地点</strong>
                <span>{event.location} · {event.venue}</span>
              </li>
            </ul>
            <p class="detail-sidebar-copy">{event.registrationNote ?? '报名方式稍后公布，当前页面先保证活动信息可读、可归档、可订阅。'}</p>
            {event.tags.length > 0 && (
              <ul class="detail-tag-list">
                {event.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            )}
          </section>

          <section id="event-actions" class="detail-sidebar-section">
            <h2>继续追踪</h2>
            <ul class="detail-sidebar-list">
              {event.registrationUrl && (
                <li>
                  <a href={event.registrationUrl} target="_blank" rel="noreferrer">打开外部报名链接</a>
                </li>
              )}
              <li><a href="/events/rss.xml">订阅活动 RSS</a></li>
              <li><a href="/events">回到活动列表</a></li>
            </ul>
          </section>

          {related.length > 0 && (
            <section id="event-related" class="detail-sidebar-section">
              <h2>相关活动</h2>
              <ul class="related-list">
                {related.map((item) => (
                  <li><a href={getEventPath(item.startAt, item.slug)}>{item.title}</a></li>
                ))}
              </ul>
            </section>
          )}
        </aside>
      </section>
    </>
  ) : (
    <section class="shell page-hero single">
      <article class="hero-panel card">
        <p class="hero-kicker">404</p>
        <h1 class="hero-title">这个活动页面暂时没有被找到。</h1>
        <p class="hero-summary">你可以先回到活动列表，查看当前活动和历史活动归档。</p>
      </article>
    </section>
  )}
</BaseLayout>

<style>
  .single {
    grid-template-columns: 1fr;
  }

  .event-hero {
    color: white;
    background:
      radial-gradient(circle at top right, rgba(245, 158, 11, 0.26), transparent 24%),
      linear-gradient(135deg, rgba(16, 37, 34, 0.98), rgba(17, 94, 89, 0.92));
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 28px 60px rgba(16, 37, 34, 0.24);
  }

  .light {
    color: white;
  }
</style>
