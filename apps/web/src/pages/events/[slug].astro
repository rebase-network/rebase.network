---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DetailHero from '@/components/DetailHero.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import { getEventByPublicNumber, getEvents, getSiteSettings } from '@/lib/content';
import { formatEventWindow } from '@/lib/dates';
import { resolvePublicEventStatus } from '@/lib/eventStatus';
import { getEventPath, getEventPublicNumberFromRouteParam } from '@/lib/paths';
import { DEFAULT_EVENT_COVER_PATH } from '@/lib/placeholders';

const routeParam = Astro.params.slug ?? '';
const eventPublicNumber = getEventPublicNumberFromRouteParam(routeParam);
const [site, event, events] = await Promise.all([getSiteSettings(), getEventByPublicNumber(eventPublicNumber), getEvents()]);
const related = event ? events.filter((item) => item.publicNumber !== event.publicNumber).slice(0, 3) : [];
const publicEventStatus = event ? resolvePublicEventStatus(event) : undefined;
const eventStatusLabel = publicEventStatus?.detailStatusLabel ?? '';
const eventLocationLine = event ? [event.location, event.venue].filter(Boolean).join(' · ') : '';
const eventHeroMeta = event ? [formatEventWindow(event.startAt, event.endAt), eventLocationLine].filter(Boolean) : [];
const eventCanRegister = Boolean(publicEventStatus?.canRegister);
const eventHasHistoricLink = Boolean(event?.registrationUrl && publicEventStatus?.isPast);
const eventLinkLabel = publicEventStatus?.detailActionLabel ?? '查看活动详情';
const eventActionTitle = eventCanRegister ? '报名方式' : eventHasHistoricLink ? '活动链接' : '参与方式';
const eventRegistrationCopy = event
  ? eventCanRegister
    ? '请通过公开链接报名，更多参与方式请查看正文中的活动说明。'
    : eventHasHistoricLink
      ? '这是历史活动，链接仅作为活动归档参考。'
      : '参与方式请查看正文中的活动说明，或以后续公告为准。'
  : '';
const eventHeroActions = event
  ? [
      ...(eventCanRegister
        ? [{ href: event.registrationUrl!, label: '立即报名', external: true, showIcon: true }]
        : []),
    ]
  : [];

if (!event) {
  Astro.response.status = 404;
}
---

<BaseLayout
  site={site}
  title={event ? event.title : '活动未找到'}
  description={event ? event.summary : '你访问的活动页面暂时无法找到。'}
  socialImage={event?.coverImageUrl ?? DEFAULT_EVENT_COVER_PATH}
  noindex={!event}
>
  {event ? (
    <>
      <section class="shell page-hero single event-detail-hero-shell">
        <DetailHero
          titleAside={eventStatusLabel}
          title={event.title}
          summary={event.summary}
          meta={eventHeroMeta}
          actions={eventHeroActions}
          hideTopline={true}
          inlineMetaActions={true}
          heroClass="event-hero"
        />
      </section>

      <section class="shell page-section detail-shell event-detail-shell">
        <article id="event-body" class="card detail-body-card event-detail">
          <div class="event-reading-frame">
            <MarkdownContent content={event.content} />
          </div>
        </article>

        <aside class="card detail-sidebar">
          <section id="event-registration" class="detail-sidebar-section">
            <h2>{eventActionTitle}</h2>
            <p class="detail-sidebar-copy">
              {eventRegistrationCopy}
            </p>
            {event.registrationUrl && (
              <ul class="detail-sidebar-list">
                <li>
                  <a href={event.registrationUrl} target="_blank" rel="noreferrer">
                    {eventLinkLabel}
                  </a>
                </li>
              </ul>
            )}
          </section>

          <section id="event-actions" class="detail-sidebar-section">
            <h2>继续关注</h2>
            <ul class="detail-sidebar-list">
              <li><a href="/events/rss.xml">订阅活动 RSS</a></li>
              <li><a href="/events">回到活动列表</a></li>
            </ul>
          </section>

          {related.length > 0 && (
            <section id="event-related" class="detail-sidebar-section">
              <h2>相关活动</h2>
              <ul class="related-list">
                {related.map((item) => (
                  <li><a href={getEventPath(item.publicNumber, item.slug)}>{item.title}</a></li>
                ))}
              </ul>
            </section>
          )}
        </aside>
      </section>
    </>
  ) : (
    <section class="shell page-hero single">
      <article class="hero-panel card">
        <p class="hero-kicker">404</p>
        <h1 class="hero-title">这个活动页面暂时没有被找到。</h1>
        <p class="hero-summary">你可以先回到活动列表，查看当前活动和历史活动归档。</p>
      </article>
    </section>
  )}
</BaseLayout>

<style>
  .single {
    grid-template-columns: 1fr;
  }

  :global(.event-hero) {
    padding: 1.05rem 1.2rem 0.92rem;
    background:
      radial-gradient(circle at top right, rgba(245, 158, 11, 0.16), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(248, 252, 250, 0.9));
    border-color: rgba(15, 118, 110, 0.12);
    box-shadow: var(--shadow-soft);
  }

  :global(.event-hero .hero-title) {
    max-width: 11.5ch;
    margin-top: 0;
    font-size: clamp(2.18rem, 4.4vw, 3.96rem);
    line-height: 0.94;
  }

  :global(.event-hero .detail-title-row) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  :global(.event-hero .detail-title-aside) {
    flex-shrink: 0;
    padding-top: 0.24rem;
    font-size: 0.64rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-strong);
    opacity: 0.72;
  }

  :global(.event-hero .hero-summary) {
    max-width: 56ch;
    margin-top: 0.58rem;
    font-size: 0.95rem;
    line-height: 1.58;
  }

  :global(.event-hero .detail-footer-row) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.62rem;
  }

  :global(.event-hero .detail-meta-strip) {
    gap: 0.5rem;
    margin-top: 0;
  }

  :global(.event-hero .detail-meta-pill) {
    position: relative;
    padding: 0;
    border: none;
    border-radius: 0;
    background: transparent;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    color: var(--muted);
    opacity: 1;
  }

  :global(.event-hero .detail-meta-pill:not(:last-child)::after) {
    content: '·';
    margin-left: 0.5rem;
    opacity: 0.45;
  }

  :global(.event-hero .button-row) {
    justify-content: flex-end;
    margin-top: 0;
  }

  :global(.event-hero .button-link) {
    padding: 0.34rem 0.7rem;
    font-size: 0.69rem;
    letter-spacing: 0.06em;
  }

  :global(.event-hero .button-link.secondary) {
    border-color: rgba(15, 118, 110, 0.14);
    background: rgba(255, 255, 255, 0.58);
  }

  .event-detail {
    padding: 1.45rem;
  }

  .event-meta p {
    margin: 0;
  }

  .event-reading-frame {
    width: min(100%, 46rem);
    margin: 0 auto;
  }

  .event-detail :global(.markdown) {
    font-size: 1.05rem;
    line-height: 1.86;
  }

  .event-detail :global(.markdown h2) {
    margin-top: 2.3rem;
    font-size: 1.75rem;
  }

  @media (max-width: 780px) {
    :global(.event-hero .detail-title-row),
    :global(.event-hero .detail-footer-row) {
      flex-direction: column;
      align-items: flex-start;
    }

    :global(.event-hero .detail-title-aside) {
      padding-top: 0;
    }
  }

</style>
