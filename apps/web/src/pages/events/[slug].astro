---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DetailHero from '@/components/DetailHero.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import { getEventBySlug, getEvents, getSiteSettings } from '@/lib/content';
import { formatEventWindow } from '@/lib/dates';
import { getEventPath, getEventSlugFromRouteParam } from '@/lib/paths';

const eventSlug = getEventSlugFromRouteParam(Astro.params.slug ?? '');
const [site, event, events] = await Promise.all([getSiteSettings(), getEventBySlug(eventSlug), getEvents()]);
const related = event ? events.filter((item) => item.slug !== event.slug).slice(0, 2) : [];
const eventStatusLabel = event ? (event.status === 'upcoming' ? '即将举办' : '活动归档') : '';
const eventBreadcrumbs = event
  ? [
      { href: '/', label: '首页' },
      { href: '/events', label: '活动' },
      { label: event.title, current: true },
    ]
  : [];
const registrationModeLabel = event ? (event.registrationUrl ? '开放报名' : '当前仅提供活动说明') : '';
const eventHeroMeta = event ? [eventStatusLabel, formatEventWindow(event.startAt, event.endAt), `${event.city} · ${event.venue}`].filter(Boolean) : [];
const eventHeroActions = event
  ? [
      ...(event.registrationUrl
        ? [{ href: event.registrationUrl, label: '外部报名', external: true, showIcon: true }]
        : []),
      { href: '/events', label: '返回活动列表', secondary: true },
    ]
  : [];

if (!event) {
  Astro.response.status = 404;
}
---

<BaseLayout
  site={site}
  title={event ? event.title : '活动未找到'}
  description={event ? event.summary : '你访问的活动页面暂时无法找到。'}
  socialImage={event?.coverImageUrl}
  noindex={!event}
>
  {event ? (
    <>
      <section class="shell page-hero single">
        <DetailHero
          kicker="活动"
          breadcrumbs={eventBreadcrumbs}
          edition={eventStatusLabel}
          title={event.title}
          summary={event.summary}
          meta={eventHeroMeta}
          actions={eventHeroActions}
          heroClass="event-hero"
        />
      </section>

      <section class="shell page-section">
        <div class="event-overview-grid">
          <article class="card event-overview-card">
            <span>时间</span>
            <strong>{formatEventWindow(event.startAt, event.endAt)}</strong>
            <p>{eventStatusLabel}</p>
          </article>
          <article class="card event-overview-card">
            <span>地点</span>
            <strong>{event.location}</strong>
            <p>{event.city} · {event.venue}</p>
          </article>
          <article class="card event-overview-card event-overview-card-action">
            <span>报名</span>
            <strong>{registrationModeLabel}</strong>
            <p>{event.registrationNote ?? '当前页面提供活动说明，报名方式以公开链接或后续公告为准。'}</p>
            {event.registrationUrl && <a class="button-link" href={event.registrationUrl} target="_blank" rel="noreferrer">打开报名链接 <span>↗</span></a>}
          </article>
        </div>
      </section>

      <section class="shell page-section event-detail-shell">
        <article id="event-body" class="card detail-body-card event-detail">
          {event.tags.length > 0 && (
            <ul class="event-reading-tags">
              {event.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          )}
          <MarkdownContent content={event.content} />
        </article>
      </section>

      <section class="shell page-section event-followup-shell">
        <div class="event-followup-grid">
          <article class="card event-followup-card">
            <p class="followup-kicker">继续追踪</p>
            <h2>继续关注活动更新</h2>
            <p>新的活动会继续出现在公开列表和 RSS 中，历史活动也会留在归档里。</p>
            <div class="followup-link-list">
              <a href="/events/rss.xml">订阅活动 RSS</a>
              <a href="/events">回到活动列表</a>
            </div>
          </article>

          {related.length > 0 && (
            <article class="card event-followup-card">
              <p class="followup-kicker">相关活动</p>
              <h2>继续看这几场</h2>
              <div class="followup-link-list">
                {related.map((item) => (
                  <a href={getEventPath(item.startAt, item.slug)}>{item.title}</a>
                ))}
              </div>
            </article>
          )}
        </div>
      </section>
    </>
  ) : (
    <section class="shell page-hero single">
      <article class="hero-panel card">
        <p class="hero-kicker">404</p>
        <h1 class="hero-title">这个活动页面暂时没有被找到。</h1>
        <p class="hero-summary">你可以先回到活动列表，查看当前活动和历史活动归档。</p>
      </article>
    </section>
  )}
</BaseLayout>

<style>
  .single {
    grid-template-columns: 1fr;
  }

  .event-hero {
    color: white;
    background:
      radial-gradient(circle at top right, rgba(245, 158, 11, 0.26), transparent 24%),
      linear-gradient(135deg, rgba(16, 37, 34, 0.98), rgba(17, 94, 89, 0.92));
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 28px 60px rgba(16, 37, 34, 0.24);
  }

  .light {
    color: white;
  }

  .event-overview-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .event-overview-card {
    display: grid;
    gap: 0.6rem;
    padding: 1.25rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 252, 251, 0.92));
  }

  .event-overview-card span,
  .event-overview-card strong,
  .event-overview-card p {
    margin: 0;
  }

  .event-overview-card span {
    color: var(--accent-strong);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .event-overview-card strong {
    font-size: clamp(1.2rem, 1.8vw, 1.55rem);
    line-height: 1.08;
  }

  .event-overview-card p {
    color: var(--muted);
    line-height: 1.72;
  }

  .event-overview-card-action .button-link {
    justify-self: start;
    margin-top: 0.3rem;
  }

  .event-detail-shell {
    grid-template-columns: 1fr;
  }

  .event-reading-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 1.15rem;
    padding: 0 0 1rem;
    list-style: none;
    border-bottom: 1px solid var(--line);
  }

  .event-reading-tags li {
    padding: 0.42rem 0.72rem;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.08);
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .event-followup-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .event-followup-card {
    display: grid;
    gap: 0.8rem;
    padding: 1.3rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(249, 252, 250, 0.92));
  }

  .followup-kicker,
  .event-followup-card h2,
  .event-followup-card p {
    margin: 0;
  }

  .followup-kicker {
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .event-followup-card h2 {
    font-size: clamp(1.45rem, 2vw, 2rem);
    line-height: 1.06;
  }

  .event-followup-card p {
    color: var(--muted);
    line-height: 1.75;
  }

  .followup-link-list {
    display: grid;
    gap: 0.75rem;
  }

  .followup-link-list a {
    display: block;
    padding: 0.88rem 1rem;
    border: 1px solid rgba(15, 118, 110, 0.12);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.74);
    color: var(--accent-strong);
    font-weight: 700;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .followup-link-list a:hover,
  .followup-link-list a:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(15, 118, 110, 0.24);
    box-shadow: 0 14px 28px rgba(15, 118, 110, 0.1);
  }

  @media (max-width: 960px) {
    .event-overview-grid,
    .event-followup-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
