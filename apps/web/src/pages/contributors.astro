---
import ContributorCard from '@/components/ContributorCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getContributorsByRole, getSiteSettings } from '@/lib/content';

const [site, groups] = await Promise.all([getSiteSettings(), getContributorsByRole()]);
const isExternalLink = (href: string) => href.startsWith('http');

const collaborationLink =
  site.footerGroups
    .flatMap((group) => group.links)
    .find((link) => /协作文档|参与|加入/i.test(link.label))?.href ?? '/about';

const contributorOverview = [
  {
    value: '贡献者做什么？',
    label: '参与内容推荐，日报更新，整理招聘信息，组织社区活动，撰写社区内容、维护社区网站和工具，以及 Github 维护',
  },
  {
    value: '需要什么能力？',
    label: '有热忱参与开源社区，有兴趣了解最近的行业变化，愿意投入到实实在在的具体的事情上，希望认识更多有趣的人',
  },
  {
    value: '如何成为贡献者？',
    label: '任何想要参与贡献的人都可以成为贡献者，在社区中联系接引人 Harry、Frozen、Shooter 或任一名志愿者即可',
  },
];

const roleGuides: Record<string, { overview: string; joinHint: string; joinLabel: string; joinHref: string }> = {
  volunteers: {
    overview: '负责把社区里的内容、活动与协作真正推进下去，包括活动组织、内容整理、页面维护与公开发布。',
    joinHint: '可以先从一次具体协作开始，持续参与后会在这里被记录和认可。',
    joinLabel: '加入我们',
    joinHref: collaborationLink,
  },
  'geekdaily-advisors': {
    overview: '持续为 GeekDaily 提供值得关注的内容线索、推荐人与推荐语，帮助日报保持长期内容密度。',
    joinHint: '如果你愿意长期推荐内容、提供判断与信号，可以从日报推荐协作开始参与。',
    joinLabel: '参与日报推荐',
    joinHref: collaborationLink,
  },
};
---

<BaseLayout
  site={site}
  title="Rebase 贡献者"
  description="认识推动 Rebase 社区内容、活动与协作持续发生的贡献者。"
>
  <section class="shell page-hero single">
    <article class="hero-panel card contributors-hero">
      <h1 class="hero-title">社区不是抽象概念，它总是由具体的人把内容、活动和协作推着往前走。</h1>
      <p class="hero-summary">
        Rebase 社区完全由贡献者们推动，在社区中，每一次栏目更新、活动组织、内容撰写、项目组建、社区工具以及相应的代码贡献都是由大家贡献，每一次社区内的思想碰撞和新的探索都来源于贡献者们的一次次尝试。每个人的小小贡献汇聚成社区里的点点滴滴，社区正是由这点点滴滴的进步慢慢成长为大家交流的平台。
      </p>
      <div class="hero-overview" aria-label="贡献者页面概览">
        {contributorOverview.map((item) => (
          <article>
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </article>
        ))}
      </div>
    </article>
  </section>

  <section class="shell page-section contributor-groups">
    {groups.map((group, index) => (
      <section id={group.role.slug} class:list={['group-block', 'card', index % 2 === 0 ? 'tone-warm' : 'tone-cool']}>
        <div class="group-head">
          <div>
            <p>0{index + 1} · {group.role.name}</p>
            <h2>{group.role.name}</h2>
          </div>
          <span class="group-count">{group.contributors.length} 位成员</span>
        </div>
        <p class="group-description">
          {roleGuides[group.role.slug]?.overview ??
            group.role.description ??
            '这组贡献者持续帮助 Rebase 保持内容与协作的长期连续性。'}
        </p>
        <div class="group-join-row">
          <p class="group-note">
            {roleGuides[group.role.slug]?.joinHint ?? '从一次实际协作开始，持续参与后会被公开记录在这里。'}
          </p>
          <a
            class="group-join-link"
            href={roleGuides[group.role.slug]?.joinHref ?? collaborationLink}
            target={isExternalLink(roleGuides[group.role.slug]?.joinHref ?? collaborationLink) ? '_blank' : undefined}
            rel={isExternalLink(roleGuides[group.role.slug]?.joinHref ?? collaborationLink) ? 'noreferrer' : undefined}
          >
            {roleGuides[group.role.slug]?.joinLabel ?? '了解如何参与'} <span>↗</span>
          </a>
        </div>

        {group.contributors[0] ? (
          <div class="group-grid">
            {group.contributors.map((contributor) => (
              <ContributorCard contributor={contributor} />
            ))}
          </div>
        ) : null}
      </section>
    ))}
  </section>
</BaseLayout>

<style>
  .single {
    grid-template-columns: 1fr;
  }

  .contributors-hero {
    position: relative;
    overflow: hidden;
    animation: none;
    backdrop-filter: none;
    background:
      radial-gradient(circle at top left, rgba(243, 196, 110, 0.26), transparent 30%),
      radial-gradient(circle at top right, rgba(15, 118, 110, 0.18), transparent 26%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 252, 251, 0.9));
    border-color: rgba(15, 118, 110, 0.14);
    box-shadow: 0 28px 60px rgba(26, 40, 34, 0.12);
  }

  .contributors-hero::before {
    content: 'PEOPLE';
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    color: rgba(17, 94, 89, 0.08);
    font-family: var(--display-font);
    font-size: clamp(4rem, 8vw, 6.8rem);
    letter-spacing: 0.08em;
    line-height: 0.82;
    pointer-events: none;
  }

  .contributors-hero > * {
    position: relative;
    z-index: 1;
  }

  .contributors-hero .hero-title {
    max-width: 16ch;
    font-size: clamp(2.35rem, 3vw + 1rem, 3.55rem);
    line-height: 1.1;
    letter-spacing: -0.035em;
  }

  .hero-overview {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .hero-overview article {
    padding: 0.88rem 0.95rem;
    border-radius: 0.95rem;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(31, 41, 51, 0.08);
    box-shadow: 0 10px 22px rgba(15, 118, 110, 0.05);
  }

  .hero-overview strong,
  .hero-overview span {
    display: block;
    margin: 0;
  }

  .hero-overview strong {
    color: var(--text);
    font-size: 1rem;
    line-height: 1.3;
  }

  .hero-overview span {
    margin-top: 0.3rem;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .contributor-groups {
    display: grid;
    gap: 1.4rem;
  }

  .group-block {
    padding: 1.25rem;
    animation: none;
    backdrop-filter: none;
  }

  .group-block.tone-warm {
    background:
      radial-gradient(circle at top right, rgba(243, 196, 110, 0.18), transparent 22%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(255, 251, 245, 0.9));
  }

  .group-block.tone-cool {
    background:
      radial-gradient(circle at top right, rgba(125, 211, 252, 0.18), transparent 22%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(246, 251, 252, 0.9));
  }

  .group-head {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }

  .group-head p,
  .group-head h2,
  .group-count,
  .group-description,
  .group-note {
    margin: 0;
  }

  .group-head p {
    color: var(--accent-strong);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .group-head h2 {
    margin-top: 0.45rem;
    font-size: clamp(1.7rem, 2.8vw, 2.7rem);
    line-height: 1.05;
  }

  .group-count {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.85rem;
    border: 1px solid rgba(15, 118, 110, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.74);
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .group-description {
    margin-top: 0.75rem;
    max-width: 60ch;
    font-size: 1rem;
    line-height: 1.72;
  }

  .group-join-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.8rem;
  }

  .group-note {
    max-width: 64ch;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.68;
  }

  .group-join-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
    padding: 0.72rem 0.94rem;
    border: 1px solid rgba(15, 118, 110, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.74);
    color: var(--accent-strong);
    font-size: 0.88rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .group-join-link:hover,
  .group-join-link:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(15, 118, 110, 0.24);
    box-shadow: 0 12px 24px rgba(15, 118, 110, 0.08);
    background: rgba(255, 255, 255, 0.92);
  }

  .group-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 1.15rem;
  }

  @media (max-width: 1100px) {
    .group-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 960px) {
    .hero-overview {
      grid-template-columns: 1fr;
    }

    .group-join-row {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 720px) {
    .contributors-hero .hero-title {
      font-size: clamp(2rem, 9vw, 2.7rem);
    }
  }
</style>
