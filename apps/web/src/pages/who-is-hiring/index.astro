---
import JobCard from '@/components/JobCard.astro';
import ListPageHero from '@/components/ListPageHero.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getJobs, getSiteSettings } from '@/lib/content';

const [site, jobs] = await Promise.all([getSiteSettings(), getJobs()]);
const activeJobs = jobs.filter((job) => !job.isExpired);
const expiredJobs = jobs.filter((job) => job.isExpired);
---

<BaseLayout site={site} title="Who-Is-Hiring | Rebase社区招聘" description="查看 Rebase 社区当前公开的招聘信息与岗位详情。">
  <ListPageHero
    title="Rebase 社区当前收到的工作机会"
    summary="Who-Is-Hiring 是免费的招聘频道，任何团队和公司都可以通过 github issue 提交招聘信息，社区志愿者会定期将招聘信息整理并发布在Rebase社区微信公众号和网站上。志愿者只负责整理格式，并不能确保招聘信息真实性，请求职者谨慎对待，如果遇到虚假信息，可以在 github issue上提出反馈，志愿者将会删除相应信息"
    actions={[
      {
        href: 'https://github.com/rebase-network/who-is-hiring',
        label: '提交职位',
        external: true,
      },
      {
        href: '/who-is-hiring/rss.xml',
        label: '订阅 RSS',
        secondary: true,
        showArrow: true,
      },
    ]}
    heroClass="jobs-hero"
  />

  <section id="job-archive" class="shell page-section">
    <div class="jobs-toolbar">
      <p class="jobs-toolbar-copy">
        <strong>开放岗位</strong>
        <span>{activeJobs.length} 个岗位</span>
        {expiredJobs.length > 0 && <span>{expiredJobs.length} 个已过期岗位</span>}
      </p>
    </div>
    {activeJobs.length > 0 ? (
      <div class="grid-3">
        {activeJobs.map((job) => <JobCard job={job} />)}
      </div>
    ) : (
      <article class="card jobs-empty-state">
        <p class="hero-kicker">持续补充</p>
        <h2>当前暂时没有开放岗位。</h2>
        <p>新的公开岗位会继续通过这个页面和 RSS 一起发布，已过期岗位会保留在下方归档中。</p>
      </article>
    )}

    {expiredJobs.length > 0 && (
      <>
        <div class="jobs-toolbar">
          <p class="jobs-toolbar-copy">
            <strong>已过期岗位</strong>
            <span>{expiredJobs.length} 个岗位</span>
          </p>
        </div>
        <div class="grid-3">
          {expiredJobs.map((job) => <JobCard job={job} />)}
        </div>
      </>
    )}
  </section>
</BaseLayout>
