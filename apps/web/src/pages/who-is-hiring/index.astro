---
import JobCard from '@/components/JobCard.astro';
import ListPageHero from '@/components/ListPageHero.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getJobs, getSiteSettings } from '@/lib/content';

const [site, jobs] = await Promise.all([getSiteSettings(), getJobs()]);
const remoteJobCount = jobs.filter((job) => job.supportsRemote).length;
const datedJobCount = jobs.filter((job) => Boolean(job.expiresAt)).length;

const jobSignals = [
  {
    value: String(jobs.length).padStart(2, '0'),
    label: '开放岗位',
    detail: '当前公开可读的岗位机会，优先收敛到同一个入口里浏览和比较。',
  },
  {
    value: String(remoteJobCount).padStart(2, '0'),
    label: '支持远程',
    detail: '远程信息直接前置展示，帮助求职者更快判断是否适合自己。',
  },
  {
    value: String(datedJobCount).padStart(2, '0'),
    label: '标注截止',
    detail: '有明确截止日期的岗位会直接写明，方便优先安排投递顺序。',
  },
];
---

<BaseLayout site={site} title="Who-Is-Hiring | Rebase社区招聘" description="查看 Rebase 社区当前公开的招聘信息与岗位详情。">
  <ListPageHero
    kicker="社区招聘"
    edition="Opportunity Board"
    title="查看 Rebase 社区当前开放的岗位机会。"
    summary="把薪资、工作模式、地点、远程支持和投递入口集中放在同一个公开入口里，方便快速判断和比较。"
    signals={jobSignals}
    jumps={[
      { href: '#job-archive', label: '岗位列表' },
      { href: '/who-is-hiring/rss.xml', label: 'RSS 订阅' },
    ]}
    heroClass="jobs-hero"
  />

  <section id="job-archive" class="shell page-section">
    <SectionHeader
      eyebrow="当前开放岗位"
      title="直接浏览全部岗位"
      description="全部岗位按最近发布时间排序，优先把能快速判断和立即投递的信息放在卡片里。"
      href="/who-is-hiring/rss.xml"
      hrefLabel="订阅 RSS"
    />
    {jobs.length > 0 ? (
      <div class="grid-3">
        {jobs.map((job) => <JobCard job={job} />)}
      </div>
    ) : (
      <article class="card jobs-empty-state">
        <p class="hero-kicker">持续补充</p>
        <h2>更多岗位正在整理中。</h2>
        <p>当前暂时还没有新的公开岗位，后续新增机会会继续通过这个页面和 RSS 一起发布。</p>
      </article>
    )}
  </section>
</BaseLayout>

<style>
  :global(.jobs-hero) {
    background:
      radial-gradient(circle at top left, rgba(243, 196, 110, 0.28), transparent 30%),
      radial-gradient(circle at 92% 18%, rgba(56, 189, 248, 0.16), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 251, 244, 0.92));
  }

  :global(.jobs-hero::before) {
    content: 'HIRING';
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    color: rgba(17, 94, 89, 0.08);
    font-family: var(--display-font);
    font-size: clamp(3.8rem, 8vw, 6.6rem);
    letter-spacing: 0.08em;
    line-height: 0.82;
    pointer-events: none;
  }

  :global(.jobs-hero .hero-title) {
    max-width: 10ch;
    font-size: clamp(2.4rem, 4.9vw, 4.6rem);
  }

  :global(.jobs-hero .hero-summary) {
    max-width: 52ch;
  }

  :global(.jobs-hero .hero-facts article p) {
    line-height: 1.62;
  }

  .jobs-empty-state {
    padding: 1.35rem;
  }

  .jobs-empty-state h2,
  .jobs-empty-state p {
    margin: 0;
  }

  .jobs-empty-state h2 {
    font-size: clamp(1.45rem, 2.2vw, 2.1rem);
  }

  .jobs-empty-state p:not(.hero-kicker) {
    margin-top: 0.75rem;
    max-width: 56ch;
    color: var(--muted);
    line-height: 1.75;
  }
</style>
