---
import BaseLayout from '@/layouts/BaseLayout.astro';
import JobCard from '@/components/JobCard.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { getJobBySlug, getJobs, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';

const slug = Astro.params.slug ?? '';
const [site, job, jobs] = await Promise.all([getSiteSettings(), getJobBySlug(slug), getJobs()]);
const related = job ? jobs.filter((item) => item.slug !== job.slug).slice(0, 2) : [];
const remoteLabel = job ? (job.supportsRemote ? '支持远程' : '线下优先') : '';
const deadlineLabel = job ? (job.expiresAt ? `截止 ${formatDate(job.expiresAt)}` : '长期开放') : '';
const applyCopy = job
  ? job.applyNote || (job.applyUrl ? '请通过下方外部链接投递。' : '请通过下方联系方式投递。')
  : '';
const jobBreadcrumbs = job
  ? [
      { href: '/', label: '首页' },
      { href: '/who-is-hiring', label: '招聘' },
      { label: job.roleTitle, current: true },
    ]
  : [];
const metaItems = job ? [job.salary, job.workMode, job.location, remoteLabel, deadlineLabel].filter(Boolean) : [];
const contactCopy = job?.contactValue ? `${job.contactLabel || '联系方式'}：${job.contactValue}` : '请优先使用岗位投递渠道。';

if (!job) {
  Astro.response.status = 404;
}
---

<BaseLayout
  site={site}
  title={job ? `${job.roleTitle} · ${job.companyName}` : '招聘未找到'}
  description={job ? job.summary : '你访问的招聘信息暂时无法找到。'}
  noindex={!job}
>
  {job ? (
    <>
      <div class="job-detail-page">
        <section class="shell page-hero single">
          <article class="card job-header">
            <div class="job-header-topline">
              <div class="job-header-context">
                <p class="hero-kicker">岗位详情</p>
                <nav class="job-breadcrumbs" aria-label="Breadcrumb">
                  {jobBreadcrumbs.map((item, index) => (
                    <>
                      {item.current || !item.href ? (
                        <span aria-current={item.current ? 'page' : undefined}>{item.label}</span>
                      ) : (
                        <a href={item.href}>{item.label}</a>
                      )}
                      {index < jobBreadcrumbs.length - 1 && <span aria-hidden="true">/</span>}
                    </>
                  ))}
                </nav>
              </div>
              <span class="job-company-chip">{job.companyName}</span>
            </div>

            <h1 class="job-header-title">{job.roleTitle}</h1>
            <p class="job-header-summary">{job.summary}</p>

            <div class="job-header-meta">
              {metaItems.map((item) => (
                <span>{item}</span>
              ))}
            </div>

            {job.applyUrl && (
              <div class="button-row">
                <a class="button-link" href={job.applyUrl} target="_blank" rel="noreferrer">
                  立即投递
                  <span>↗</span>
                </a>
              </div>
            )}
          </article>
        </section>

        <section class="shell page-section job-detail-layout">
          <article class="card job-content-card">
            <div class="job-meta-grid">
              <article>
                <span>公司</span>
                <strong>{job.companyName}</strong>
              </article>
              <article>
                <span>薪资</span>
                <strong>{job.salary}</strong>
              </article>
              <article>
                <span>模式</span>
                <strong>{job.workMode}</strong>
              </article>
              <article>
                <span>地点</span>
                <strong>{job.location}</strong>
              </article>
            </div>

            <MarkdownContent content={job.description} />
          </article>

          <aside class="card job-apply-card">
            <section class="job-apply-section">
              <h2>投递方式</h2>
              <p class="job-apply-copy">{applyCopy}</p>

              <div class="job-apply-actions">
                {job.applyUrl && (
                  <a class="button-link" href={job.applyUrl} target="_blank" rel="noreferrer">
                    打开投递链接
                    <span>↗</span>
                  </a>
                )}
              </div>

              <dl class="job-fact-list">
                <div>
                  <dt>截止时间</dt>
                  <dd>{deadlineLabel}</dd>
                </div>
                <div>
                  <dt>远程支持</dt>
                  <dd>{remoteLabel}</dd>
                </div>
                <div class="job-fact-wide">
                  <dt>联系方式</dt>
                  <dd>{contactCopy}</dd>
                </div>
              </dl>
            </section>
          </aside>
        </section>

        {related.length > 0 && (
          <section class="shell page-section">
            <SectionHeader
              eyebrow="更多机会"
              title="继续浏览其他岗位"
              description="如果这个岗位暂时不匹配，可以继续看看同一批公开机会。"
              href="/who-is-hiring"
              hrefLabel="回到岗位列表"
            />
            <div class="grid-2 job-related-grid">
              {related.map((item) => <JobCard job={item} />)}
            </div>
          </section>
        )}
      </div>
    </>
  ) : (
    <section class="shell page-hero single">
      <article class="hero-panel card">
        <p class="hero-kicker">404</p>
        <h1 class="hero-title">这个招聘页面暂时没有被找到。</h1>
        <p class="hero-summary">你可以先回到招聘列表，浏览社区当前公开的岗位信息。</p>
      </article>
    </section>
  )}
</BaseLayout>
