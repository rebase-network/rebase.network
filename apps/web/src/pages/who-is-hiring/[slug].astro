---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DetailHero from '@/components/DetailHero.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import { getJobBySlug, getJobs, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';
import { getJobPath } from '@/lib/paths';

const slug = Astro.params.slug ?? '';
const [site, job, jobs] = await Promise.all([getSiteSettings(), getJobBySlug(slug), getJobs()]);
const related = job ? jobs.filter((item) => item.slug !== job.slug).slice(0, 3) : [];
const remoteLabel = job ? (job.supportsRemote ? '支持远程' : '线下优先') : '';
const deadlineLabel = job ? (job.expiresAt ? `截止 ${formatDate(job.expiresAt)}` : '长期开放') : '';
const applyCopy = job
  ? job.applyNote || (job.applyUrl ? '请通过下方报名表单或公开链接投递。' : '请通过下方联系方式投递。')
  : '';
const heroMetaItems = job ? [job.salary, job.workMode, job.location].filter(Boolean) : [];
const contactValue = job?.contactValue?.trim() ?? '';
const contactLabel = job?.contactLabel?.trim() || '联系方式';
const jobBodyLead = job
  ? [
      [job.companyName, remoteLabel].filter(Boolean).join(' · '),
      [job.salary, job.workMode, job.location, deadlineLabel].filter(Boolean).join(' · '),
    ]
  : [];

if (!job) {
  Astro.response.status = 404;
}
---

<BaseLayout
  site={site}
  title={job ? `${job.roleTitle} · ${job.companyName}` : '招聘未找到'}
  description={job ? job.summary : '你访问的招聘信息暂时无法找到。'}
  noindex={!job}
>
  {job ? (
    <>
      <section class="shell page-hero single">
        <DetailHero
          titleAside={job.companyName}
          title={job.roleTitle}
          summary={job.summary}
          meta={heroMetaItems}
          actions={job.applyUrl ? [{ href: job.applyUrl, label: '立即投递', external: true, showIcon: true }] : []}
          hideTopline={true}
          inlineMetaActions={true}
          heroClass="job-hero"
        />
      </section>

      <section class="shell page-section detail-shell job-detail-shell">
        <article id="job-body" class="card detail-body-card job-detail">
          <div class="detail-body-lead job-meta">
            {jobBodyLead.map((line) => (
              <p>{line}</p>
            ))}
          </div>
          <div class="job-reading-frame">
            <MarkdownContent content={job.description} />
          </div>
        </article>

        <aside class="card detail-sidebar">
          <section class="detail-sidebar-section">
            <h2>岗位信息</h2>
            <ul class="detail-fact-list">
              <li>
                <strong>公司</strong>
                <span>{job.companyName}</span>
              </li>
              <li>
                <strong>薪资</strong>
                <span>{job.salary}</span>
              </li>
              <li>
                <strong>工作方式</strong>
                <span>{job.workMode}</span>
              </li>
              <li>
                <strong>工作地点</strong>
                <span>{job.location}</span>
              </li>
              <li>
                <strong>远程支持</strong>
                <span>{remoteLabel}</span>
              </li>
              <li>
                <strong>截止时间</strong>
                <span>{deadlineLabel}</span>
              </li>
            </ul>
          </section>

          <section class="detail-sidebar-section">
            <h2>投递方式</h2>
            <p class="detail-sidebar-copy">{applyCopy}</p>
            {(job.applyUrl || contactValue) && (
              <ul class="detail-sidebar-list">
                {job.applyUrl && (
                  <li>
                    <a href={job.applyUrl} target="_blank" rel="noreferrer">
                      立即投递
                    </a>
                  </li>
                )}
                {contactValue && (
                  <li>
                    <span class="detail-static-item">{contactLabel}：{contactValue}</span>
                  </li>
                )}
              </ul>
            )}
          </section>

          <section class="detail-sidebar-section">
            <h2>继续关注</h2>
            <ul class="detail-sidebar-list">
              <li><a href="/who-is-hiring/rss.xml">订阅招聘 RSS</a></li>
              <li><a href="/who-is-hiring">回到招聘列表</a></li>
            </ul>
          </section>

          {related.length > 0 && (
            <section class="detail-sidebar-section">
              <h2>更多岗位</h2>
              <ul class="related-list">
                {related.map((item) => (
                  <li><a href={getJobPath(item.slug)}>{item.roleTitle}</a></li>
                ))}
              </ul>
            </section>
          )}
        </aside>
      </section>
    </>
  ) : (
    <section class="shell page-hero single">
      <article class="hero-panel card">
        <p class="hero-kicker">404</p>
        <h1 class="hero-title">这个招聘页面暂时没有被找到。</h1>
        <p class="hero-summary">你可以先回到招聘列表，浏览社区当前公开的岗位信息。</p>
      </article>
    </section>
  )}
</BaseLayout>

<style>
  .single {
    grid-template-columns: 1fr;
  }

  :global(.job-hero) {
    color: white;
    padding: 1.05rem 1.2rem 0.92rem;
    background:
      radial-gradient(circle at top right, rgba(243, 196, 110, 0.22), transparent 22%),
      linear-gradient(135deg, rgba(16, 37, 34, 0.98), rgba(17, 94, 89, 0.92));
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 28px 60px rgba(16, 37, 34, 0.24);
  }

  :global(.job-hero .hero-title) {
    max-width: 11.5ch;
    margin-top: 0;
    font-size: clamp(2.18rem, 4.4vw, 3.96rem);
    line-height: 0.94;
  }

  :global(.job-hero .detail-title-row) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  :global(.job-hero .detail-title-aside) {
    flex-shrink: 0;
    padding-top: 0.24rem;
    font-size: 0.64rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.44;
  }

  :global(.job-hero .hero-summary) {
    max-width: 56ch;
    margin-top: 0.58rem;
    font-size: 0.95rem;
    line-height: 1.58;
  }

  :global(.job-hero .detail-footer-row) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.62rem;
  }

  :global(.job-hero .detail-meta-strip) {
    gap: 0.5rem;
    margin-top: 0;
  }

  :global(.job-hero .detail-meta-pill) {
    position: relative;
    padding: 0;
    border: none;
    border-radius: 0;
    background: transparent;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    opacity: 0.92;
  }

  :global(.job-hero .detail-meta-pill:not(:last-child)::after) {
    content: '·';
    margin-left: 0.5rem;
    opacity: 0.45;
  }

  :global(.job-hero .button-row) {
    justify-content: flex-end;
    margin-top: 0;
  }

  :global(.job-hero .button-link) {
    padding: 0.34rem 0.7rem;
    font-size: 0.69rem;
    letter-spacing: 0.06em;
  }

  .job-detail {
    padding: 1.45rem;
  }

  .job-meta p {
    margin: 0;
  }

  .job-reading-frame {
    width: min(100%, 46rem);
    margin: 0 auto;
  }

  .job-detail :global(.markdown) {
    font-size: 1.05rem;
    line-height: 1.86;
  }

  .job-detail :global(.markdown h2) {
    margin-top: 2.3rem;
    font-size: 1.75rem;
  }

  .detail-static-item {
    display: block;
    padding: 0.82rem 0.9rem;
    border: 1px solid rgba(223, 244, 238, 0.12);
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.7;
  }

  @media (max-width: 780px) {
    :global(.job-hero .detail-title-row),
    :global(.job-hero .detail-footer-row) {
      flex-direction: column;
      align-items: flex-start;
    }

    :global(.job-hero .detail-title-aside) {
      padding-top: 0;
    }
  }
</style>
