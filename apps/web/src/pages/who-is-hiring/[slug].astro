---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DetailHero from '@/components/DetailHero.astro';
import DetailSidebarLinksSection from '@/components/DetailSidebarLinksSection.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import { getJobBySlug, getJobs, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';
import { getJobPath } from '@/lib/paths';

const slug = Astro.params.slug ?? '';
const [site, job, jobs] = await Promise.all([getSiteSettings(), getJobBySlug(slug), getJobs()]);
const related = job ? jobs.filter((item) => item.slug !== job.slug).slice(0, 2) : [];
const remoteLabel = job ? (job.supportsRemote ? '支持远程' : '线下优先') : '';
const applyCopy = job
  ? job.applyNote || (job.applyUrl ? '请通过下方外部链接投递。' : '请通过下方联系方式投递。')
  : '';
const jobBreadcrumbs = job
  ? [
      { href: '/', label: '首页' },
      { href: '/who-is-hiring', label: '招聘' },
      { label: job.roleTitle, current: true },
    ]
  : [];
const jobHeroMeta = job ? [job.workMode, job.location, remoteLabel].filter(Boolean) : [];
const jobHeroActions = job
  ? [
      ...(job.applyUrl ? [{ href: job.applyUrl, label: '立即投递', external: true, showIcon: true }] : []),
      { href: '/who-is-hiring', label: '回到招聘列表', secondary: true },
    ]
  : [];
const jobJumpLinks = [
  { href: '#job-overview', label: '岗位概览' },
  { href: '#job-responsibilities', label: '工作内容' },
  { href: '#job-info', label: '投递信息' },
];
const jobWayfindingLinks = [
  { href: '#job-overview', label: '查看岗位概览' },
  { href: '#job-responsibilities', label: '查看工作内容' },
  { href: '#job-info', label: '查看投递信息' },
];
const jobActionLinks = [
  ...(job?.applyUrl ? [{ href: job.applyUrl, label: '打开外部投递链接', external: true }] : []),
  { href: '/who-is-hiring', label: '回到招聘列表' },
];
const jobRelatedLinks = related.map((item) => ({
  href: getJobPath(item.slug),
  label: item.roleTitle,
}));

if (!job) {
  Astro.response.status = 404;
}
---

<BaseLayout
  site={site}
  title={job ? `${job.roleTitle} · ${job.companyName}` : '招聘未找到'}
  description={job ? job.summary : '你访问的招聘信息暂时无法找到。'}
  noindex={!job}
>
  {job ? (
    <>
      <section class="shell page-hero single">
        <DetailHero
          kicker="岗位详情"
          breadcrumbs={jobBreadcrumbs}
          edition={job.companyName}
          title={job.roleTitle}
          summary={job.summary}
          meta={jobHeroMeta}
          note={`${job.salary} · 发布时间 ${formatDate(job.publishedAt)}`}
          actions={jobHeroActions}
          jumps={jobJumpLinks}
          heroClass="job-hero"
        />
      </section>

      <section class="shell page-section detail-shell">
        <article id="job-overview" class="card detail-body-card job-detail">
          <div class="job-meta-grid">
            <article>
              <span>公司</span>
              <strong>{job.companyName}</strong>
            </article>
            <article>
              <span>薪资</span>
              <strong>{job.salary}</strong>
            </article>
            <article>
              <span>模式</span>
              <strong>{job.workMode}</strong>
            </article>
            <article>
              <span>地点</span>
              <strong>{job.location}</strong>
            </article>
          </div>

          <MarkdownContent content={job.description} />

          <section id="job-responsibilities" class="responsibilities">
            <h2>工作内容</h2>
            <ul>
              {job.responsibilities.map((item) => <li>{item}</li>)}
            </ul>
          </section>
        </article>

        <aside class="card detail-sidebar">
          <DetailSidebarLinksSection
            title="页面导览"
            copy="如果你是从搜索结果或职位分享进入，可以先用这些锚点快速判断是否匹配。"
            links={jobWayfindingLinks}
          />

          <section id="job-info" class="detail-sidebar-section">
            <h2>投递信息</h2>
            <p class="detail-sidebar-copy">{applyCopy}</p>
            <ul class="detail-fact-list">
              <li>
                <strong>发布时间</strong>
                <span>{formatDate(job.publishedAt)}</span>
              </li>
              <li>
                <strong>远程支持</strong>
                <span>{remoteLabel}</span>
              </li>
              <li>
                <strong>联系方式</strong>
                <span>{job.contactValue ? `${job.contactLabel || '联系方式'}：${job.contactValue}` : '请优先使用岗位投递渠道。'}</span>
              </li>
            </ul>
            {job.tags.length > 0 && (
              <ul class="detail-tag-list">
                {job.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            )}
          </section>

          <DetailSidebarLinksSection id="job-actions" title="继续查看" links={jobActionLinks} />

          {related.length > 0 && (
            <DetailSidebarLinksSection
              id="job-related"
              title="相关岗位"
              links={jobRelatedLinks}
              listClass="related-list"
            />
          )}
        </aside>
      </section>
    </>
  ) : (
    <section class="shell page-hero single">
      <article class="hero-panel card">
        <p class="hero-kicker">404</p>
        <h1 class="hero-title">这个招聘页面暂时没有被找到。</h1>
        <p class="hero-summary">你可以先回到招聘列表，浏览社区当前公开的岗位信息。</p>
      </article>
    </section>
  )}
</BaseLayout>

<style>
  .single {
    grid-template-columns: 1fr;
  }

  .job-hero {
    color: white;
    background:
      radial-gradient(circle at 15% 18%, rgba(125, 211, 252, 0.2), transparent 24%),
      linear-gradient(135deg, rgba(19, 33, 68, 0.98), rgba(15, 118, 110, 0.92));
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 28px 60px rgba(19, 33, 68, 0.24);
  }

  .light {
    color: white;
  }

  .job-meta-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin-bottom: 1.2rem;
  }

  .job-meta-grid article {
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(31, 41, 51, 0.08);
  }

  .job-meta-grid span,
  .job-meta-grid strong {
    display: block;
  }

  .job-meta-grid span {
    color: var(--muted);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .job-meta-grid strong {
    margin-top: 0.4rem;
    font-size: 1.05rem;
  }

  .responsibilities {
    margin-top: 1.5rem;
  }

  .responsibilities h2 {
    margin: 0 0 0.8rem;
    font-size: 1.4rem;
  }

  .responsibilities ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--muted);
    line-height: 1.8;
  }

  @media (max-width: 960px) {
    .job-meta-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
