---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import { getJobBySlug, getJobs, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';
import { getJobPath } from '@/lib/paths';

const slug = Astro.params.slug ?? '';
const [site, job, jobs] = await Promise.all([getSiteSettings(), getJobBySlug(slug), getJobs()]);
const related = job ? jobs.filter((item) => item.slug !== job.slug).slice(0, 3) : [];
const remoteLabel = job ? (job.supportsRemote ? '支持远程' : '线下优先') : '';
const deadlineLabel = job ? (job.expiresAt ? `截止 ${formatDate(job.expiresAt)}` : '长期开放') : '';
const applyCopy = job
  ? job.applyNote || (job.applyUrl ? '请通过下方报名表单或公开链接投递。' : '请通过下方联系方式投递。')
  : '';
const contactValue = job?.contactValue?.trim() ?? '';
const contactLabel = job?.contactLabel?.trim() || '联系方式';
const metaItems = job ? [job.salary, job.workMode, job.location, remoteLabel, deadlineLabel].filter(Boolean) : [];

if (!job) {
  Astro.response.status = 404;
}
---

<BaseLayout
  site={site}
  title={job ? `${job.roleTitle} · ${job.companyName}` : '招聘未找到'}
  description={job ? job.summary : '你访问的招聘信息暂时无法找到。'}
  noindex={!job}
>
  {job ? (
    <>
      <section class="shell page-section detail-shell job-detail-shell">
        <article id="job-body" class="card detail-body-card job-detail">
          <header class="job-head">
            <p class="job-eyebrow">{job.companyName}</p>
            <h1>{job.roleTitle}</h1>
            <p class="job-summary">{job.summary}</p>
            {metaItems.length > 0 && (
              <ul class="job-meta-list">
                {metaItems.map((item) => <li>{item}</li>)}
              </ul>
            )}
            {applyCopy && <p class="job-apply-note">{applyCopy}</p>}
          </header>
          <div class="job-reading-frame">
            <MarkdownContent content={job.description} />
          </div>
        </article>

        <aside class="card detail-sidebar">
          <section class="detail-sidebar-section">
            <h2>投递方式</h2>
            {(job.applyUrl || contactValue) && (
              <>
                {job.applyUrl && (
                  <a class="job-sidebar-primary" href={job.applyUrl} target="_blank" rel="noreferrer">
                    立即投递 <span>↗</span>
                  </a>
                )}
                <ul class="detail-sidebar-list">
                {contactValue && (
                  <li>
                    <span class="detail-static-item">{contactLabel}：{contactValue}</span>
                  </li>
                )}
                </ul>
              </>
            )}
          </section>

          <section class="detail-sidebar-section">
            <h2>继续关注</h2>
            <ul class="detail-sidebar-list">
              <li><a href="/who-is-hiring/rss.xml">订阅招聘 RSS</a></li>
              <li><a href="/who-is-hiring">回到招聘列表</a></li>
            </ul>
          </section>

          {related.length > 0 && (
            <section class="detail-sidebar-section">
              <h2>更多岗位</h2>
              <ul class="related-list">
                {related.map((item) => (
                  <li><a href={getJobPath(item.slug)}>{item.roleTitle}</a></li>
                ))}
              </ul>
            </section>
          )}
        </aside>
      </section>
    </>
  ) : (
    <section class="shell page-hero single">
      <article class="hero-panel card">
        <p class="hero-kicker">404</p>
        <h1 class="hero-title">这个招聘页面暂时没有被找到。</h1>
        <p class="hero-summary">你可以先回到招聘列表，浏览社区当前公开的岗位信息。</p>
      </article>
    </section>
  )}
</BaseLayout>

<style>
  .job-head {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.45rem;
    padding-bottom: 1.3rem;
    border-bottom: 1px solid rgba(31, 41, 51, 0.08);
  }

  .job-detail {
    padding: 1.45rem;
  }

  .job-head h1,
  .job-summary,
  .job-apply-note {
    margin: 0;
  }

  .job-eyebrow {
    margin: 0;
    color: var(--accent-strong);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .job-head h1 {
    font-size: clamp(2rem, 3.4vw, 3rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
  }

  .job-summary {
    max-width: 62ch;
    color: var(--muted);
    line-height: 1.8;
  }

  .job-meta-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .job-meta-list li {
    padding: 0.42rem 0.72rem;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.08);
    color: var(--accent-strong);
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1.5;
  }

  .job-apply-note {
    max-width: 60ch;
    color: var(--text);
    line-height: 1.75;
  }

  .job-reading-frame {
    width: min(100%, 46rem);
    margin: 0 auto;
  }

  .job-detail :global(.markdown) {
    font-size: 1.05rem;
    line-height: 1.86;
  }

  .job-detail :global(.markdown h2) {
    margin-top: 2.3rem;
    font-size: 1.75rem;
  }

  .detail-static-item {
    display: block;
    padding: 0.82rem 0.9rem;
    border: 1px solid rgba(223, 244, 238, 0.12);
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.7;
  }

  .job-sidebar-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    width: 100%;
    margin-top: 0.8rem;
    padding: 0.82rem 0.9rem;
    border: 1px solid rgba(243, 196, 110, 0.24);
    border-radius: 0.9rem;
    background: rgba(243, 196, 110, 0.16);
    color: #fff;
    font-weight: 800;
    letter-spacing: 0.04em;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease, box-shadow 180ms ease;
  }

  .job-sidebar-primary:hover,
  .job-sidebar-primary:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(243, 196, 110, 0.34);
    background: rgba(243, 196, 110, 0.22);
    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.14);
  }
</style>
