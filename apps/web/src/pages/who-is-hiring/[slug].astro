---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import { getJobByPublicNumber, getJobs, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';
import { getJobPath, getJobPublicNumberFromRouteParam } from '@/lib/paths';

const routeParam = Astro.params.slug ?? '';
const jobPublicNumber = getJobPublicNumberFromRouteParam(routeParam);
const [site, job, jobs] = await Promise.all([getSiteSettings(), getJobByPublicNumber(jobPublicNumber), getJobs()]);
const related = job ? jobs.filter((item) => item.publicNumber !== job.publicNumber).slice(0, 3) : [];
const normalizedCompanyName = job?.companyName.trim() ?? '';
const companyName = normalizedCompanyName && !['/', '-', '—'].includes(normalizedCompanyName)
  ? normalizedCompanyName
  : '公司未公开';
const remoteLabel = job ? (job.supportsRemote ? '支持远程' : '线下优先') : '';
const expiryLabel = job?.isExpired ? '岗位已过期' : '';
const updateLabel = job ? `最后更新 ${formatDate(job.updatedAt)}` : '';
const formatWorkMode = (value: string) => {
  switch (value) {
    case 'full-time':
      return '全职';
    case 'part-time':
      return '兼职';
    default:
      return value;
  }
};
const applyCopy = job
  ? job.isExpired
    ? '该岗位已由运营标记为过期，如仍有兴趣，请先与招聘方确认岗位是否仍在开放。'
    : job.applyNote || (job.applyUrl ? '请通过下方公开链接投递，或按招聘方说明联系。' : '请通过下方联系方式联系招聘方。')
  : '';
const contactValue = job?.contactValue?.trim() ?? '';
const contactLabel = job?.contactLabel?.trim() || '联系方式';
const applyButtonLabel = job?.isExpired ? '查看原投递链接' : '立即投递';
const metaItems = job ? [job.salary, formatWorkMode(job.workMode), job.location, remoteLabel, expiryLabel, updateLabel].filter(Boolean) : [];

if (!job) {
  Astro.response.status = 404;
}
---

<BaseLayout
  site={site}
  title={job ? `${job.roleTitle} · ${companyName}` : '招聘未找到'}
  description={job ? job.summary : '你访问的招聘信息暂时无法找到。'}
  noindex={!job}
>
  {job ? (
    <>
      <section class="shell page-section detail-shell job-detail-shell">
        <article id="job-body" class="card detail-body-card job-detail">
          <header class="job-head">
            <p class:list={['job-eyebrow', companyName === '公司未公开' && 'is-missing']}>{companyName}</p>
            <h1>{job.roleTitle}</h1>
            <p class="job-summary">{job.summary}</p>
            {metaItems.length > 0 && (
              <ul class="job-meta-list">
                {metaItems.map((item) => <li>{item}</li>)}
              </ul>
            )}
            {applyCopy && <p class="job-apply-note">{applyCopy}</p>}
          </header>
          <div class="job-reading-frame">
            <MarkdownContent content={job.description} />
          </div>
        </article>

        <aside class="card detail-sidebar">
          <section class="detail-sidebar-section">
            <h2>投递方式</h2>
            {(job.applyUrl || contactValue) && (
              <>
                {job.applyUrl && (
                  <a class="job-sidebar-primary" href={job.applyUrl} target="_blank" rel="noreferrer">
                    {applyButtonLabel} <span>↗</span>
                  </a>
                )}
                <ul class="detail-sidebar-list">
                {contactValue && (
                  <li>
                    <span class="detail-static-item">{contactLabel}：{contactValue}</span>
                  </li>
                )}
                </ul>
              </>
            )}
          </section>

          <section class="detail-sidebar-section">
            <h2>继续关注</h2>
            <ul class="detail-sidebar-list">
              <li><a href="/who-is-hiring/rss.xml">订阅招聘 RSS</a></li>
              <li><a href="/who-is-hiring">回到招聘列表</a></li>
            </ul>
          </section>

          {related.length > 0 && (
            <section class="detail-sidebar-section">
              <h2>更多岗位</h2>
              <ul class="related-list">
                {related.map((item) => (
                  <li><a href={getJobPath(item.publicNumber, item.slug)}>{item.roleTitle}</a></li>
                ))}
              </ul>
            </section>
          )}
        </aside>
      </section>
    </>
  ) : (
    <section class="shell page-hero single">
      <article class="hero-panel card">
        <p class="hero-kicker">404</p>
        <h1 class="hero-title">这个招聘页面暂时没有被找到。</h1>
        <p class="hero-summary">你可以先回到招聘列表，浏览社区当前公开的岗位信息。</p>
      </article>
    </section>
  )}
</BaseLayout>

<style>
  .job-head {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.45rem;
    padding-bottom: 1.3rem;
    border-bottom: 1px solid rgba(31, 41, 51, 0.08);
  }

  .job-detail {
    padding: 1.45rem;
  }

  .job-head h1,
  .job-summary,
  .job-apply-note {
    margin: 0;
  }

  .job-eyebrow {
    margin: 0;
    color: var(--accent-strong);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    text-transform: none;
  }

  .job-eyebrow.is-missing {
    color: var(--muted);
  }

  .job-head h1 {
    font-size: clamp(2rem, 3.4vw, 3rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
  }

  .job-summary {
    max-width: 62ch;
    color: var(--muted);
    line-height: 1.8;
  }

  .job-meta-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .job-meta-list li {
    padding: 0.42rem 0.72rem;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.08);
    color: var(--accent-strong);
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1.5;
  }

  .job-apply-note {
    max-width: 60ch;
    color: var(--text);
    line-height: 1.75;
  }

  .job-reading-frame {
    width: min(100%, 46rem);
    margin: 0 auto;
  }

  .job-detail :global(.markdown) {
    font-size: 1.05rem;
    line-height: 1.86;
  }

  .job-detail :global(.markdown h2) {
    margin-top: 2.3rem;
    font-size: 1.75rem;
  }

  .detail-static-item {
    display: block;
    padding: 0.82rem 0.9rem;
    border: 1px solid rgba(31, 41, 51, 0.08);
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.66);
    color: var(--text);
    line-height: 1.7;
  }

  .job-sidebar-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    width: 100%;
    margin-top: 0.8rem;
    padding: 0.82rem 0.9rem;
    border: 1px solid rgba(15, 118, 110, 0.18);
    border-radius: 0.9rem;
    background: rgba(15, 118, 110, 0.1);
    color: var(--accent-strong);
    font-weight: 800;
    letter-spacing: 0.04em;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease, box-shadow 180ms ease;
  }

  .job-sidebar-primary:hover,
  .job-sidebar-primary:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(15, 118, 110, 0.28);
    background: rgba(15, 118, 110, 0.14);
    box-shadow: var(--shadow-soft);
  }
</style>
