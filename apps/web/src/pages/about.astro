---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import { getAboutContent, getSiteSettings } from '@/lib/content';

const [site, about] = await Promise.all([getSiteSettings(), getAboutContent()]);
const { intro, sections, seoTitle, seoDescription } = about;

const pageTitle = seoTitle?.trim() || '关于 Rebase';
const pageDescription = seoDescription?.trim() || intro.summary;
const orderedSections = sections.filter((section) => section.title.trim() || section.body.trim());
const sectionLabel = (index: number) => String(index + 1).padStart(2, '0');
---

<BaseLayout site={site} title={pageTitle} description={pageDescription}>
  <section class="shell page-hero single">
    <article class="hero-panel card about-hero">
      <h1 class="hero-title">{intro.title}</h1>
      <p class="hero-summary">{intro.summary}</p>
    </article>
  </section>

  <section class="shell page-section">
    <article class="card about-story">
      {orderedSections.length > 0 ? (
        <div class="story-flow">
          {orderedSections.map((section, index) => (
            <section class="story-section">
              <div class="story-topline">
                <span>{sectionLabel(index)}</span>
              </div>
              <h2>{section.title}</h2>
              <MarkdownContent content={section.body} />
            </section>
          ))}
        </div>
      ) : (
        <div class="story-empty">
          <p class="story-kicker">社区说明</p>
          <h2>关于页内容正在整理中。</h2>
          <p>我们会很快补充 Rebase 的背景、理念与协作方式。</p>
        </div>
      )}
    </article>
  </section>
</BaseLayout>

<style>
  .single {
    grid-template-columns: 1fr;
  }

  .about-hero {
    position: relative;
    overflow: hidden;
    padding: 1.05rem 1.18rem 0.98rem;
    background:
      radial-gradient(circle at top left, rgba(243, 196, 110, 0.28), transparent 30%),
      radial-gradient(circle at 92% 18%, rgba(15, 118, 110, 0.16), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 251, 244, 0.92));
    border-color: rgba(15, 118, 110, 0.14);
    box-shadow: 0 28px 60px rgba(26, 40, 34, 0.12);
  }

  .about-hero::before {
    content: 'REBASE';
    position: absolute;
    top: 0.78rem;
    right: 0.98rem;
    color: rgba(17, 94, 89, 0.025);
    font-family: var(--display-font);
    font-size: clamp(2.8rem, 5vw, 4.8rem);
    letter-spacing: 0.08em;
    line-height: 0.82;
    pointer-events: none;
  }

  .about-hero > * {
    position: relative;
    z-index: 1;
  }

  .about-hero .hero-title {
    max-width: 16ch;
    font-size: clamp(2.35rem, 3vw + 1rem, 3.55rem);
    line-height: 1.1;
    letter-spacing: -0.035em;
    text-wrap: balance;
  }

  .about-story {
    padding: clamp(1.45rem, 2.8vw, 2rem);
    background:
      radial-gradient(circle at top right, rgba(243, 196, 110, 0.16), transparent 22%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(248, 252, 251, 0.9));
  }

  .story-empty {
    display: grid;
    gap: 0.75rem;
    width: min(100%, 48rem);
    margin: 0 auto;
  }

  .story-kicker {
    margin: 0;
    color: var(--accent-strong);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .story-flow {
    min-width: 0;
    width: min(100%, 48rem);
    margin: 0 auto;
  }

  .story-section {
    min-width: 0;
    padding-top: 1.45rem;
  }

  .story-section + .story-section {
    margin-top: 1.45rem;
    border-top: 1px solid var(--line);
  }

  .story-topline {
    display: flex;
    align-items: center;
  }

  .story-topline span {
    display: inline-grid;
    width: 2.4rem;
    height: 2.4rem;
    place-items: center;
    border-radius: 0.8rem;
    background: rgba(15, 118, 110, 0.1);
    color: var(--accent-strong);
    font-size: 0.85rem;
    font-weight: 800;
  }

  .story-section h2,
  .story-empty h2 {
    margin: 0.95rem 0 1rem;
    font-size: clamp(1.7rem, 2.8vw, 2.55rem);
    line-height: 1.08;
    text-wrap: balance;
  }

  .story-empty {
    min-height: 16rem;
    align-content: center;
  }

  .story-empty p:last-child {
    margin: 0;
    max-width: 40rem;
    color: var(--muted);
    line-height: 1.8;
  }

  .story-section :global(.markdown) {
    font-size: 1rem;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .story-section :global(.markdown p),
  .story-section :global(.markdown li),
  .story-section :global(.markdown a) {
    overflow-wrap: anywhere;
  }

  .story-section :global(.markdown code) {
    word-break: break-all;
  }

  .story-section :global(.markdown > :last-child),
  .story-empty p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 720px) {
    .about-hero::before {
      top: 0.72rem;
      right: 0.78rem;
      font-size: clamp(2.35rem, 12vw, 3.8rem);
    }

    .about-hero {
      padding: 0.96rem 0.96rem 0.92rem;
    }

    .story-section h2,
    .story-empty h2 {
      margin-top: 0.85rem;
    }
  }
</style>
