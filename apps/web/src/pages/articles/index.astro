---
import ArticleCard from '@/components/ArticleCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { getArticles, getSiteSettings } from '@/lib/content';

const [site, articles] = await Promise.all([getSiteSettings(), getArticles()]);
const leadArticle = articles[0];
const archiveArticles = articles.slice(1);
---

<BaseLayout site={site} title="Rebase 文章" description="浏览 Rebase 社区发布的文章、复盘与方法总结。">
  <section class="shell page-hero single">
    <article class="hero-panel card archive-hero">
      <p class="hero-kicker">文章归档</p>
      <h1 class="hero-title">把社区里的想法、复盘和方法写成可以沉淀下来的文章。</h1>
      <p class="hero-summary">文章页承接更长线的讨论：产品、信息架构、社区运营和 builder workflow。</p>
      <div class="hero-facts">
        <article>
          <span>文章总数</span>
          <strong>{articles.length}</strong>
        </article>
        <article>
          <span>订阅源</span>
          <strong>/articles/rss.xml</strong>
        </article>
      </div>
    </article>
  </section>

  {leadArticle && (
    <section class="shell page-section">
      <SectionHeader
        eyebrow="主推荐"
        title="编辑台推荐阅读"
        description="文章页首页保留一个主稿入口，优先承接最能代表 Rebase 方法论的长文。"
      />
      <div class="lead-layout">
        <ArticleCard article={leadArticle} featured />
        <article class="card archive-note">
          <p class="hero-kicker">阅读提示</p>
          <h2>公开写作不是宣传页，而是把社区如何思考、如何迭代、如何组织信息留下可复用的上下文。</h2>
          <p>文章和 GeekDaily、活动、招聘互相导流：日报负责更新速度，文章负责沉淀深度。</p>
          <a href="/articles/rss.xml">订阅文章 RSS</a>
        </article>
      </div>
    </section>
  )}

  <section class="shell page-section">
    <SectionHeader
      eyebrow="文章列表"
      title="全部文章"
      description="第一版先聚焦结构清晰、可阅读、可订阅的社区写作体验。"
      href="/articles/rss.xml"
      hrefLabel="订阅 RSS"
    />
    <div class="grid-3">
      {archiveArticles.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .single {
    grid-template-columns: 1fr;
  }

  .archive-hero {
    background:
      radial-gradient(circle at top right, rgba(245, 158, 11, 0.16), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(255, 252, 247, 0.9));
  }

  .hero-facts {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    margin-top: 1.4rem;
  }

  .hero-facts article,
  .archive-note {
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.66);
    border: 1px solid rgba(31, 41, 51, 0.08);
  }

  .hero-facts span,
  .hero-facts strong {
    display: block;
  }

  .hero-facts span {
    color: var(--accent-strong);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-facts strong {
    margin-top: 0.45rem;
    font-size: 1.05rem;
  }

  .lead-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(18rem, 0.9fr);
    gap: 1rem;
  }

  .archive-note h2,
  .archive-note p {
    margin: 0;
  }

  .archive-note h2 {
    font-size: clamp(1.8rem, 2.5vw, 2.6rem);
    line-height: 1.05;
  }

  .archive-note p {
    margin-top: 0.9rem;
    color: var(--muted);
    line-height: 1.8;
  }

  .archive-note a {
    display: inline-flex;
    margin-top: 1rem;
    color: var(--accent-strong);
    font-weight: 800;
  }

  @media (max-width: 960px) {
    .hero-facts,
    .lead-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
