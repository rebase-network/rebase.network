---
import ArticleCard from '@/components/ArticleCard.astro';
import ListEmptyState from '@/components/ListEmptyState.astro';
import ListPageHero from '@/components/ListPageHero.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getArticles, getSiteSettings } from '@/lib/content';

const [site, articles] = await Promise.all([getSiteSettings(), getArticles()]);
const leadArticle = articles[0];
const archiveArticles = articles.slice(1);
---

<BaseLayout site={site} title="Rebase 文章" description="浏览 Rebase 社区发布的文章、复盘与方法总结。">
  <ListPageHero
    kicker="文章"
    edition="Rebase Writing"
    title="Rebase 文章"
    summary="把社区里的判断、复盘和方法整理成可以继续阅读、继续引用的长内容。"
    heroClass="articles-hero"
  />

  <section id="article-latest" class="shell page-section">
    <SectionHeader
      eyebrow="最新文章"
      title="先从最近的一篇开始"
      description="最新发布的长文放在最前面，其余文章继续留在归档里。"
      href="/articles/rss.xml"
      hrefLabel="订阅 RSS"
    />
    {leadArticle ? (
      <div class="article-lead-grid">
        <ArticleCard article={leadArticle} featured />
      </div>
    ) : (
      <ListEmptyState
        kicker="持续整理"
        title="文章归档正在建立中。"
        description="新的复盘、方法和判断会逐步补充进这个栏目。"
      />
    )}
  </section>

  <section id="article-archive" class="shell page-section">
    <SectionHeader
      eyebrow="文章归档"
      title="全部文章"
      description="按发布时间持续归档，方便继续查找、继续引用。"
      href="/articles/rss.xml"
      hrefLabel="订阅 RSS"
    />
    {archiveArticles.length > 0 ? (
      <div class="grid-3">
        {archiveArticles.map((article) => <ArticleCard article={article} />)}
      </div>
    ) : (
      <ListEmptyState
        kicker="持续更新"
        title="更多文章正在整理中。"
        description="当前先保留主稿入口，后续会继续把新的复盘、判断和方法写作补进这份归档里。"
      />
    )}
  </section>
</BaseLayout>

<style>
  :global(.articles-hero) {
    background:
      radial-gradient(circle at top left, rgba(243, 196, 110, 0.28), transparent 30%),
      radial-gradient(circle at 92% 18%, rgba(15, 118, 110, 0.14), transparent 22%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 251, 244, 0.92));
  }

  :global(.articles-hero::before) {
    content: 'WRITING';
    position: absolute;
    top: 1rem;
    right: 1.3rem;
    color: rgba(17, 94, 89, 0.08);
    font-family: var(--display-font);
    font-size: clamp(3.8rem, 8vw, 6.6rem);
    letter-spacing: 0.08em;
    line-height: 0.82;
    pointer-events: none;
  }

  :global(.articles-hero .hero-title) {
    max-width: 8ch;
    text-wrap: balance;
  }

  .article-lead-grid {
    display: grid;
  }
</style>
