---
import ArticleCard from '@/components/ArticleCard.astro';
import ListEmptyState from '@/components/ListEmptyState.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getArticles, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';
import { getArticlePath } from '@/lib/paths';
import { DEFAULT_ARTICLE_COVER_PATH } from '@/lib/placeholders';

const [site, articles] = await Promise.all([getSiteSettings(), getArticles()]);
const leadArticle = articles[0];
const archiveArticles = articles.slice(1);
const leadAuthorLine = leadArticle?.authors.map((author) => author.name).filter(Boolean).join(' · ') ?? '';
---

<BaseLayout site={site} title="Rebase 文章" description="浏览 Rebase 社区发布的文章、复盘与方法总结。">
  <section class:list={['shell', 'page-hero', 'article-hero-layout', !leadArticle && 'single']}>
    <article class="hero-panel card articles-hero">
      <h1 class="hero-title">Rebase 文章</h1>
      <p class="hero-summary">把社区里的判断、复盘和方法整理成可以继续阅读、继续引用的长内容。</p>
      <div class="button-row article-hero-actions">
        <span class="button-link secondary is-disabled" aria-disabled="true" title="推荐文章入口即将开放">推荐文章</span>
        <a class="button-link" href="/articles/rss.xml">订阅 RSS <span>↗</span></a>
      </div>
    </article>

    {leadArticle && (
      <article class="card article-spotlight">
        <div class="article-spotlight-topline">
          <p class="article-spotlight-kicker">最新文章</p>
          <span>{formatDate(leadArticle.publishedAt)}</span>
        </div>
        <a class="article-spotlight-cover" href={getArticlePath(leadArticle.slug)} aria-label={leadArticle.title}>
          <img src={leadArticle.coverImageUrl ?? DEFAULT_ARTICLE_COVER_PATH} alt="" loading="lazy" />
        </a>
        <div class="article-spotlight-body">
          <p class="article-spotlight-meta">{leadArticle.readingTime}{leadAuthorLine ? ` · ${leadAuthorLine}` : ''}</p>
          <h2>
            <a href={getArticlePath(leadArticle.slug)}>{leadArticle.title}</a>
          </h2>
        </div>
      </article>
    )}
  </section>

  <section id="article-archive" class="shell page-section">
    <SectionHeader title="全部文章" />
    {(leadArticle ? archiveArticles : articles).length > 0 ? (
      <div class="grid-3">
        {(leadArticle ? archiveArticles : articles).map((article) => <ArticleCard article={article} compact />)}
      </div>
    ) : (
      <ListEmptyState
        kicker="持续更新"
        title="更多文章正在整理中。"
        description="当前先保留主稿入口，后续会继续把新的复盘、判断和方法写作补进这份归档里。"
      />
    )}
  </section>
</BaseLayout>

<style>
  :global(.articles-hero) {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(243, 196, 110, 0.28), transparent 30%),
      radial-gradient(circle at 92% 18%, rgba(15, 118, 110, 0.14), transparent 22%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 251, 244, 0.92));
  }

  :global(.articles-hero::before) {
    content: 'WRITING';
    position: absolute;
    top: 1rem;
    right: 1.3rem;
    color: rgba(17, 94, 89, 0.08);
    font-family: var(--display-font);
    font-size: clamp(3.8rem, 8vw, 6.6rem);
    letter-spacing: 0.08em;
    line-height: 0.82;
    pointer-events: none;
  }

  :global(.articles-hero .hero-title) {
    max-width: 8ch;
    text-wrap: balance;
  }

  :global(.articles-hero) {
    padding: 1.3rem 1.6rem 1.55rem;
  }

  .article-hero-layout {
    align-items: stretch;
  }

  .article-hero-layout.single {
    grid-template-columns: 1fr;
  }

  .articles-hero .hero-topline {
    justify-content: flex-end;
  }

  .article-hero-actions {
    flex-wrap: wrap;
  }

  .article-hero-actions .is-disabled {
    border-color: rgba(15, 118, 110, 0.12);
    background: rgba(255, 255, 255, 0.58);
    color: rgba(17, 94, 89, 0.72);
    box-shadow: none;
    cursor: default;
  }

  .article-spotlight {
    display: grid;
    grid-template-rows: auto auto 1fr;
    gap: 0.9rem;
    padding: 1.2rem;
    background:
      radial-gradient(circle at top right, rgba(243, 196, 110, 0.16), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 251, 250, 0.94));
    border-color: rgba(15, 118, 110, 0.12);
    box-shadow: 0 24px 48px rgba(26, 40, 34, 0.1);
  }

  .article-spotlight-topline,
  .article-spotlight-body {
    display: grid;
    gap: 0.55rem;
  }

  .article-spotlight-topline {
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.8rem;
  }

  .article-spotlight-kicker,
  .article-spotlight-topline span,
  .article-spotlight-meta,
  .article-spotlight-body h2 {
    margin: 0;
  }

  .article-spotlight-kicker,
  .article-spotlight-topline span,
  .article-spotlight-meta {
    font-size: 0.76rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .article-spotlight-kicker,
  .article-spotlight-meta {
    color: var(--accent-strong);
    font-weight: 800;
  }

  .article-spotlight-topline span {
    color: var(--muted);
    font-weight: 700;
  }

  .article-spotlight-cover {
    display: block;
    overflow: hidden;
    border-radius: 1rem;
    aspect-ratio: 5 / 3;
    background: rgba(15, 118, 110, 0.08);
  }

  .article-spotlight-cover img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 240ms ease;
  }

  .article-spotlight:hover .article-spotlight-cover img,
  .article-spotlight:focus-within .article-spotlight-cover img {
    transform: scale(1.03);
  }


  .article-spotlight-body h2 {
    font-size: clamp(1.45rem, 2vw, 2rem);
    line-height: 1.04;
  }

  .article-spotlight-body h2 a {
    transition: color 160ms ease;
  }

  .article-spotlight:hover h2 a,
  .article-spotlight:focus-within h2 a {
    color: var(--accent-strong);
  }

  @media (max-width: 960px) {
    .article-spotlight-topline {
      grid-template-columns: 1fr;
    }
  }
</style>
