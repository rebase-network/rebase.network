---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DetailHero from '@/components/DetailHero.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import { getArticleByPublicNumber, getArticles, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';
import { getArticlePath, getArticlePublicNumberFromRouteParam } from '@/lib/paths';
import { DEFAULT_ARTICLE_COVER_PATH } from '@/lib/placeholders';

const routeParam = Astro.params.slug ?? '';
const articlePublicNumber = getArticlePublicNumberFromRouteParam(routeParam);
const [site, article, articles] = await Promise.all([getSiteSettings(), getArticleByPublicNumber(articlePublicNumber), getArticles()]);
const related = article ? articles.filter((item) => item.publicNumber !== article.publicNumber).slice(0, 3) : [];
const articleAuthors = article?.authors.map((author) => author.name).join(' · ') ?? '';
const articleHeroMeta = article ? [formatDate(article.publishedAt), article.readingTime, articleAuthors].filter(Boolean) : [];
const articleHeroActions = [
  { href: '/articles/rss.xml', label: '订阅文章 RSS', showIcon: false, secondary: true },
];

if (!article) {
  Astro.response.status = 404;
}
---

<BaseLayout
  site={site}
  title={article ? article.title : '文章未找到'}
  description={article ? article.summary : '你访问的文章暂时无法找到。'}
  socialImage={article?.coverImageUrl ?? DEFAULT_ARTICLE_COVER_PATH}
  noindex={!article}
>
  {article ? (
    <>
      <section class="shell page-hero single">
        <DetailHero
          titleAside="Longform Dispatch"
          title={article.title}
          summary={article.summary}
          meta={articleHeroMeta}
          actions={articleHeroActions}
          hideTopline={true}
          inlineMetaActions={true}
          heroClass="article-hero"
          heroStyle={`--article-accent:${article.coverAccent};`}
        />
      </section>

      <section class="shell page-section detail-shell">
        <article id="article-body" class="card detail-body-card article-detail">
          <MarkdownContent content={article.body} />
        </article>

        <aside class="card detail-sidebar">
          {article.tags.length > 0 && (
            <section id="article-topics" class="detail-sidebar-section">
              <h2>文章标签</h2>
              <ul class="detail-tag-list">
                {article.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            </section>
          )}

          <section id="article-actions" class="detail-sidebar-section">
            <h2>继续阅读</h2>
            <ul class="detail-sidebar-list">
              <li><a href="/articles/rss.xml">订阅文章 RSS</a></li>
              <li><a href="/articles">返回文章列表</a></li>
            </ul>
          </section>

          {related.length > 0 && (
            <section id="article-related" class="detail-sidebar-section">
              <h2>延伸阅读</h2>
              <ul class="related-list">
                {related.map((item) => (
                  <li><a href={getArticlePath(item.publicNumber, item.slug)}>{item.title}</a></li>
                ))}
              </ul>
            </section>
          )}
        </aside>
      </section>
    </>
  ) : (
    <section class="shell page-hero single">
      <article class="hero-panel card">
        <p class="hero-kicker">404</p>
        <h1 class="hero-title">这篇文章暂时没有被找到。</h1>
        <p class="hero-summary">你可以先回到文章列表，继续浏览 Rebase 已发布的内容。</p>
      </article>
    </section>
  )}
</BaseLayout>

<style>
  .single {
    grid-template-columns: 1fr;
  }

  :global(.article-hero) {
    padding: 1.05rem 1.2rem 0.92rem;
    background:
      radial-gradient(circle at top right, rgba(243, 196, 110, 0.14), transparent 24%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(248, 252, 250, 0.9)),
      var(--article-accent);
    border-color: rgba(15, 118, 110, 0.12);
    box-shadow: var(--shadow-soft);
  }

  :global(.article-hero .light) {
    color: var(--text);
  }

  :global(.article-hero .detail-topline) {
    gap: 0.45rem 0.9rem;
  }

  :global(.article-hero .detail-context) {
    gap: 0.3rem;
  }

  :global(.article-hero .hero-kicker) {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
  }

  :global(.article-hero .detail-breadcrumbs a),
  :global(.article-hero .detail-breadcrumbs span) {
    font-size: 0.76rem;
  }

  :global(.article-hero .detail-edition) {
    padding: 0;
    border: none;
    background: transparent;
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    color: var(--accent-strong);
    opacity: 0.72;
  }

  :global(.article-hero .hero-title) {
    max-width: 13ch;
    margin-top: 0;
    font-size: clamp(2rem, 3.55vw, 3.35rem);
    line-height: 1;
  }

  :global(.article-hero .detail-title-row) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  :global(.article-hero .detail-title-aside) {
    flex-shrink: 0;
    padding-top: 0.24rem;
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-strong);
    opacity: 0.72;
  }

  :global(.article-hero .hero-summary) {
    max-width: 56ch;
    margin-top: 0.58rem;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.58;
  }

  :global(.article-hero .detail-footer-row) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.62rem;
  }

  :global(.article-hero .detail-meta-strip) {
    gap: 0.5rem;
    margin-top: 0;
  }

  :global(.article-hero .detail-meta-pill) {
    position: relative;
    padding: 0;
    border: none;
    border-radius: 0;
    background: transparent;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    color: var(--muted);
    opacity: 1;
  }

  :global(.article-hero .detail-meta-pill:not(:last-child)::after) {
    content: '·';
    margin-left: 0.5rem;
    opacity: 0.45;
  }

  :global(.article-hero .button-row) {
    justify-content: flex-end;
    margin-top: 0;
  }

  :global(.article-hero .button-link.secondary) {
    padding: 0.34rem 0.7rem;
    border-color: rgba(15, 118, 110, 0.14);
    background: rgba(255, 255, 255, 0.58);
    font-size: 0.69rem;
    letter-spacing: 0.06em;
  }

  @media (max-width: 780px) {
    :global(.article-hero .detail-title-row),
    :global(.article-hero .detail-footer-row) {
      flex-direction: column;
      align-items: flex-start;
    }

    :global(.article-hero .detail-title-aside) {
      padding-top: 0;
    }
  }

  .article-detail :global(.markdown > h1:first-child) {
    display: none;
  }
</style>
