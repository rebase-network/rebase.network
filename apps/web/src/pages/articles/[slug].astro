---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DetailHero from '@/components/DetailHero.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import { getArticleBySlug, getArticles, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';
import { getArticlePath } from '@/lib/paths';

const slug = Astro.params.slug ?? '';
const [site, article, articles] = await Promise.all([getSiteSettings(), getArticleBySlug(slug), getArticles()]);
const related = article ? articles.filter((item) => item.slug !== article.slug).slice(0, 2) : [];
const articleAuthors = article?.authors.map((author) => author.name).join(' · ') ?? '';
const articleBreadcrumbs = article
  ? [
      { href: '/', label: '首页' },
      { href: '/articles', label: '文章' },
      { label: article.title, current: true },
    ]
  : [];
const articleHeroMeta = article ? [formatDate(article.publishedAt), article.readingTime, articleAuthors].filter(Boolean) : [];
const articleHeroActions = [
  { href: '/articles', label: '回到文章列表', secondary: true },
];

if (!article) {
  Astro.response.status = 404;
}
---

<BaseLayout
  site={site}
  title={article ? article.title : '文章未找到'}
  description={article ? article.summary : '你访问的文章暂时无法找到。'}
  socialImage={article?.coverImageUrl}
  noindex={!article}
>
  {article ? (
    <>
      <section class="shell page-hero single">
        <DetailHero
          kicker="文章"
          breadcrumbs={articleBreadcrumbs}
          edition="Longform"
          title={article.title}
          summary={article.summary}
          meta={articleHeroMeta}
          actions={articleHeroActions}
          heroClass="article-hero"
          heroStyle={`--article-accent:${article.coverAccent};`}
        />
      </section>

      <section class="shell page-section article-detail-shell">
        <article id="article-body" class="card detail-body-card article-detail">
          {(articleAuthors || article.tags.length > 0) && (
            <header class="article-reading-header">
              {articleAuthors && <p class="article-reading-meta">{articleAuthors}</p>}
              {article.tags.length > 0 && (
                <ul class="article-reading-tags">
                  {article.tags.map((tag) => <li>{tag}</li>)}
                </ul>
              )}
            </header>
          )}
          <MarkdownContent content={article.body} />
        </article>
      </section>

      <section class="shell page-section article-followup-shell">
        <div class="article-followup-grid">
          <article class="card article-followup-card">
            <p class="followup-kicker">订阅与归档</p>
            <h2>继续追踪 Rebase 写作</h2>
            <p>如果你是从搜索、分享或 RSS 进入，读完这篇后可以继续回到文章归档。</p>
            <div class="followup-link-list">
              <a href="/articles/rss.xml">订阅文章 RSS</a>
              <a href="/articles">返回文章列表</a>
            </div>
          </article>

          {related.length > 0 && (
            <article class="card article-followup-card">
              <p class="followup-kicker">延伸阅读</p>
              <h2>继续读这两篇</h2>
              <div class="followup-link-list">
                {related.map((item) => (
                  <a href={getArticlePath(item.slug)}>{item.title}</a>
                ))}
              </div>
            </article>
          )}
        </div>
      </section>
    </>
  ) : (
    <section class="shell page-hero single">
      <article class="hero-panel card">
        <p class="hero-kicker">404</p>
        <h1 class="hero-title">这篇文章暂时没有被找到。</h1>
        <p class="hero-summary">你可以先回到文章列表，继续浏览 Rebase 已发布的内容。</p>
      </article>
    </section>
  )}
</BaseLayout>

<style>
  .single {
    grid-template-columns: 1fr;
  }

  .article-hero {
    color: white;
    background:
      linear-gradient(135deg, rgba(12, 23, 22, 0.72), rgba(12, 23, 22, 0.3)),
      var(--article-accent);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 28px 60px rgba(23, 32, 29, 0.22);
  }

  .light {
    color: white;
  }

  .article-detail-shell {
    grid-template-columns: 1fr;
  }

  .article-reading-header {
    display: grid;
    gap: 0.9rem;
    margin-bottom: 1.15rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }

  .article-reading-meta {
    margin: 0;
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .article-reading-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .article-reading-tags li {
    padding: 0.42rem 0.72rem;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.08);
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .article-followup-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .article-followup-card {
    display: grid;
    gap: 0.8rem;
    padding: 1.3rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(249, 252, 250, 0.92));
  }

  .followup-kicker,
  .article-followup-card h2,
  .article-followup-card p {
    margin: 0;
  }

  .followup-kicker {
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .article-followup-card h2 {
    font-size: clamp(1.45rem, 2vw, 2rem);
    line-height: 1.06;
  }

  .article-followup-card p {
    color: var(--muted);
    line-height: 1.75;
  }

  .followup-link-list {
    display: grid;
    gap: 0.75rem;
  }

  .followup-link-list a {
    display: block;
    padding: 0.88rem 1rem;
    border: 1px solid rgba(15, 118, 110, 0.12);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.74);
    color: var(--accent-strong);
    font-weight: 700;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .followup-link-list a:hover,
  .followup-link-list a:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(15, 118, 110, 0.24);
    box-shadow: 0 14px 28px rgba(15, 118, 110, 0.1);
  }

  @media (max-width: 960px) {
    .article-followup-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
