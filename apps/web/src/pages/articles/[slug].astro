---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DetailHero from '@/components/DetailHero.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import { getArticleBySlug, getArticles, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';
import { getArticlePath } from '@/lib/paths';
import { DEFAULT_ARTICLE_COVER_PATH } from '@/lib/placeholders';

const slug = Astro.params.slug ?? '';
const [site, article, articles] = await Promise.all([getSiteSettings(), getArticleBySlug(slug), getArticles()]);
const related = article ? articles.filter((item) => item.slug !== article.slug).slice(0, 2) : [];
const articleJumpTarget = related.length > 0 ? '#article-related' : '#article-actions';
const articleAuthors = article?.authors.map((author) => author.name).join(' · ') ?? '';
const articleBreadcrumbs = article
  ? [
      { href: '/', label: '首页' },
      { href: '/articles', label: '文章' },
      { label: article.title, current: true },
    ]
  : [];
const articleHeroMeta = article ? [formatDate(article.publishedAt), article.readingTime, articleAuthors].filter(Boolean) : [];
const articleHeroActions = [
  { href: '/articles/rss.xml', label: '订阅文章 RSS', showIcon: false, secondary: true },
];

if (!article) {
  Astro.response.status = 404;
}
---

<BaseLayout
  site={site}
  title={article ? article.title : '文章未找到'}
  description={article ? article.summary : '你访问的文章暂时无法找到。'}
  socialImage={article?.coverImageUrl ?? DEFAULT_ARTICLE_COVER_PATH}
  noindex={!article}
>
  {article ? (
    <>
      <section class="shell page-hero single">
        <DetailHero
          kicker="文章"
          breadcrumbs={articleBreadcrumbs}
          edition="Longform Dispatch"
          title={article.title}
          summary={article.summary}
          meta={articleHeroMeta}
          actions={articleHeroActions}
          heroClass="article-hero"
          heroStyle={`--article-accent:${article.coverAccent};`}
        />
      </section>

      <section class="shell page-section detail-shell">
        <article id="article-body" class="card detail-body-card article-detail">
          <div class="detail-body-lead article-meta">
            <p>{formatDate(article.publishedAt)} · {article.readingTime}</p>
            <p>{articleAuthors}</p>
          </div>
          <MarkdownContent content={article.body} />
        </article>

        <aside class="card detail-sidebar">
          <section class="detail-sidebar-section">
            <h2>页面导览</h2>
            <p class="detail-sidebar-copy">如果你是从搜索、分享或 RSS 进入，可以先用这几个锚点快速定位。</p>
            <ul class="detail-sidebar-list">
              <li><a href="#article-body">进入正文</a></li>
              <li><a href="#article-info">查看文章信息</a></li>
              <li><a href={articleJumpTarget}>继续阅读</a></li>
            </ul>
          </section>

          <section id="article-info" class="detail-sidebar-section">
            <h2>文章信息</h2>
            <ul class="detail-fact-list">
              <li>
                <strong>发布时间</strong>
                <span>{formatDate(article.publishedAt)}</span>
              </li>
              <li>
                <strong>作者</strong>
                <span>{articleAuthors}</span>
              </li>
              <li>
                <strong>阅读时长</strong>
                <span>{article.readingTime}</span>
              </li>
            </ul>
            {article.tags.length > 0 && (
              <ul class="detail-tag-list">
                {article.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            )}
          </section>

          <section id="article-actions" class="detail-sidebar-section">
            <h2>继续阅读</h2>
            <p class="detail-sidebar-copy">除了当前正文，还保留订阅入口和完整归档，方便后续继续追踪。</p>
            <ul class="detail-sidebar-list">
              <li><a href="/articles/rss.xml">订阅文章 RSS</a></li>
              <li><a href="/articles">返回文章列表</a></li>
            </ul>
          </section>

          {related.length > 0 && (
            <section id="article-related" class="detail-sidebar-section">
              <h2>延伸阅读</h2>
              <ul class="related-list">
                {related.map((item) => (
                  <li><a href={getArticlePath(item.slug)}>{item.title}</a></li>
                ))}
              </ul>
            </section>
          )}
        </aside>
      </section>
    </>
  ) : (
    <section class="shell page-hero single">
      <article class="hero-panel card">
        <p class="hero-kicker">404</p>
        <h1 class="hero-title">这篇文章暂时没有被找到。</h1>
        <p class="hero-summary">你可以先回到文章列表，继续浏览 Rebase 已发布的内容。</p>
      </article>
    </section>
  )}
</BaseLayout>

<style>
  .single {
    grid-template-columns: 1fr;
  }

  :global(.article-hero) {
    color: white;
    padding: 1.2rem 1.3rem 1rem;
    background:
      linear-gradient(135deg, rgba(12, 23, 22, 0.72), rgba(12, 23, 22, 0.3)),
      var(--article-accent);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 28px 60px rgba(23, 32, 29, 0.22);
  }

  :global(.article-hero .light) {
    color: white;
  }

  :global(.article-hero .detail-topline) {
    gap: 0.45rem 0.9rem;
  }

  :global(.article-hero .detail-context) {
    gap: 0.3rem;
  }

  :global(.article-hero .hero-kicker) {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
  }

  :global(.article-hero .detail-breadcrumbs a),
  :global(.article-hero .detail-breadcrumbs span) {
    font-size: 0.76rem;
  }

  :global(.article-hero .detail-edition) {
    padding: 0;
    border: none;
    background: transparent;
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    opacity: 0.58;
  }

  :global(.article-hero .hero-title) {
    max-width: 10ch;
    margin-top: 0.2rem;
    font-size: clamp(2.45rem, 4.8vw, 4.2rem);
    line-height: 0.92;
  }

  :global(.article-hero .hero-summary) {
    max-width: 56ch;
    margin-top: 0.72rem;
    font-size: 0.98rem;
    line-height: 1.65;
  }

  :global(.article-hero .detail-meta-strip) {
    gap: 0.5rem;
    margin-top: 0.8rem;
  }

  :global(.article-hero .detail-meta-pill) {
    position: relative;
    padding: 0;
    border: none;
    border-radius: 0;
    background: transparent;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    opacity: 0.92;
  }

  :global(.article-hero .detail-meta-pill:not(:last-child)::after) {
    content: '·';
    margin-left: 0.5rem;
    opacity: 0.45;
  }

  :global(.article-hero .button-row) {
    justify-content: flex-end;
    margin-top: 0.55rem;
  }

  :global(.article-hero .button-link.secondary) {
    padding: 0.42rem 0.78rem;
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.06);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .article-detail :global(.markdown > h1:first-child) {
    display: none;
  }
</style>
