---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import { getArticleBySlug, getArticles, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';
import { getArticlePath } from '@/lib/paths';
import type { Article } from '@rebase/types';

export async function getStaticPaths() {
  const articles = await getArticles();
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: {
      article,
      related: articles.filter((item) => item.slug !== article.slug).slice(0, 2),
    },
  }));
}

const slug = Astro.params.slug ?? '';
const site = await getSiteSettings();
const article = (Astro.props.article as Article | undefined) ?? (await getArticleBySlug(slug));
const related = (Astro.props.related as Article[] | undefined) ?? [];
const articleAuthors = article?.authors.map((author) => author.name).join(' · ') ?? '';
const articleContextNote = article
  ? article.tags.length > 0
    ? `关键词：${article.tags.join(' · ')}`
    : '把社区里的方法、复盘和判断整理成可以反复回看的长内容。'
  : '';

if (!article) {
  Astro.response.status = 404;
}
---

<BaseLayout
  site={site}
  title={article ? article.title : '文章未找到'}
  description={article ? article.summary : '你访问的文章暂时无法找到。'}
  socialImage={article?.coverImageUrl}
  noindex={!article}
>
  {article ? (
    <>
      <section class="shell page-hero single">
        <article class="hero-panel card detail-hero article-hero" style={`--article-accent:${article.coverAccent};`}>
          <div class="detail-topline">
            <div class="detail-context">
              <p class="hero-kicker light">文章详情</p>
              <nav class="detail-breadcrumbs light" aria-label="Breadcrumb">
                <a href="/">首页</a>
                <span aria-hidden="true">/</span>
                <a href="/articles">文章</a>
                <span aria-hidden="true">/</span>
                <span aria-current="page">{article.title}</span>
              </nav>
            </div>
            <span class="detail-edition">Longform Dispatch</span>
          </div>
          <h1 class="hero-title light">{article.title}</h1>
          <p class="hero-summary light">{article.summary}</p>
          <div class="detail-meta-strip">
            <span class="detail-meta-pill">{formatDate(article.publishedAt)}</span>
            <span class="detail-meta-pill">{article.readingTime}</span>
            <span class="detail-meta-pill">{articleAuthors}</span>
          </div>
          <p class="detail-hero-note light">{articleContextNote}</p>
          <div class="button-row">
            <a class="button-link" href="/articles/rss.xml">订阅文章 RSS <span>↗</span></a>
            <a class="button-link secondary" href="/articles">回到文章列表</a>
          </div>
          <div class="detail-jump-list">
            <a href="#article-body">进入正文</a>
            <a href="#article-info">文章信息</a>
            <a href={related.length > 0 ? '#article-related' : '#article-actions'}>继续阅读</a>
          </div>
        </article>
      </section>

      <section class="shell page-section detail-shell">
        <article id="article-body" class="card detail-body-card article-detail">
          <div class="detail-body-lead article-meta">
            <p>{formatDate(article.publishedAt)} · {article.readingTime}</p>
            <p>{articleAuthors}</p>
          </div>
          <MarkdownContent content={article.body} />
        </article>

        <aside class="card detail-sidebar">
          <section class="detail-sidebar-section">
            <h2>页面导览</h2>
            <p class="detail-sidebar-copy">如果你是从搜索、分享或 RSS 进入，可以先用这几个锚点快速定位。</p>
            <ul class="detail-sidebar-list">
              <li><a href="#article-body">进入正文</a></li>
              <li><a href="#article-info">查看文章信息</a></li>
              <li><a href={related.length > 0 ? '#article-related' : '#article-actions'}>继续阅读</a></li>
            </ul>
          </section>

          <section id="article-info" class="detail-sidebar-section">
            <h2>文章信息</h2>
            <ul class="detail-fact-list">
              <li>
                <strong>发布时间</strong>
                <span>{formatDate(article.publishedAt)}</span>
              </li>
              <li>
                <strong>作者</strong>
                <span>{articleAuthors}</span>
              </li>
              <li>
                <strong>阅读时长</strong>
                <span>{article.readingTime}</span>
              </li>
            </ul>
            {article.tags.length > 0 && (
              <ul class="detail-tag-list">
                {article.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            )}
          </section>

          <section id="article-actions" class="detail-sidebar-section">
            <h2>继续阅读</h2>
            <p class="detail-sidebar-copy">除了当前正文，还保留订阅入口和完整归档，方便后续继续追踪。</p>
            <ul class="detail-sidebar-list">
              <li><a href="/articles/rss.xml">订阅文章 RSS</a></li>
              <li><a href="/articles">返回文章列表</a></li>
            </ul>
          </section>

          {related.length > 0 && (
            <section id="article-related" class="detail-sidebar-section">
              <h2>延伸阅读</h2>
              <ul class="related-list">
                {related.map((item) => (
                  <li><a href={getArticlePath(item.slug)}>{item.title}</a></li>
                ))}
              </ul>
            </section>
          )}
        </aside>
      </section>
    </>
  ) : (
    <section class="shell page-hero single">
      <article class="hero-panel card">
        <p class="hero-kicker">404</p>
        <h1 class="hero-title">这篇文章暂时没有被找到。</h1>
        <p class="hero-summary">你可以先回到文章列表，继续浏览 Rebase 已发布的内容。</p>
      </article>
    </section>
  )}
</BaseLayout>

<style>
  .single {
    grid-template-columns: 1fr;
  }

  .article-hero {
    color: white;
    background:
      linear-gradient(135deg, rgba(12, 23, 22, 0.72), rgba(12, 23, 22, 0.3)),
      var(--article-accent);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 28px 60px rgba(23, 32, 29, 0.22);
  }

  .light {
    color: white;
  }
</style>
