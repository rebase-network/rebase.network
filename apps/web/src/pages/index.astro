---
import ArticleCard from '@/components/ArticleCard.astro';
import EventCard from '@/components/EventCard.astro';
import GeekDailyCard from '@/components/GeekDailyCard.astro';
import JobCard from '@/components/JobCard.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { createAvatarData } from '@/lib/avatar';
import { getHomeFeed, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';

const [site, feed] = await Promise.all([getSiteSettings(), getHomeFeed()]);
const contributorPreviewLimit = 10;
const contributorPreview = feed.featuredContributors.slice(0, contributorPreviewLimit);
const liveWire = feed.dynamicFeed.slice(0, 6);
const recentGeekDaily = feed.recentGeekDaily.slice(0, 3);
const frontPageHighlights = liveWire.slice(0, 3);

const liveWireTypeLabel = {
  article: '文章',
  job: '招聘',
  event: '活动',
  geekdaily: 'GeekDaily',
} as const;
---

<BaseLayout site={site} title="Rebase 社区首页" description={site.description}>
  <section class="shell page-hero home-hero">
    <article class="hero-panel card masthead-panel">
      <div class="hero-topline">
        <p class="hero-kicker">面向建设者的社区媒体</p>
        <span class="edition-chip">Rebase Front Page</span>
      </div>
      <h1 class="hero-title">{site.heroTitle}</h1>
      <p class="hero-summary">{site.heroSummary}</p>
      <p class="brand-note">这是一个由中国开发者用热爱和业余时间共同维护的非营利、公益性开发者社区。</p>
      <div class="button-row">
        <a class="button-link" href={site.heroPrimaryCtaUrl}>{site.heroPrimaryCtaLabel} <span>↗</span></a>
        <a class="button-link secondary" href={site.heroSecondaryCtaUrl}>{site.heroSecondaryCtaLabel} <span>↗</span></a>
      </div>
      <div class="hero-highlights">
        {frontPageHighlights.map((item, index) => (
          <a class="highlight-card" href={item.href}>
            <span>0{index + 1} · {liveWireTypeLabel[item.type]}</span>
            <strong>{item.title}</strong>
            <p>{item.summary}</p>
          </a>
        ))}
      </div>
    </article>

    <aside class="signal-panel card live-desk">
      <SectionHeader
        eyebrow="社区实时线"
        title="正在发生什么"
        description="用一条实时更新的社区新闻线，把文章、活动、GeekDaily 和招聘放在同一个阅读入口里。"
      />
      <ol class="live-wire-list">
        {liveWire.map((item) => (
          <li class="live-wire-item">
            <a href={item.href}>
              <div class="live-wire-meta">
                <span>{liveWireTypeLabel[item.type]}</span>
                <time>{item.publishedAt ? formatDate(item.publishedAt) : '刚刚更新'}</time>
              </div>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
            </a>
          </li>
        ))}
      </ol>
    </aside>
  </section>

  <section class="shell meta-strip page-section">
    {site.homeStats.map((stat) => (
      <article class="card">
        <strong>{stat.value}</strong>
        <span>{stat.label}</span>
      </article>
    ))}
  </section>

  <section class="shell page-section current-desk">
    <SectionHeader
      eyebrow="首页编排"
      title="今天进入 Rebase 最值得先看的内容"
      description="首屏之下不是简单分栏，而是一份社区首页编辑台：主稿、日报、活动和招聘同时在线。"
    />
    <div class="dispatch-grid">
      {feed.latestArticles[0] && <ArticleCard article={feed.latestArticles[0]} featured />}
      <div class="dispatch-stack">
        {feed.latestGeekDaily && <GeekDailyCard episode={feed.latestGeekDaily} />}
        {feed.latestJobs[0] && <JobCard job={feed.latestJobs[0]} />}
        {feed.latestEvents[0] && <EventCard event={feed.latestEvents[0]} />}
      </div>
    </div>
  </section>

  <section class="shell page-section">
    <SectionHeader
      eyebrow="近期 GeekDaily"
      title="近期 GeekDaily"
      description="日报是 Rebase 最稳定的社区更新机制，也是搜索与 RSS 最常被消费的入口。"
      href="/geekdaily"
      hrefLabel="进入 GeekDaily"
    />
    <div class="grid-3">
      {recentGeekDaily.map((episode) => (
        <GeekDailyCard episode={episode} />
      ))}
    </div>
  </section>

  <section class="shell page-section">
    <SectionHeader
      eyebrow="最新文章"
      title="近期文章"
      description="从产品、社区到信息架构，公开记录 Rebase 的想法与方法。"
      href="/articles"
      hrefLabel="浏览全部文章"
    />
    <div class="grid-3">
      {feed.latestArticles.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>
  </section>

  <section class="shell page-section dual-column">
    <SectionHeader
      eyebrow="社区招聘"
      title="新增招聘信息"
      description="帮助读者快速理解岗位背景、工作模式和联系方式。"
      href="/who-is-hiring"
      hrefLabel="进入招聘板"
    />
    <div class="grid-3">
      {feed.latestJobs.map((job) => (
        <JobCard job={job} />
      ))}
    </div>
  </section>

  <section class="shell page-section">
    <SectionHeader
      eyebrow="社区活动"
      title="社区活动"
      description="第一版先聚焦活动展示与外部报名入口，后续再扩展更复杂的活动能力。"
      href="/events"
      hrefLabel="查看活动"
    />
    <div class="grid-3">
      {feed.latestEvents.map((event) => (
        <EventCard event={event} />
      ))}
    </div>
  </section>

  <section class="shell page-section">
    <SectionHeader
      eyebrow="社区共建者"
      title="由更多真实的人，一起把社区持续往前推"
      href="/contributors"
      hrefLabel="查看全部贡献者"
    />
    <article class="card contributors-overview">
      <div class="contributors-copy">
        <p class="contributors-kicker">社区照片墙</p>
        <div class="contributors-intro">
          <h3>先看见真实的人，再进入完整的贡献者档案。</h3>
          <p>
            Rebase 由志愿者、编辑与长期协作者共同维护。这里先展示一组持续变化的公开面孔，让社区的气质先被看见。
          </p>
        </div>

        <p class="contributors-note">
          内容整理、活动组织、推荐协作与长期共建，都会慢慢沉淀成可被看见的记录。
        </p>
      </div>

      <div class="contributors-cloud" aria-hidden="true">
        {contributorPreview.map((contributor) => (
          <div class="avatar-token" title={contributor.name}>
            {contributor.avatarUrl ? (
              <img src={contributor.avatarUrl} alt="" loading="lazy" />
            ) : (
              <div class="avatar-fallback" style={`background:${createAvatarData(contributor.avatarSeed)}`}>
                <span>{contributor.name.slice(0, 1)}</span>
              </div>
            )}
          </div>
        ))}
      </div>
    </article>
  </section>

  <section class="shell page-section">
    <article class="card feed-callout">
      <div>
        <p class="hero-kicker">订阅入口</p>
        <h2>如果你习惯用 RSS 追踪社区内容，Rebase 从第一版开始就把 feed 当成标准输出。</h2>
      </div>
      <div class="feed-links">
        <a href="/rss.xml">全站 RSS</a>
        <a href="/geekdaily/rss.xml">GeekDaily RSS</a>
        <a href="/articles/rss.xml">文章 RSS</a>
        <a href="/events/rss.xml">活动 RSS</a>
        <a href="/who-is-hiring/rss.xml">招聘 RSS</a>
      </div>
    </article>
  </section>
</BaseLayout>

<style>
  .home-hero {
    align-items: stretch;
  }

  .masthead-panel {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(243, 196, 110, 0.32), transparent 34%),
      radial-gradient(circle at 92% 18%, rgba(15, 118, 110, 0.16), transparent 22%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 251, 244, 0.92));
    border-color: rgba(15, 118, 110, 0.14);
    box-shadow: 0 26px 60px rgba(26, 40, 34, 0.12);
  }

  .masthead-panel::before {
    content: 'REBASE';
    position: absolute;
    top: 1.2rem;
    right: 1.45rem;
    color: rgba(17, 94, 89, 0.08);
    font-family: var(--display-font);
    font-size: clamp(4.4rem, 8vw, 7rem);
    letter-spacing: 0.08em;
    line-height: 0.82;
    pointer-events: none;
  }

  .masthead-panel::after {
    content: '';
    position: absolute;
    inset: auto -8rem -8rem auto;
    width: 16rem;
    height: 16rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(17, 94, 89, 0.18), transparent 68%);
    pointer-events: none;
  }

  .hero-topline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .edition-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.48rem 0.8rem;
    border: 1px solid rgba(15, 118, 110, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.7);
    color: var(--accent-strong);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .masthead-panel .hero-title {
    max-width: 11ch;
    text-wrap: balance;
  }

  .brand-note {
    margin: 1rem 0 0;
    max-width: 46ch;
    color: rgba(17, 94, 89, 0.84);
    font-size: 0.96rem;
    line-height: 1.75;
  }

  .hero-highlights {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    margin-top: 1.35rem;
  }

  .highlight-card {
    position: relative;
    display: grid;
    gap: 0.45rem;
    padding: 1rem;
    border: 1px solid rgba(15, 118, 110, 0.12);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.76);
    box-shadow: 0 12px 24px rgba(15, 118, 110, 0.06);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .highlight-card:hover,
  .highlight-card:focus-visible {
    transform: translateY(-3px);
    border-color: rgba(15, 118, 110, 0.24);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 18px 36px rgba(15, 118, 110, 0.1);
  }

  .highlight-card span,
  .highlight-card strong,
  .highlight-card p {
    margin: 0;
  }

  .highlight-card span {
    color: var(--accent-strong);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .highlight-card strong {
    font-family: var(--display-font);
    font-size: 1.18rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .highlight-card p {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .live-desk {
    display: grid;
    gap: 1rem;
    background:
      radial-gradient(circle at top right, rgba(245, 158, 11, 0.18), transparent 24%),
      linear-gradient(180deg, rgba(16, 37, 34, 0.97), rgba(19, 54, 49, 0.94));
    border-color: rgba(15, 118, 110, 0.22);
    box-shadow: 0 26px 56px rgba(16, 37, 34, 0.24);
  }

  .live-desk :global(.section-header p),
  .live-desk :global(.section-header h2),
  .live-desk :global(.section-header span),
  .live-desk :global(.section-header a) {
    color: rgba(255, 255, 255, 0.9);
  }

  .live-desk :global(.section-header a) {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .live-desk :global(.section-header a:hover),
  .live-desk :global(.section-header a:focus-visible) {
    border-color: rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.12);
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.12);
  }

  .live-wire-list {
    display: grid;
    gap: 0.85rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .live-wire-item a {
    display: block;
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(223, 244, 238, 0.12);
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
  }

  .live-wire-item a:hover,
  .live-wire-item a:focus-visible {
    transform: translateY(-3px);
    border-color: rgba(243, 196, 110, 0.34);
    background: rgba(255, 255, 255, 0.14);
    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.14);
  }

  .live-wire-meta {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
  }

  .live-wire-meta span,
  .live-wire-meta time {
    color: rgba(223, 244, 238, 0.86);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .live-wire-meta time {
    color: rgba(223, 244, 238, 0.6);
  }

  .live-wire-item h3,
  .live-wire-item p {
    margin: 0;
  }

  .live-wire-item h3 {
    margin-top: 0.5rem;
    font-size: 1rem;
    line-height: 1.35;
    color: white;
  }

  .live-wire-item p {
    margin-top: 0.45rem;
    color: rgba(223, 244, 238, 0.72);
    line-height: 1.65;
  }

  .current-desk {
    padding-top: 1.9rem;
  }

  .dispatch-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(19rem, 0.9fr);
    gap: 1rem;
  }

  .dispatch-stack {
    display: grid;
    gap: 1rem;
  }

  .feed-callout {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 1rem;
    padding: 1.6rem;
    background:
      radial-gradient(circle at top right, rgba(245, 158, 11, 0.12), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(248, 253, 251, 0.9));
  }

  .feed-callout h2 {
    margin: 0;
    font-size: clamp(1.7rem, 2.5vw, 2.6rem);
    line-height: 1.08;
    max-width: 15ch;
  }

  .feed-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .feed-links a {
    display: block;
    padding: 1rem 1.1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.68);
    border: 1px solid rgba(31, 41, 51, 0.08);
    color: var(--accent-strong);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
  }

  .feed-links a:hover,
  .feed-links a:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(15, 118, 110, 0.18);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 14px 28px rgba(15, 118, 110, 0.1);
  }

  .contributors-overview {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(28rem, 1.18fr);
    gap: 1.4rem;
    align-items: center;
    padding: 1.3rem 1.35rem;
    background:
      radial-gradient(circle at top left, rgba(243, 196, 110, 0.22), transparent 26%),
      radial-gradient(circle at 82% 18%, rgba(15, 118, 110, 0.18), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(247, 252, 250, 0.93));
  }

  .contributors-overview::after {
    content: '';
    position: absolute;
    inset: auto -3rem -5rem auto;
    width: 12rem;
    height: 12rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(15, 118, 110, 0.12), transparent 70%);
    pointer-events: none;
  }

  .contributors-copy {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.9rem;
    max-width: 30rem;
  }

  .contributors-kicker,
  .contributors-intro h3,
  .contributors-intro p,
  .contributors-note {
    margin: 0;
  }

  .contributors-kicker {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.36rem 0.72rem;
    border: 1px solid rgba(15, 118, 110, 0.16);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
    color: rgba(15, 118, 110, 0.88);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .contributors-intro {
    display: grid;
    gap: 0.72rem;
  }

  .contributors-intro h3 {
    max-width: 12ch;
    color: var(--text);
    font-size: clamp(1.45rem, 1.8vw + 1rem, 2rem);
    line-height: 1.16;
    letter-spacing: -0.03em;
  }

  .contributors-intro p {
    max-width: 52ch;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.76;
  }

  .contributors-note {
    max-width: 46ch;
    padding-top: 0.88rem;
    border-top: 1px solid rgba(15, 118, 110, 0.1);
    color: rgba(62, 86, 76, 0.88);
    font-size: 0.92rem;
    line-height: 1.72;
  }

  .contributors-cloud {
    position: relative;
    isolation: isolate;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 5.2rem));
    gap: 1.15rem 0.95rem;
    align-items: start;
    justify-content: end;
    width: min(100%, 33rem);
    margin-left: auto;
    padding: 2.15rem 0.75rem 0.95rem 0.9rem;
  }

  .contributors-cloud::before {
    content: '';
    position: absolute;
    inset: 0.3rem 0.2rem 0.15rem;
    z-index: -2;
    border: 1px solid rgba(15, 118, 110, 0.1);
    border-radius: 1.35rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(247, 252, 250, 0.56)),
      radial-gradient(circle at 1px 1px, rgba(15, 118, 110, 0.06) 1px, transparent 0);
    background-size: auto, 18px 18px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.68), 0 18px 40px rgba(26, 40, 34, 0.08);
  }

  .contributors-cloud::after {
    content: '';
    position: absolute;
    top: 1rem;
    left: 50%;
    width: 5.2rem;
    height: 1.15rem;
    z-index: -1;
    border-radius: 0.45rem;
    background:
      linear-gradient(180deg, rgba(243, 196, 110, 0.6), rgba(243, 196, 110, 0.24));
    box-shadow: 0 8px 16px rgba(243, 196, 110, 0.14);
    opacity: 0.72;
    transform: translateX(-50%) rotate(-2deg);
  }

  .avatar-token {
    position: relative;
    justify-self: center;
    width: 5.05rem;
    padding: 0.3rem 0.3rem 0.78rem;
    border: 1px solid rgba(15, 118, 110, 0.1);
    border-radius: 0.7rem;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 18px 36px rgba(26, 40, 34, 0.12);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .avatar-token::before {
    content: '';
    position: absolute;
    top: 0.18rem;
    left: 50%;
    width: 42%;
    height: 0.5rem;
    border-radius: 0.3rem;
    background: linear-gradient(180deg, rgba(243, 196, 110, 0.55), rgba(243, 196, 110, 0.2));
    box-shadow: 0 6px 12px rgba(243, 196, 110, 0.16);
    opacity: 0.76;
    transform: translateX(-50%) rotate(-5deg);
  }

  .avatar-token img,
  .avatar-fallback {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 0.52rem;
  }

  .avatar-token:hover,
  .avatar-token:focus-visible {
    transform: translateY(-0.18rem) scale(1.02);
    border-color: rgba(15, 118, 110, 0.22);
    box-shadow: 0 18px 38px rgba(26, 40, 34, 0.14);
  }

  .avatar-fallback {
    display: grid;
    place-items: center;
    color: white;
    font-size: 1.35rem;
    font-weight: 800;
  }

  .avatar-token:nth-child(5n + 1) {
    transform: rotate(-5deg);
    justify-self: start;
  }

  .avatar-token:nth-child(5n + 2) {
    transform: rotate(4deg);
  }

  .avatar-token:nth-child(5n + 3) {
    transform: rotate(6deg);
    margin-top: 0.15rem;
  }

  .avatar-token:nth-child(5n + 4) {
    transform: rotate(-4deg);
  }

  .avatar-token:nth-child(5n) {
    transform: rotate(3deg);
    justify-self: end;
    margin-top: 0.25rem;
  }

  .avatar-token:nth-child(6),
  .avatar-token:nth-child(9) {
    margin-top: 0.45rem;
  }

  .avatar-token:nth-child(7),
  .avatar-token:nth-child(10) {
    margin-top: 0.3rem;
  }

  .avatar-token:nth-child(8) {
    margin-top: 0.1rem;
  }

  @media (max-width: 960px) {
    .hero-highlights,
    .dispatch-grid,
    .contributors-overview {
      grid-template-columns: 1fr;
    }

    .feed-callout {
      grid-template-columns: 1fr;
    }

    .feed-links {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .hero-topline {
      align-items: flex-start;
      flex-direction: column;
    }

    .highlight-card strong {
      font-size: 1.08rem;
    }

    .feed-links {
      grid-template-columns: 1fr;
    }

    .contributors-cloud {
      grid-template-columns: repeat(3, minmax(0, 5rem));
      gap: 0.85rem;
