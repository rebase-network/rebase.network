---
import ArticleCard from '@/components/ArticleCard.astro';
import EventCard from '@/components/EventCard.astro';
import GeekDailyCard from '@/components/GeekDailyCard.astro';
import JobCard from '@/components/JobCard.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { createAvatarData } from '@/lib/avatar';
import { getHomeFeed, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';

const [site, feed] = await Promise.all([getSiteSettings(), getHomeFeed()]);
const contributorPreviewLimit = 10;
const contributorPreview = feed.featuredContributors.slice(0, contributorPreviewLimit);
const liveWire = feed.dynamicFeed.slice(0, 4);
const recentGeekDaily = feed.recentGeekDaily.slice(0, 3);

const liveWireTypeLabel = {
  article: '文章',
  job: '招聘',
  event: '活动',
  geekdaily: 'GeekDaily',
} as const;
---

<BaseLayout site={site} title="Rebase 社区首页" description={site.description}>
  <section class="shell page-hero home-hero">
    <article class="hero-panel card masthead-panel">
      <div class="hero-topline">
        <p class="hero-kicker">建设面向开发者和创新者的社区</p>
      </div>
      <h1 class="hero-title">{site.heroTitle}</h1>
      <p class="hero-summary">{site.heroSummary}</p>
      <p class="brand-note">这是一个由中国开发者用热爱和业余时间共同维护的非营利、公益性开发者社区。</p>
      <div class="button-row">
        <a class="button-link" href={site.heroPrimaryCtaUrl}>{site.heroPrimaryCtaLabel} <span>↗</span></a>
        <a class="button-link secondary" href={site.heroSecondaryCtaUrl}>{site.heroSecondaryCtaLabel} <span>↗</span></a>
      </div>
    </article>

    <aside class="signal-panel card live-desk">
      <SectionHeader
        compact
        title="社区正在发生什么"
      />
      <ol class="live-wire-list">
        {liveWire.map((item) => (
          <li class="live-wire-item">
            <a href={item.href}>
              <div class="live-wire-meta">
                <span>{liveWireTypeLabel[item.type]}</span>
                <time>{item.publishedAt ? formatDate(item.publishedAt) : '刚刚更新'}</time>
              </div>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
            </a>
          </li>
        ))}
      </ol>
    </aside>
  </section>

  <section class="shell meta-strip page-section">
    {site.homeStats.map((stat) => (
      <article class="card">
        <strong>{stat.value}</strong>
        <span>{stat.label}</span>
      </article>
    ))}
  </section>

  <section class="shell page-section">
    <SectionHeader
      compact
      title="近期极客日报"
      description="日报是最稳定的社区更新机制，紧随时代变化，也是搜索与RSS最常用的入口"
      href="/geekdaily"
      hrefLabel="浏览极客日报"
    />
    <div class="grid-3">
      {recentGeekDaily.map((episode) => (
        <GeekDailyCard episode={episode} compact />
      ))}
    </div>
  </section>

  <section class="shell page-section">
    <SectionHeader
      compact
      title="近期文章"
      description="从产品、社区、新技术、新探索到信息架构，公开记录社区内的想法"
      href="/articles"
      hrefLabel="浏览全部文章"
    />
    <div class="grid-3">
      {feed.latestArticles.map((article) => (
        <ArticleCard article={article} compact />
      ))}
    </div>
  </section>

  <section class="shell page-section dual-column">
    <SectionHeader
      compact
      title="新增招聘信息"
      description="帮助读者快速理解岗位背景、工作模式和联系方式。"
      href="/who-is-hiring"
      hrefLabel="浏览全部职位"
    />
    <div class="grid-3">
      {feed.latestJobs.map((job) => (
        <JobCard job={job} compact />
      ))}
    </div>
  </section>

  <section class="shell page-section">
    <SectionHeader
      compact
      title="社区活动"
      description="第一版先聚焦活动展示与报名入口，后续再扩展更复杂的活动能力。"
      href="/events"
      hrefLabel="查看活动"
    />
    <div class="grid-3">
      {feed.latestEvents.map((event) => (
        <EventCard event={event} compact />
      ))}
    </div>
  </section>

  <section class="shell page-section">
    <SectionHeader
      compact
      title="由更多真实的人，一起把社区持续往前推"
      href="/contributors"
      hrefLabel="查看全部贡献者"
    />
    <article class="card contributors-overview">
      <div class="contributors-copy">
        <p class="contributors-kicker">社区照片墙</p>
        <div class="contributors-intro">
          <h3>先看见真实的人，再进入完整的贡献者档案。</h3>
          <p>
            Rebase 由志愿者、编辑与长期协作者共同维护。这里先展示一组持续变化的公开面孔，让社区的气质先被看见。
          </p>
        </div>

        <p class="contributors-note">
          内容整理、活动组织、推荐协作与长期共建，都会慢慢沉淀成可被看见的记录。
        </p>
      </div>

      <div class="contributors-cloud" aria-hidden="true">
        {contributorPreview.map((contributor) => (
          <div class="avatar-token" title={contributor.name}>
            {contributor.avatarUrl ? (
              <img src={contributor.avatarUrl} alt="" loading="lazy" />
            ) : (
              <div class="avatar-fallback" style={`background:${createAvatarData(contributor.avatarSeed)}`}>
                <span>{contributor.name.slice(0, 1)}</span>
              </div>
            )}
          </div>
        ))}
      </div>
    </article>
  </section>

  <section class="shell page-section">
    <article class="card feed-strip">
      <div class="feed-strip-copy">
        <p class="feed-strip-label">RSS 订阅</p>
        <p>通过 RSS 持续追踪 Rebase 的公开内容更新。</p>
      </div>
      <div class="feed-strip-links">
        <a class="feed-primary-link" href="/rss.xml">全站 RSS <span>↗</span></a>
        <div class="feed-secondary-links">
          <a href="/geekdaily/rss.xml">极客日报</a>
          <a href="/articles/rss.xml">文章</a>
          <a href="/events/rss.xml">活动</a>
          <a href="/who-is-hiring/rss.xml">招聘</a>
        </div>
      </div>
    </article>
  </section>
</BaseLayout>

<style>
  .home-hero {
    align-items: stretch;
  }

  .masthead-panel {
    position: relative;
    overflow: hidden;
    padding: 1.42rem 1.48rem 1.45rem;
    background:
      radial-gradient(circle at top left, rgba(243, 196, 110, 0.32), transparent 34%),
      radial-gradient(circle at 92% 18%, rgba(15, 118, 110, 0.16), transparent 22%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 251, 244, 0.92));
    border-color: rgba(15, 118, 110, 0.14);
    box-shadow: 0 26px 60px rgba(26, 40, 34, 0.12);
  }

  .masthead-panel::before {
    content: 'REBASE';
    position: absolute;
    top: 1.2rem;
    right: 1.45rem;
    color: rgba(17, 94, 89, 0.08);
    font-family: var(--display-font);
    font-size: clamp(4.4rem, 8vw, 7rem);
    letter-spacing: 0.08em;
    line-height: 0.82;
    pointer-events: none;
  }

  .masthead-panel::after {
    content: '';
    position: absolute;
    inset: auto -8rem -8rem auto;
    width: 16rem;
    height: 16rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(17, 94, 89, 0.18), transparent 68%);
    pointer-events: none;
  }

  .hero-topline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .masthead-panel .hero-title {
    max-width: 11ch;
    font-size: clamp(2.35rem, 3vw + 1rem, 3.55rem);
    line-height: 1.1;
    letter-spacing: -0.035em;
    text-wrap: balance;
  }

  .brand-note {
    margin: 0.82rem 0 0;
    max-width: 46ch;
    color: rgba(17, 94, 89, 0.84);
    font-size: 0.93rem;
    line-height: 1.68;
  }

  .masthead-panel .button-row {
    gap: 0.72rem;
    margin-top: 1.18rem;
  }

  .masthead-panel .button-link {
    padding: 0.84rem 0.98rem;
  }

  .live-desk {
    display: grid;
    gap: 0.78rem;
    padding: 1.35rem 1.3rem 1.25rem;
    background:
      radial-gradient(circle at top right, rgba(245, 158, 11, 0.18), transparent 24%),
      linear-gradient(180deg, rgba(16, 37, 34, 0.97), rgba(19, 54, 49, 0.94));
    border-color: rgba(15, 118, 110, 0.22);
    box-shadow: 0 26px 56px rgba(16, 37, 34, 0.24);
  }

  .live-desk :global(.section-header.compact) {
    margin-bottom: 0.2rem;
    gap: 0.72rem;
  }

  .live-desk :global(.section-header.compact > div) {
    max-width: 28rem;
  }

  .live-desk :global(.section-header p),
  .live-desk :global(.section-header h2),
  .live-desk :global(.section-header span),
  .live-desk :global(.section-header a) {
    color: rgba(255, 255, 255, 0.9);
  }

  .live-desk :global(.section-header.compact h2) {
    font-size: clamp(1.28rem, 1.45vw, 1.72rem);
  }

  .live-desk :global(.section-header.compact span) {
    font-size: 0.9rem;
    line-height: 1.56;
  }

  .live-desk :global(.section-header a) {
    padding: 0.66rem 0.9rem;
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .live-desk :global(.section-header a:hover),
  .live-desk :global(.section-header a:focus-visible) {
    border-color: rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.12);
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.12);
  }

  .live-wire-list {
    display: grid;
    gap: 0.72rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .live-wire-item a {
    display: block;
    padding: 0.82rem 0.86rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(223, 244, 238, 0.12);
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
  }

  .live-wire-item a:hover,
  .live-wire-item a:focus-visible {
    transform: translateY(-3px);
    border-color: rgba(243, 196, 110, 0.34);
    background: rgba(255, 255, 255, 0.14);
    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.14);
  }

  .live-wire-meta {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
  }

  .live-wire-meta span,
  .live-wire-meta time {
    color: rgba(223, 244, 238, 0.86);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .live-wire-meta time {
    color: rgba(223, 244, 238, 0.6);
  }

  .live-wire-item h3,
  .live-wire-item p {
    margin: 0;
  }

  .live-wire-item h3 {
    margin-top: 0.42rem;
    font-size: 0.96rem;
    line-height: 1.3;
    color: white;
  }

  .live-wire-item p {
    margin-top: 0.38rem;
    color: rgba(223, 244, 238, 0.72);
    font-size: 0.92rem;
    line-height: 1.58;
  }

  .current-desk {
    padding-top: 1.9rem;
  }

  .dispatch-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(19rem, 0.9fr);
    gap: 1rem;
  }

  .dispatch-stack {
    display: grid;
    gap: 1rem;
  }

  .feed-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem 1.25rem;
    padding: 1.05rem 1.18rem;
    background:
      radial-gradient(circle at top right, rgba(245, 158, 11, 0.12), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(248, 253, 251, 0.9));
  }

  .feed-strip-copy {
    display: grid;
    gap: 0.28rem;
    max-width: 32rem;
  }

  .feed-strip-copy p {
    margin: 0;
  }

  .feed-strip-label {
    color: var(--accent-strong);
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .feed-strip-copy p:last-child {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.64;
  }

  .feed-strip-links {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 0.7rem 0.8rem;
  }

  .feed-primary-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.74rem 0.92rem;
    border-radius: 999px;
    border: 1px solid rgba(15, 118, 110, 0.18);
    background: rgba(255, 255, 255, 0.82);
    color: var(--accent-strong);
    font-size: 0.84rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
  }

  .feed-primary-link:hover,
  .feed-primary-link:focus-visible {
    transform: translateY(-1px);
    border-color: rgba(15, 118, 110, 0.26);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 14px 28px rgba(15, 118, 110, 0.08);
  }

  .feed-secondary-links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  .feed-secondary-links a {
    display: inline-flex;
    align-items: center;
    min-height: 2.25rem;
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    color: rgba(17, 94, 89, 0.84);
    font-size: 0.9rem;
    font-weight: 700;
    transition: color 180ms ease, background 180ms ease;
  }

  .feed-secondary-links a:hover,
  .feed-secondary-links a:focus-visible {
    color: var(--accent-strong);
    background: rgba(255, 255, 255, 0.64);
  }

  .contributors-overview {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(28rem, 1.18fr);
    gap: 1.25rem;
    align-items: center;
    padding: 1.18rem 1.25rem;
    background:
      radial-gradient(circle at top left, rgba(243, 196, 110, 0.22), transparent 26%),
      radial-gradient(circle at 82% 18%, rgba(15, 118, 110, 0.18), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(247, 252, 250, 0.93));
  }

  .contributors-overview::after {
    content: '';
    position: absolute;
    inset: auto -3rem -5rem auto;
    width: 12rem;
    height: 12rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(15, 118, 110, 0.12), transparent 70%);
    pointer-events: none;
  }

  .contributors-copy {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.78rem;
    max-width: 30rem;
  }

  .contributors-kicker,
  .contributors-intro h3,
  .contributors-intro p,
  .contributors-note {
    margin: 0;
  }

  .contributors-kicker {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.36rem 0.72rem;
    border: 1px solid rgba(15, 118, 110, 0.16);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
    color: rgba(15, 118, 110, 0.88);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .contributors-intro {
    display: grid;
    gap: 0.72rem;
  }

  .contributors-intro h3 {
    max-width: 12ch;
    color: var(--text);
    font-size: clamp(1.45rem, 1.8vw + 1rem, 2rem);
    line-height: 1.16;
    letter-spacing: -0.03em;
  }

  .contributors-intro p {
    max-width: 52ch;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.76;
  }

  .contributors-note {
    max-width: 46ch;
    padding-top: 0.88rem;
    border-top: 1px solid rgba(15, 118, 110, 0.1);
    color: rgba(62, 86, 76, 0.88);
    font-size: 0.92rem;
    line-height: 1.72;
  }

  .contributors-cloud {
    position: relative;
    isolation: isolate;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 5.2rem));
    gap: 1.15rem 0.95rem;
    align-items: start;
    justify-content: end;
    width: min(100%, 33rem);
    margin-left: auto;
    padding: 1.85rem 0.75rem 1.28rem 0.9rem;
  }

  .contributors-cloud::before {
    content: '';
    position: absolute;
    inset: 0.3rem 0.2rem 0.15rem;
    z-index: -2;
    border: 1px solid rgba(15, 118, 110, 0.1);
    border-radius: 1.35rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(247, 252, 250, 0.56)),
      radial-gradient(circle at 1px 1px, rgba(15, 118, 110, 0.06) 1px, transparent 0);
    background-size: auto, 18px 18px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.68), 0 18px 40px rgba(26, 40, 34, 0.08);
  }

  .contributors-cloud::after {
    content: '';
    position: absolute;
    top: 1rem;
    left: 50%;
    width: 5.2rem;
    height: 1.15rem;
    z-index: -1;
    border-radius: 0.45rem;
    background:
      linear-gradient(180deg, rgba(243, 196, 110, 0.6), rgba(243, 196, 110, 0.24));
    box-shadow: 0 8px 16px rgba(243, 196, 110, 0.14);
    opacity: 0.72;
    transform: translateX(-50%) rotate(-2deg);
  }

  .avatar-token {
    --avatar-rotation: 0deg;
    --avatar-hover-shift: 0rem;
    --avatar-scale: 1;
    position: relative;
    top: 0.72rem;
    justify-self: center;
    width: 5.05rem;
    padding: 0.3rem 0.3rem 0.78rem;
    border: 1px solid rgba(15, 118, 110, 0.1);
    border-radius: 0.7rem;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 18px 36px rgba(26, 40, 34, 0.12);
    transform:
      translateY(var(--avatar-hover-shift))
      rotate(var(--avatar-rotation))
      scale(var(--avatar-scale));
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .avatar-token::before {
    content: '';
    position: absolute;
    top: 0.18rem;
    left: 50%;
    width: 42%;
    height: 0.5rem;
    border-radius: 0.3rem;
    background: linear-gradient(180deg, rgba(243, 196, 110, 0.55), rgba(243, 196, 110, 0.2));
    box-shadow: 0 6px 12px rgba(243, 196, 110, 0.16);
    opacity: 0.76;
    transform: translateX(-50%) rotate(-5deg);
  }

  .avatar-token img,
  .avatar-fallback {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 0.52rem;
  }

  .avatar-token:hover,
  .avatar-token:focus-visible {
    --avatar-hover-shift: -0.18rem;
    --avatar-scale: 1.02;
    border-color: rgba(15, 118, 110, 0.22);
    box-shadow: 0 18px 38px rgba(26, 40, 34, 0.14);
  }

  .avatar-fallback {
    display: grid;
    place-items: center;
    color: white;
    font-size: 1.35rem;
    font-weight: 800;
  }

  .avatar-token:nth-child(5n + 1) {
    --avatar-rotation: -5deg;
    justify-self: start;
  }

  .avatar-token:nth-child(5n + 2) {
    --avatar-rotation: 4deg;
  }

  .avatar-token:nth-child(5n + 3) {
    --avatar-rotation: 6deg;
    margin-top: 0.15rem;
  }

  .avatar-token:nth-child(5n + 4) {
    --avatar-rotation: -4deg;
  }

  .avatar-token:nth-child(5n) {
    --avatar-rotation: 3deg;
    justify-self: end;
    margin-top: 0.25rem;
  }

  .avatar-token:nth-child(6),
  .avatar-token:nth-child(9) {
    margin-top: 0.45rem;
  }

  .avatar-token:nth-child(7),
  .avatar-token:nth-child(10) {
    margin-top: 0.3rem;
  }

  .avatar-token:nth-child(8) {
    margin-top: 0.1rem;
  }

  @media (max-width: 960px) {
    .dispatch-grid,
    .contributors-overview {
      grid-template-columns: 1fr;
    }

    .feed-strip {
      align-items: flex-start;
      flex-direction: column;
    }

    .feed-strip-links,
    .feed-secondary-links {
      justify-content: flex-start;
    }
  }

  @media (max-width: 720px) {
    .hero-topline {
      align-items: flex-start;
      flex-direction: column;
    }

    .contributors-cloud {
      grid-template-columns: repeat(3, minmax(0, 5rem));
      gap: 0.85rem;
      width: 100%;
      justify-content: start;
      margin-left: 0;
      padding: 1.45rem 0 1.1rem;
    }

    .contributors-cloud::before {
      inset: 0.3rem 0 0;
    }

    .contributors-cloud::after {
      top: 0.65rem;
    }

    .avatar-token:nth-child(n) {
      --avatar-rotation: 0deg;
      --avatar-hover-shift: 0rem;
      --avatar-scale: 1;
      top: 0;
      width: 5rem;
      margin-top: 0;
      justify-self: start;
    }
  }
</style>
