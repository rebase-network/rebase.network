---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getGeekDailyArchiveOverview, getGeekDailyEpisodes, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';
import { getGeekDailyPath } from '@/lib/paths';

const pageSize = 18;
const [site, overview, episodes] = await Promise.all([
  getSiteSettings(),
  getGeekDailyArchiveOverview(),
  getGeekDailyEpisodes(pageSize),
]);
const years = overview.years;
const featuredTags = overview.featuredTags;

Astro.response.headers.set('Cache-Control', 'public, max-age=300, stale-while-revalidate=3600');
---

<BaseLayout
  site={site}
  title="Rebase极客日报"
  description="浏览、筛选并检索 Rebase 社区的 GeekDaily 历史归档。"
>
  <section class="shell page-hero single">
    <article class="hero-panel card geekdaily-archive-hero">
      <div class="hero-topline">
        <p class="hero-kicker">极客日报</p>
        <span class="edition-chip">Issue Archive</span>
      </div>
      <h1 class="hero-title">Rebase 极客日报</h1>
      <p class="hero-summary">
        由社区志愿者持续整理发布，每期收录值得关注的技术内容、推荐人和推荐语，方便你按期回看、检索与订阅。
      </p>
    </article>
  </section>

  <section class="shell page-section controls-grid">
    <div class="card search-panel">
      <label for="geekdaily-search">搜索 GeekDaily</label>
      <input
        id="geekdaily-search"
        name="q"
        type="search"
        placeholder="搜索期数、geekdaily-编号、标题、推荐语、条目标题或推荐人"
        autocomplete="off"
      />
      <p>支持期数编号、<code>geekdaily-1915</code>、标题、推荐语、推荐人和条目标题关键词。</p>
    </div>

    <div class="card quick-filter-panel">
      {featuredTags.length > 0 && (
        <div>
          <p class="panel-title">标签筛选</p>
          <div class="chip-row" role="list">
            {featuredTags.map((tag) => (
              <button
                type="button"
                class="chip-button"
                data-tag={tag}
                aria-pressed="false"
                aria-controls="results-list"
              >
                {tag}
              </button>
            ))}
          </div>
        </div>
      )}
      <div>
        <p class="panel-title">年份筛选</p>
        <div class="chip-row" role="list">
          {years.slice(0, 6).map((year) => (
            <button
              type="button"
              class="chip-button muted"
              data-year={year}
              aria-pressed="false"
              aria-controls="results-list"
            >
              {year}
            </button>
          ))}
        </div>
      </div>
      <button type="button" class="reset-button" id="reset-filters" aria-controls="results-list">清空筛选</button>
    </div>
  </section>

  <section class="shell page-section">
    <div class="results-head">
      <div id="results-status" role="status" aria-live="polite" aria-atomic="true">
        <p id="results-count">共 {overview.totalEpisodes} 期</p>
        <span id="results-state">默认展示最近 {pageSize} 期。</span>
      </div>
      <a href="/geekdaily/rss.xml">订阅 RSS ↗</a>
    </div>

    <div class="episode-list" id="results-list" data-total-episodes={overview.totalEpisodes} aria-busy="false">
      {episodes.map((episode) => (
        <article class="card episode-card">
          <p class="meta">{episode.title} · {formatDate(episode.publishedAt)}</p>
          <h2>
            <a href={getGeekDailyPath(episode.episodeNumber)}>{episode.title}</a>
          </h2>
          <p class="summary">{episode.summary}</p>
          {episode.editors.length > 0 && <p class="editor-line">编辑：{episode.editors.join('、')}</p>}
          <ul>
            {episode.items.slice(0, 3).map((item) => <li>{item.title}</li>)}
          </ul>
        </article>
      ))}
    </div>

    <div class="pager card" aria-label="GeekDaily 分页">
      <button type="button" id="pager-prev" disabled>上一页</button>
      <p id="pager-label">第 1 页</p>
      <button type="button" id="pager-next" disabled={overview.totalEpisodes <= pageSize}>下一页</button>
    </div>
  </section>

  <script>
    type ArchiveEpisodeItem = {
      title: string;
      authorName: string;
      summary: string;
      sourceUrl: string;
    };

    type ArchiveEpisode = {
      slug: string;
      episodeNumber: number;
      title: string;
      summary: string;
      publishedAt: string;
      editors: string[];
      tags: string[];
      items: ArchiveEpisodeItem[];
    };

    type ArchivePayload = {
      data: ArchiveEpisode[];
      meta: {
        page: number;
        pageSize: number;
        totalItems: number;
        totalPages: number;
        hasPrevPage: boolean;
        hasNextPage: boolean;
      };
    };

    type SearchDocumentItem = {
      title: string;
      authorName: string;
      summary: string;
    };

    type SearchDocument = {
      slug: string;
      episodeNumber: number;
      title: string;
      summary: string;
      editors: string[];
      tags: string[];
      publishedAt: string;
      year: string;
      items: SearchDocumentItem[];
      searchableText: string;
    };
    type SearchDocumentPayload = Omit<SearchDocument, 'searchableText'>;
    type SearchDocumentEnvelope = {
      data: SearchDocumentPayload[];
    };

    const pageSize = 18;
    const input = document.querySelector<HTMLInputElement>('#geekdaily-search');
    const list = document.querySelector<HTMLElement>('#results-list');
    const totalEpisodes = Number(list?.dataset.totalEpisodes ?? '0');
    const count = document.querySelector<HTMLElement>('#results-count');
    const stateLabel = document.querySelector<HTMLElement>('#results-state');
    const prevButton = document.querySelector<HTMLButtonElement>('#pager-prev');
    const nextButton = document.querySelector<HTMLButtonElement>('#pager-next');
    const pagerLabel = document.querySelector<HTMLElement>('#pager-label');
    const tagButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-tag]'));
    const yearButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-year]'));
    const resetButton = document.querySelector<HTMLButtonElement>('#reset-filters');

    const escapeHtml = (value: string) =>
      value
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const formatPublishedAt = (value: string) =>
      new Intl.DateTimeFormat('zh-CN', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        timeZone: 'Asia/Shanghai',
      }).format(new Date(value));

    if (input && list && count && stateLabel && prevButton && nextButton && pagerLabel && resetButton) {
      const defaultMarkup = list.innerHTML;
      let documentsPromise: Promise<SearchDocument[]> | undefined;
      const archivePageCache = new Map<string, Promise<ArchivePayload>>();
      let renderToken = 0;

      const state = {
        query: '',
        tag: '',
        year: '',
        page: 1,
      };

      const syncControls = () => {
        input.value = state.query;

        for (const button of tagButtons) {
          const active = button.dataset.tag === state.tag;
          button.dataset.active = active ? 'true' : 'false';
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
        }

        for (const button of yearButtons) {
          const active = button.dataset.year === state.year;
          button.dataset.active = active ? 'true' : 'false';
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
        }
      };

      const setBusyState = (busy: boolean) => {
        list.setAttribute('aria-busy', busy ? 'true' : 'false');
      };

      const buildActiveFilters = () =>
        [state.query && `搜索“${state.query}”`, state.tag && `标签 ${state.tag}`, state.year && `年份 ${state.year}`].filter(Boolean);

      const renderEpisodeCards = (
        items: Array<{ episodeNumber: number; title: string; publishedAt: string; summary: string; editors: string[]; items: { title: string }[] }>,
      ) => {
        if (items.length === 0) {
          list.innerHTML = `
            <article class="card empty-state">
              <h2>没有找到匹配的 GeekDaily</h2>
              <p>你可以尝试换一个关键词，或者先清空年份筛选再继续搜索。</p>
            </article>
          `;
          return;
        }

        list.innerHTML = items
          .map((item) => {
            const itemPreview = item.items
              .slice(0, 3)
              .map((entry) => `<li>${escapeHtml(entry.title)}</li>`)
              .join('');
            const editorLine =
              item.editors.length > 0 ? `<p class="editor-line">编辑：${escapeHtml(item.editors.join('、'))}</p>` : '';

            return `
              <article class="card episode-card">
                <p class="meta">${escapeHtml(item.title)} · ${escapeHtml(formatPublishedAt(item.publishedAt))}</p>
                <h2><a href="/geekdaily/geekdaily-${item.episodeNumber}">${escapeHtml(item.title)}</a></h2>
                <p class="summary">${escapeHtml(item.summary)}</p>
                ${editorLine}
                <ul>${itemPreview}</ul>
              </article>
            `;
          })
          .join('');
      };

      const updateUrl = () => {
        const params = new URLSearchParams(window.location.search);

        if (state.query) {
          params.set('q', state.query);
        } else {
          params.delete('q');
        }

        if (state.tag) {
          params.set('tag', state.tag);
        } else {
          params.delete('tag');
        }

        if (state.year) {
          params.set('year', state.year);
        } else {
          params.delete('year');
        }

        if (state.page > 1) {
          params.set('page', String(state.page));
        } else {
          params.delete('page');
        }

        const queryString = params.toString();
        const nextUrl = queryString ? `${window.location.pathname}?${queryString}` : window.location.pathname;
        window.history.replaceState({}, '', nextUrl);
      };

      const hydrateFromUrl = () => {
        const params = new URLSearchParams(window.location.search);
        const rawPage = Number(params.get('page') ?? '1');

        state.query = params.get('q') ?? '';
        state.tag = params.get('tag') ?? '';
        state.year = params.get('year') ?? '';
        state.page = Number.isFinite(rawPage) && rawPage > 0 ? Math.floor(rawPage) : 1;
      };

      const restoreDefault = () => {
        renderToken += 1;
        list.innerHTML = defaultMarkup;
        count.textContent = `共 ${totalEpisodes} 期`;
        stateLabel.textContent = `默认展示最近 ${pageSize} 期。`;
        pagerLabel.textContent = '第 1 页';
        prevButton.disabled = true;
        nextButton.disabled = totalEpisodes <= pageSize;
        setBusyState(false);
        syncControls();
        updateUrl();
      };

      const buildArchiveEndpoint = () => {
        const params = new URLSearchParams();
        params.set('page', String(state.page));
        params.set('pageSize', String(pageSize));

        if (state.tag) {
          params.set('tag', state.tag);
        }

        if (state.year) {
          params.set('year', state.year);
        }

        return `/api/geekdaily-archive.json?${params.toString()}`;
      };

      const loadArchivePage = async () => {
        const endpoint = buildArchiveEndpoint();
        const cached = archivePageCache.get(endpoint);
        if (cached) {
          return cached;
        }

        stateLabel.textContent = '正在加载归档列表...';
        setBusyState(true);

        const promise = fetch(endpoint)
          .then((response) => {
            if (!response.ok) {
              throw new Error(`archive request failed: ${response.status}`);
            }

            return response.json() as Promise<ArchivePayload>;
          })
          .catch((error) => {
            archivePageCache.delete(endpoint);
            throw error;
          })
          .finally(() => {
            setBusyState(false);
          });

        archivePageCache.set(endpoint, promise);
        return promise;
      };

      const loadDocuments = async () => {
        if (!documentsPromise) {
          stateLabel.textContent = '正在加载历史检索数据...';
          setBusyState(true);
          documentsPromise = fetch('/api/geekdaily-search.json')
            .then((response) => {
              if (!response.ok) {
                throw new Error(`search index request failed: ${response.status}`);
              }
              return response.json() as Promise<SearchDocumentPayload[] | SearchDocumentEnvelope>;
            })
            .then((payload) => {
              const documents = Array.isArray(payload) ? payload : payload.data;
              if (!Array.isArray(documents)) {
                throw new Error('search index response is invalid');
              }

              return documents.map((document) => {
                const searchableText = [
                  document.title,
                  document.summary,
                  document.tags.join(' '),
                  ...document.items.flatMap((item) => [item.title, item.authorName, item.summary]),
                ]
                  .join(' ')
                  .toLowerCase();

                return {
                  ...document,
                  searchableText,
                };
              });
            })
            .catch((error) => {
              documentsPromise = undefined;
              throw error;
            })
            .finally(() => {
              setBusyState(false);
            });
        }

        return documentsPromise;
      };

      const renderArchive = (payload: ArchivePayload) => {
        const activeFilters = buildActiveFilters();

        renderEpisodeCards(payload.data);
        count.textContent = activeFilters.length > 0 ? `找到 ${payload.meta.totalItems} 期` : `共 ${totalEpisodes} 期`;
        stateLabel.textContent =
          activeFilters.length > 0
            ? `当前条件：${activeFilters.join(' · ')}`
            : state.page > 1
              ? '按发布时间倒序浏览归档。'
              : `默认展示最近 ${pageSize} 期。`;
        pagerLabel.textContent = `第 ${payload.meta.page} / ${Math.max(payload.meta.totalPages, 1)} 页`;
        prevButton.disabled = !payload.meta.hasPrevPage;
        nextButton.disabled = !payload.meta.hasNextPage;

        syncControls();
        updateUrl();
      };

      const getFilteredDocuments = (documents: SearchDocument[]) => {
        const baseResults = documents.filter((document) => {
          const matchesTag = !state.tag || document.tags.includes(state.tag);
          const matchesYear = !state.year || document.year === state.year;
          return matchesTag && matchesYear;
        });

        if (!state.query) {
          return baseResults;
        }

        const numericQuery = state.query.toLowerCase().replace(/^(geekdaily|episode)-/, '').replace(/^#/, '').trim();
        const exactEpisodeMatches = baseResults.filter((document) => String(document.episodeNumber) === numericQuery);

        if (/^\d+$/.test(numericQuery) && exactEpisodeMatches.length > 0) {
          return exactEpisodeMatches;
        }

        const tokens = state.query
          .toLowerCase()
          .split(/\s+/)
          .map((token) => token.trim())
          .filter(Boolean);

        return baseResults.filter((document) => tokens.every((token) => document.searchableText.includes(token)));
      };

      const renderSearch = (documents: SearchDocument[]) => {
        const filtered = getFilteredDocuments(documents);
        const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
        state.page = Math.min(Math.max(state.page, 1), totalPages);

        const pageStart = (state.page - 1) * pageSize;
        const visibleItems = filtered.slice(pageStart, pageStart + pageSize);
        const activeFilters = buildActiveFilters();

        renderEpisodeCards(visibleItems);

        count.textContent = activeFilters.length > 0 ? `找到 ${filtered.length} 期` : `共 ${documents.length} 期`;
        stateLabel.textContent = activeFilters.length > 0 ? `当前条件：${activeFilters.join(' · ')}` : `默认展示最近 ${pageSize} 期。`;
        pagerLabel.textContent = `第 ${state.page} / ${totalPages} 页`;
        prevButton.disabled = state.page <= 1;
        nextButton.disabled = state.page >= totalPages;

        syncControls();
        updateUrl();
      };

      const loadAndRender = async () => {
        const currentToken = ++renderToken;

        if (!state.query) {
          try {
            const payload = await loadArchivePage();
            if (currentToken !== renderToken) {
              return;
            }
            renderArchive(payload);
          } catch (error) {
            if (currentToken !== renderToken) {
              return;
            }
            console.error(error);
            list.innerHTML = `
              <article class="card empty-state">
                <h2>暂时无法加载 GeekDaily 归档</h2>
                <p>你可以稍后刷新重试，或者先回到第一页继续浏览默认归档列表。</p>
              </article>
            `;
            count.textContent = '归档暂不可用';
            stateLabel.textContent = '归档数据加载失败。';
            pagerLabel.textContent = '第 1 页';
            prevButton.disabled = true;
            nextButton.disabled = true;
            setBusyState(false);
            syncControls();
            updateUrl();
          }

          return;
        }

        try {
          const documents = await loadDocuments();
          if (currentToken !== renderToken) {
            return;
          }
          renderSearch(documents);
        } catch (error) {
          if (currentToken !== renderToken) {
            return;
          }
          console.error(error);
          list.innerHTML = `
            <article class="card empty-state">
              <h2>暂时无法加载 GeekDaily 检索数据</h2>
              <p>你可以稍后刷新重试，或者先直接浏览默认归档列表。</p>
            </article>
          `;
          count.textContent = '检索暂不可用';
          stateLabel.textContent = '历史检索数据加载失败。';
          pagerLabel.textContent = '第 1 页';
          prevButton.disabled = true;
          nextButton.disabled = true;
          setBusyState(false);
          syncControls();
          updateUrl();
        }
      };

      input.addEventListener('input', async () => {
        state.query = input.value.trim();
        state.page = 1;
        if (!state.query && !state.tag && !state.year && state.page === 1) {
          restoreDefault();
          return;
        }
        await loadAndRender();
      });

      prevButton.addEventListener('click', async () => {
        state.page -= 1;
        await loadAndRender();
      });

      nextButton.addEventListener('click', async () => {
        state.page += 1;
        await loadAndRender();
      });

      for (const button of tagButtons) {
        button.addEventListener('click', async () => {
          state.tag = state.tag === button.dataset.tag ? '' : button.dataset.tag ?? '';
          state.page = 1;
          if (!state.query && !state.tag && !state.year && state.page === 1) {
            restoreDefault();
            return;
          }
          await loadAndRender();
        });
      }

      for (const button of yearButtons) {
        button.addEventListener('click', async () => {
          state.year = state.year === button.dataset.year ? '' : button.dataset.year ?? '';
          state.page = 1;
          if (!state.query && !state.tag && !state.year && state.page === 1) {
            restoreDefault();
            return;
          }
          await loadAndRender();
        });
      }

      resetButton.addEventListener('click', () => {
        state.query = '';
        state.tag = '';
        state.year = '';
        state.page = 1;
        restoreDefault();
      });

      hydrateFromUrl();
      syncControls();

      if (state.query || state.tag || state.year || state.page > 1) {
        void loadAndRender();
      }
    }
  </script>
</BaseLayout>

<style>
  .single {
    grid-template-columns: 1fr;
    padding: 1rem 0 0.4rem;
  }

  .geekdaily-archive-hero {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 0.45rem;
    padding: 1.15rem 1.3rem;
    background:
      radial-gradient(circle at top left, rgba(125, 211, 252, 0.18), transparent 30%),
      radial-gradient(circle at 92% 18%, rgba(15, 118, 110, 0.14), transparent 22%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(244, 251, 249, 0.9));
  }

  .geekdaily-archive-hero::before {
    content: 'GEEKDAILY';
    position: absolute;
    top: 0.85rem;
    right: 1.15rem;
    color: rgba(17, 94, 89, 0.08);
    font-family: var(--display-font);
    font-size: clamp(3.4rem, 7vw, 5.8rem);
    letter-spacing: 0.08em;
    line-height: 0.82;
    pointer-events: none;
  }

  .geekdaily-archive-hero > * {
    position: relative;
    z-index: 1;
  }

  .hero-topline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .edition-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.42rem 0.76rem;
    border: 1px solid rgba(15, 118, 110, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    color: var(--accent-strong);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .geekdaily-archive-hero .hero-kicker {
    margin-bottom: 0;
  }

  .geekdaily-archive-hero .hero-title {
    max-width: none;
    font-size: clamp(2rem, 4vw, 2.85rem);
    line-height: 1;
    letter-spacing: -0.035em;
  }

  .geekdaily-archive-hero .hero-summary {
    margin-top: 0;
    max-width: 64ch;
    font-size: 0.98rem;
    line-height: 1.72;
  }

  .search-panel,
  .quick-filter-panel,
  .episode-list :global(.episode-card),
  .pager {
    padding: 1.2rem;
  }

  .panel-title,
  .search-panel label,
  .results-head p,
  .results-head a,
  .results-head span {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .panel-title,
  .search-panel label,
  .results-head a {
    color: var(--accent-strong);
  }

  .search-panel p,
  .results-head span,
  .episode-list :global(.summary),
  .episode-list :global(.empty-state p) {
    color: var(--muted);
    line-height: 1.75;
  }

  .controls-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 1rem;
  }

  .search-panel {
    display: grid;
    gap: 0.9rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(240, 249, 246, 0.88));
  }

  .search-panel input {
    width: 100%;
    padding: 1rem 1.05rem;
    border: 1px solid rgba(31, 41, 51, 0.12);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.82);
    font: inherit;
  }

  .quick-filter-panel {
    display: grid;
    gap: 1rem;
    align-content: start;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 249, 239, 0.9));
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.85rem;
  }

  .chip-button,
  .reset-button,
  .pager button {
    padding: 0.75rem 0.95rem;
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    font: inherit;
  }

  .chip-button {
    background: rgba(15, 118, 110, 0.09);
    color: var(--accent-strong);
    font-weight: 700;
  }

  .chip-button.muted {
    background: rgba(148, 163, 184, 0.16);
    color: var(--muted);
  }

  .chip-button[data-active='true'] {
    background: var(--accent-strong);
    color: white;
  }

  .reset-button,
  .pager button {
    background: rgba(31, 41, 51, 0.08);
    color: var(--text);
    font-weight: 700;
  }

