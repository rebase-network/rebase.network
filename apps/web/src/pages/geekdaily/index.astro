---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getGeekDailyArchiveOverview, getGeekDailyEpisodes, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';
import { getGeekDailyPath } from '@/lib/paths';

const pageSize = 18;
const [site, overview, episodes] = await Promise.all([
  getSiteSettings(),
  getGeekDailyArchiveOverview(),
  getGeekDailyEpisodes(pageSize),
]);
const years = overview.years;
const featuredTags = overview.featuredTags;
---

<BaseLayout
  site={site}
  title="GeekDaily 归档"
  description="浏览、筛选并检索 Rebase 社区的 GeekDaily 历史归档。"
>
  <section class="shell page-hero single">
    <article class="hero-panel card">
      <p class="hero-kicker">GeekDaily 归档</p>
      <h1 class="hero-title">GeekDaily 是 Rebase 的持续现场，它应该被阅读、搜索和订阅。</h1>
      <p class="hero-summary">
        第一版先用前端搜索做实用检索，并把 1800+ 期历史内容组织成一个更适合浏览的期数归档。
      </p>
    </article>
  </section>

  <section class="shell page-section archive-stats">
    <article class="card stat-card">
      <span>归档总数</span>
      <strong>{overview.totalEpisodes} 期</strong>
      <p>按期数归档，避免把每一期拆散成难以理解的零碎列表。</p>
    </article>
    <article class="card stat-card">
      <span>时间跨度</span>
      <strong>{years.at(-1)} - {years[0]}</strong>
      <p>为历史日报保留稳定链接、可搜索入口和 RSS 输出。</p>
    </article>
    <article class="card stat-card">
      <span>链接规则</span>
      <strong>/geekdaily/geekdaily-1915</strong>
      <p>统一使用 <code>geekdaily-&#123;episode-number&#125;</code> 规则，让期数含义和栏目来源一眼可辨。</p>
    </article>
  </section>

  <section class="shell page-section controls-grid">
    <div class="card search-panel">
      <label for="geekdaily-search">搜索 GeekDaily</label>
      <input
        id="geekdaily-search"
        name="q"
        type="search"
        placeholder="搜索期数、geekdaily-编号、标题、推荐语、条目标题或推荐人"
        autocomplete="off"
      />
      <p>支持期数编号、<code>geekdaily-1915</code>、标题、推荐语、推荐人和条目标题关键词。</p>
    </div>

    <div class="card quick-filter-panel">
      {featuredTags.length > 0 && (
        <div>
          <p class="panel-title">标签筛选</p>
          <div class="chip-row" role="list">
            {featuredTags.map((tag) => (
              <button
                type="button"
                class="chip-button"
                data-tag={tag}
                aria-pressed="false"
                aria-controls="results-list"
              >
                {tag}
              </button>
            ))}
          </div>
        </div>
      )}
      <div>
        <p class="panel-title">年份筛选</p>
        <div class="chip-row" role="list">
          {years.slice(0, 6).map((year) => (
            <button
              type="button"
              class="chip-button muted"
              data-year={year}
              aria-pressed="false"
              aria-controls="results-list"
            >
              {year}
            </button>
          ))}
        </div>
      </div>
      <button type="button" class="reset-button" id="reset-filters" aria-controls="results-list">清空筛选</button>
    </div>
  </section>

  <section class="shell page-section">
    <div class="results-head">
      <div id="results-status" role="status" aria-live="polite" aria-atomic="true">
        <p id="results-count">共 {overview.totalEpisodes} 期</p>
        <span id="results-state">默认展示最近 {pageSize} 期。</span>
      </div>
      <a href="/geekdaily/rss.xml">订阅 RSS ↗</a>
    </div>

    <div class="episode-list" id="results-list" data-total-episodes={overview.totalEpisodes} aria-busy="false">
      {episodes.map((episode) => (
        <article class="card episode-card">
          <p class="meta">{episode.title} · {formatDate(episode.publishedAt)}</p>
          <h2>
            <a href={getGeekDailyPath(episode.episodeNumber)}>{episode.title}</a>
          </h2>
          <p class="summary">{episode.summary}</p>
          <p class="body">{episode.body}</p>
          <ul>
            {episode.items.slice(0, 3).map((item) => <li>{item.title}</li>)}
          </ul>
        </article>
      ))}
    </div>

    <div class="pager card" aria-label="GeekDaily 分页">
      <button type="button" id="pager-prev" disabled>上一页</button>
      <p id="pager-label">第 1 页</p>
      <button type="button" id="pager-next" disabled={overview.totalEpisodes <= pageSize}>下一页</button>
    </div>
  </section>

  <script>
    type SearchDocument = {
      slug: string;
      episodeNumber: number;
      title: string;
      summary: string;
      body: string;
      tags: string[];
      publishedAt: string;
      year: string;
      itemTitles: string[];
      searchableText: string;
    };

    const pageSize = 18;
    const input = document.querySelector<HTMLInputElement>('#geekdaily-search');
    const list = document.querySelector<HTMLElement>('#results-list');
    const totalEpisodes = Number(list?.dataset.totalEpisodes ?? '0');
    const count = document.querySelector<HTMLElement>('#results-count');
    const stateLabel = document.querySelector<HTMLElement>('#results-state');
    const prevButton = document.querySelector<HTMLButtonElement>('#pager-prev');
    const nextButton = document.querySelector<HTMLButtonElement>('#pager-next');
    const pagerLabel = document.querySelector<HTMLElement>('#pager-label');
    const tagButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-tag]'));
    const yearButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-year]'));
    const resetButton = document.querySelector<HTMLButtonElement>('#reset-filters');

    const escapeHtml = (value: string) =>
      value
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const formatPublishedAt = (value: string) =>
      new Intl.DateTimeFormat('zh-CN', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        timeZone: 'Asia/Shanghai',
      }).format(new Date(value));

    if (input && list && count && stateLabel && prevButton && nextButton && pagerLabel && resetButton) {
      const defaultMarkup = list.innerHTML;
      let documentsPromise: Promise<SearchDocument[]> | undefined;

      const state = {
        query: '',
        tag: '',
        year: '',
        page: 1,
      };

      const syncControls = () => {
        input.value = state.query;

        for (const button of tagButtons) {
          const active = button.dataset.tag === state.tag;
          button.dataset.active = active ? 'true' : 'false';
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
        }

        for (const button of yearButtons) {
          const active = button.dataset.year === state.year;
          button.dataset.active = active ? 'true' : 'false';
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
        }
      };

      const setBusyState = (busy: boolean) => {
        list.setAttribute('aria-busy', busy ? 'true' : 'false');
      };

      const updateUrl = () => {
        const params = new URLSearchParams(window.location.search);

        if (state.query) {
          params.set('q', state.query);
        } else {
          params.delete('q');
        }

        if (state.tag) {
          params.set('tag', state.tag);
        } else {
          params.delete('tag');
        }

        if (state.year) {
          params.set('year', state.year);
        } else {
          params.delete('year');
        }

        if (state.page > 1) {
          params.set('page', String(state.page));
        } else {
          params.delete('page');
        }

        const queryString = params.toString();
        const nextUrl = queryString ? `${window.location.pathname}?${queryString}` : window.location.pathname;
        window.history.replaceState({}, '', nextUrl);
      };

      const hydrateFromUrl = () => {
        const params = new URLSearchParams(window.location.search);
        const rawPage = Number(params.get('page') ?? '1');

        state.query = params.get('q') ?? '';
        state.tag = params.get('tag') ?? '';
        state.year = params.get('year') ?? '';
        state.page = Number.isFinite(rawPage) && rawPage > 0 ? Math.floor(rawPage) : 1;
      };

      const restoreDefault = () => {
        list.innerHTML = defaultMarkup;
        count.textContent = `共 ${totalEpisodes} 期`;
        stateLabel.textContent = `默认展示最近 ${pageSize} 期。`;
        pagerLabel.textContent = '第 1 页';
        prevButton.disabled = true;
        nextButton.disabled = totalEpisodes <= pageSize;
        setBusyState(false);
        syncControls();
        updateUrl();
      };

      const loadDocuments = async () => {
        if (!documentsPromise) {
          stateLabel.textContent = '正在加载历史检索数据...';
          setBusyState(true);
          documentsPromise = fetch('/api/geekdaily-search.json')
            .then((response) => {
              if (!response.ok) {
                throw new Error(`search index request failed: ${response.status}`);
              }
              return response.json() as Promise<SearchDocument[]>;
            })
            .catch((error) => {
              documentsPromise = undefined;
              throw error;
            })
            .finally(() => {
              setBusyState(false);
            });
        }

        return documentsPromise;
      };

      const getFilteredDocuments = (documents: SearchDocument[]) => {
        const baseResults = documents.filter((document) => {
          const matchesTag = !state.tag || document.tags.includes(state.tag);
          const matchesYear = !state.year || document.year === state.year;
          return matchesTag && matchesYear;
        });

        if (!state.query) {
          return baseResults;
        }

        const numericQuery = state.query.toLowerCase().replace(/^(geekdaily|episode)-/, '').replace(/^#/, '').trim();
        const exactEpisodeMatches = baseResults.filter((document) => String(document.episodeNumber) === numericQuery);

        if (/^\d+$/.test(numericQuery) && exactEpisodeMatches.length > 0) {
          return exactEpisodeMatches;
        }

        const tokens = state.query
          .toLowerCase()
          .split(/\s+/)
          .map((token) => token.trim())
          .filter(Boolean);

        return baseResults.filter((document) => tokens.every((token) => document.searchableText.includes(token)));
      };

      const render = (documents: SearchDocument[]) => {
        const filtered = getFilteredDocuments(documents);
        const totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
        state.page = Math.min(Math.max(state.page, 1), totalPages);

        const pageStart = (state.page - 1) * pageSize;
        const visibleItems = filtered.slice(pageStart, pageStart + pageSize);
        const activeFilters = [
          state.query && `搜索“${state.query}”`,
          state.tag && `标签 ${state.tag}`,
          state.year && `年份 ${state.year}`,
        ].filter(Boolean);

        if (visibleItems.length === 0) {
          list.innerHTML = `
            <article class="card empty-state">
              <h2>没有找到匹配的 GeekDaily</h2>
              <p>你可以尝试换一个关键词，或者先清空年份筛选再继续搜索。</p>
            </article>
          `;
        } else {
          list.innerHTML = visibleItems
            .map((item) => {
              const itemPreview = item.itemTitles
                .slice(0, 3)
                .map((title) => `<li>${escapeHtml(title)}</li>`)
                .join('');

              return `
                <article class="card episode-card">
                  <p class="meta">${escapeHtml(item.title)} · ${escapeHtml(formatPublishedAt(item.publishedAt))}</p>
                  <h2><a href="/geekdaily/geekdaily-${item.episodeNumber}">${escapeHtml(item.title)}</a></h2>
                  <p class="summary">${escapeHtml(item.summary)}</p>
                  <p class="body">${escapeHtml(item.body)}</p>
                  <ul>${itemPreview}</ul>
                </article>
              `;
            })
            .join('');
        }

        count.textContent = activeFilters.length > 0 ? `找到 ${filtered.length} 期` : `共 ${documents.length} 期`;
        stateLabel.textContent = activeFilters.length > 0 ? `当前条件：${activeFilters.join(' · ')}` : `默认展示最近 ${pageSize} 期。`;
        pagerLabel.textContent = `第 ${state.page} / ${totalPages} 页`;
        prevButton.disabled = state.page <= 1;
        nextButton.disabled = state.page >= totalPages;

        syncControls();
        updateUrl();
      };

      const loadAndRender = async () => {
        try {
          const documents = await loadDocuments();
          render(documents);
        } catch (error) {
          console.error(error);
          list.innerHTML = `
            <article class="card empty-state">
              <h2>暂时无法加载 GeekDaily 检索数据</h2>
              <p>你可以稍后刷新重试，或者先直接浏览默认归档列表。</p>
            </article>
          `;
          count.textContent = '检索暂不可用';
          stateLabel.textContent = '历史检索数据加载失败。';
          pagerLabel.textContent = '第 1 页';
          prevButton.disabled = true;
          nextButton.disabled = true;
          setBusyState(false);
          syncControls();
          updateUrl();
        }
      };

      input.addEventListener('input', async () => {
        state.query = input.value.trim();
        state.page = 1;
        if (!state.query && !state.tag && !state.year && !documentsPromise) {
          restoreDefault();
          return;
        }
        await loadAndRender();
      });

      prevButton.addEventListener('click', async () => {
        state.page -= 1;
        await loadAndRender();
      });

      nextButton.addEventListener('click', async () => {
        state.page += 1;
        await loadAndRender();
      });

      for (const button of tagButtons) {
        button.addEventListener('click', async () => {
          state.tag = state.tag === button.dataset.tag ? '' : button.dataset.tag ?? '';
          state.page = 1;
          if (!state.query && !state.tag && !state.year && !documentsPromise) {
            restoreDefault();
            return;
          }
          await loadAndRender();
        });
      }

      for (const button of yearButtons) {
        button.addEventListener('click', async () => {
          state.year = state.year === button.dataset.year ? '' : button.dataset.year ?? '';
          state.page = 1;
          if (!state.query && !state.tag && !state.year && !documentsPromise) {
            restoreDefault();
            return;
          }
          await loadAndRender();
        });
      }

      resetButton.addEventListener('click', () => {
        state.query = '';
        state.tag = '';
        state.year = '';
        state.page = 1;
        if (!documentsPromise) {
          restoreDefault();
          return;
        }
        void loadAndRender();
      });

      hydrateFromUrl();
      syncControls();

      if (state.query || state.tag || state.year || state.page > 1) {
        void loadAndRender();
      }
    }
  </script>
</BaseLayout>

<style>
  .single {
    grid-template-columns: 1fr;
  }

  .archive-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .stat-card,
  .search-panel,
  .quick-filter-panel,
  .episode-card,
  .pager {
    padding: 1.2rem;
  }

  .stat-card {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(245, 251, 249, 0.88));
  }

  .stat-card span,
  .panel-title,
  .search-panel label,
  .results-head p,
  .results-head a,
  .results-head span {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .stat-card span,
  .panel-title,
  .search-panel label,
  .results-head a {
    color: var(--accent-strong);
  }

  .stat-card strong {
    display: block;
    margin-top: 0.55rem;
    font-size: 1.65rem;
    line-height: 1.1;
  }

  .stat-card p,
  .search-panel p,
  .results-head span,
  .summary,
  .body,
  .empty-state p {
    color: var(--muted);
    line-height: 1.75;
  }

  .controls-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 1rem;
  }

  .search-panel {
    display: grid;
    gap: 0.9rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(240, 249, 246, 0.88));
  }

  .search-panel input {
    width: 100%;
    padding: 1rem 1.05rem;
    border: 1px solid rgba(31, 41, 51, 0.12);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.82);
    font: inherit;
  }

  .quick-filter-panel {
    display: grid;
    gap: 1rem;
    align-content: start;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 249, 239, 0.9));
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.85rem;
  }

  .chip-button,
  .reset-button,
  .pager button {
    padding: 0.75rem 0.95rem;
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    font: inherit;
  }

  .chip-button {
    background: rgba(15, 118, 110, 0.09);
    color: var(--accent-strong);
    font-weight: 700;
  }

  .chip-button.muted {
    background: rgba(148, 163, 184, 0.16);
    color: var(--muted);
  }

  .chip-button[data-active='true'] {
    background: var(--accent-strong);
    color: white;
  }

  .reset-button,
  .pager button {
    background: rgba(31, 41, 51, 0.08);
    color: var(--text);
    font-weight: 700;
  }

  .results-head,
  .pager {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .results-head {
    margin-bottom: 1rem;
  }

  .results-head a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.72rem 0.95rem;
    border: 1px solid rgba(15, 118, 110, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.86);
    box-shadow: 0 10px 20px rgba(15, 118, 110, 0.08);
    transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
  }

  .results-head a:hover,
  .results-head a:focus-visible {
    transform: translateY(-1px);
    border-color: rgba(15, 118, 110, 0.28);
    box-shadow: 0 14px 28px rgba(15, 118, 110, 0.12);
  }

  .episode-list {
    display: grid;
    gap: 1rem;
  }

  .episode-card {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 0.35rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(253, 250, 244, 0.9));
  }

  .episode-card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 5px;
    background: linear-gradient(180deg, #0f766e 0%, #f59e0b 100%);
    opacity: 0.86;
  }

  .episode-card:hover,
  .episode-card:focus-within {
    transform: translateY(-4px);
    border-color: rgba(15, 118, 110, 0.18);
    box-shadow: var(--shadow-strong);
  }

  .episode-card h2,
  .empty-state h2 {
    margin: 0.35rem 0 0.65rem;
    font-size: clamp(1.45rem, 2vw, 1.9rem);
    line-height: 1.08;
  }

  .episode-card h2 a {
    transition: color 160ms ease;
  }

  .episode-card:hover h2 a,
  .episode-card:focus-within h2 a {
    color: var(--accent-strong);
  }

  .meta,
  .summary,
  .body,
  .episode-card ul,
  .empty-state p {
    margin: 0;
  }

  .body {
    margin-top: 0.75rem;
    white-space: pre-line;
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 4;
  }

  .episode-card ul {
    padding-left: 1rem;
    margin-top: 0.95rem;
    color: var(--muted);
    line-height: 1.7;
    columns: 2;
    column-gap: 1.6rem;
  }

  .empty-state {
    padding: 1.4rem;
  }

  .pager {
    margin-top: 1rem;
  }

  .pager button:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  @media (max-width: 960px) {
    .archive-stats,
    .controls-grid {
      grid-template-columns: 1fr;
    }

    .episode-card ul {
      columns: 1;
    }
  }
</style>
