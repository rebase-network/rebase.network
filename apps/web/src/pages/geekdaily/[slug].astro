---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DetailSidebarLinksSection from '@/components/DetailSidebarLinksSection.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import { getGeekDailyEpisodeBySlug, getGeekDailyEpisodes, getSiteSettings } from '@/lib/content';
import { formatDate } from '@/lib/dates';
import { getGeekDailyPath } from '@/lib/paths';

const geekDailyTemplateOutro =
  'Rebase 极客日报由社区志愿者共同维护，持续整理值得关注的技术内容与行业信号。';

const extractGeekDailyBodyNote = (bodyMarkdown: string) => {
  const normalized = bodyMarkdown.trim();

  if (!normalized || !normalized.endsWith(geekDailyTemplateOutro)) {
    return normalized;
  }

  const outroMarker = `\n\n---\n\n${geekDailyTemplateOutro}`;
  const noteMarker = '\n\n## 本期补充\n\n';
  const noteStart = normalized.indexOf(noteMarker);
  const outroStart = normalized.lastIndexOf(outroMarker);

  if (noteStart === -1 || outroStart === -1 || outroStart <= noteStart) {
    return '';
  }

  return normalized.slice(noteStart + noteMarker.length, outroStart).trim();
};

const slug = Astro.params.slug ?? '';
const [site, episode, episodes] = await Promise.all([getSiteSettings(), getGeekDailyEpisodeBySlug(slug), getGeekDailyEpisodes()]);
const related = episode ? episodes.filter((item) => item.slug !== episode.slug).slice(0, 2) : [];
const episodeNote = episode ? extractGeekDailyBodyNote(episode.body) : '';
const episodeActionLinks = [
  { href: '/geekdaily/rss.xml', label: '订阅 GeekDaily RSS' },
  { href: '/geekdaily', label: '回到 GeekDaily 列表' },
];
const episodeRelatedLinks = related.map((item) => ({
  href: getGeekDailyPath(item.episodeNumber),
  label: item.title,
}));

if (!episode) {
  Astro.response.status = 404;
}
---

<BaseLayout
  site={site}
  title={episode ? episode.title : 'GeekDaily 未找到'}
  description={episode ? episode.summary : '你访问的 GeekDaily 内容暂时无法找到。'}
  noindex={!episode}
>
  {episode ? (
    <>
      <section class="shell page-section detail-shell">
        <article id="episode-body" class="card detail-body-card episode-detail">
          <header class="episode-head">
            <p class="episode-eyebrow">极客日报 #{episode.episodeNumber}</p>
            <h1>{episode.title}</h1>
            <p class="episode-summary">{episode.summary}</p>
            <div class="detail-body-lead lead">
              <p>{formatDate(episode.publishedAt)}</p>
              {episode.editors.length > 0 && <p>本期编辑：{episode.editors.join('、')}</p>}
              {episode.tags.length > 0 && (
                <ul>
                  {episode.tags.map((tag) => <li>{tag}</li>)}
                </ul>
              )}
            </div>
          </header>
          {episodeNote ? (
            <MarkdownContent content={episodeNote} />
          ) : (
            <p class="episode-note-empty">本期内容由结构化推荐条目自动整理，无需额外补充说明。</p>
          )}
          <section id="episode-items" class="item-section">
            <h2>本期推荐</h2>
            <div class="item-list">
              {episode.items.map((item, index) => (
                <article class="item-card">
                  <span>#{index + 1}</span>
                  <div>
                    <h3>
                      <a href={item.sourceUrl} target="_blank" rel="noreferrer">
                        {item.title}
                      </a>
                    </h3>
                    <p class="author">推荐人：{item.author}</p>
                    <p class="summary">{item.summary}</p>
                  </div>
                </article>
              ))}
            </div>
          </section>
          <section class="episode-outro">
            <p>{geekDailyTemplateOutro}</p>
          </section>
        </article>

        <aside class="card detail-sidebar">
          <section id="episode-info" class="detail-sidebar-section">
            <h2>期数信息</h2>
            <ul class="detail-fact-list">
              <li>
                <strong>发布时间</strong>
                <span>{formatDate(episode.publishedAt)}</span>
              </li>
              <li>
                <strong>条目数量</strong>
                <span>{episode.items.length} 条推荐</span>
              </li>
              <li>
                <strong>本期编辑</strong>
                <span>{episode.editors.length > 0 ? episode.editors.join('、') : '待补充'}</span>
              </li>
              <li>
                <strong>链接规范</strong>
                <span><code>{getGeekDailyPath(episode.episodeNumber)}</code></span>
              </li>
            </ul>
            {episode.tags.length > 0 && (
              <ul class="detail-tag-list">
                {episode.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            )}
          </section>

          <DetailSidebarLinksSection
            id="episode-actions"
            title="继续追踪"
            copy="GeekDaily 详情页除了正文，还保留了逐条推荐和固定路径，适合从搜索结果重新进入。"
            links={episodeActionLinks}
          />

          {related.length > 0 && (
            <DetailSidebarLinksSection
              id="episode-related"
              title="相关期数"
              links={episodeRelatedLinks}
              listClass="related-list"
            />
          )}
        </aside>
      </section>
    </>
  ) : (
    <section class="shell page-hero single">
      <article class="hero-panel card">
        <p class="hero-kicker">404</p>
        <h1 class="hero-title">这期 GeekDaily 暂时没有被找到。</h1>
        <p class="hero-summary">你可以先回到 GeekDaily 列表，继续浏览最近与历史归档。</p>
      </article>
    </section>
  )}
</BaseLayout>

<style>
  .episode-head {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.35rem;
    border-bottom: 1px solid rgba(31, 41, 51, 0.08);
  }

  .episode-eyebrow {
    margin: 0;
    color: var(--accent-strong);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .episode-head h1 {
    margin: 0;
    font-size: clamp(2rem, 3.4vw, 3rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
  }

  .episode-summary {
    margin: 0;
    max-width: 62ch;
    color: var(--muted);
    line-height: 1.8;
  }

  .lead ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .lead li {
    padding: 0.42rem 0.72rem;
    border-radius: 999px;
    background: rgba(245, 158, 11, 0.12);
    color: #92400e;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .item-list {
    display: grid;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .item-section {
    margin-top: 1.5rem;
  }

  .item-section h2 {
    margin: 0;
    font-size: 1.45rem;
  }

  .episode-note-empty,
  .episode-outro {
    margin-top: 1.35rem;
    padding: 1rem 1.1rem;
    border-radius: 1rem;
    background: rgba(15, 118, 110, 0.06);
    color: rgba(17, 24, 39, 0.82);
  }

  .episode-outro p,
  .episode-note-empty {
    margin: 0;
  }

  .item-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(31, 41, 51, 0.08);
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
  }

  .item-card:hover,
  .item-card:focus-within {
    transform: translateY(-3px);
    border-color: rgba(15, 118, 110, 0.16);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 18px 32px rgba(15, 118, 110, 0.08);
  }

  .item-card span {
    display: grid;
    width: 2.2rem;
    height: 2.2rem;
    place-items: center;
    border-radius: 0.75rem;
    background: rgba(15, 118, 110, 0.1);
    color: var(--accent-strong);
    font-weight: 800;
  }

  .item-card h3,
  .author,
  .summary {
    margin: 0;
  }

  .item-card h3 {
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .author {
    margin-top: 0.45rem;
    color: var(--accent-strong);
    font-size: 0.84rem;
    font-weight: 700;
  }

  .summary {
    margin-top: 0.65rem;
    color: var(--muted);
    line-height: 1.75;
  }
</style>
